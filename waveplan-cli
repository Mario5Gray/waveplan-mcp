    fin_p.add_argument("git_sha", nargs="?", default="", help="Optional git SHA of the commit")
    get_p = sub.add_parser("get", help="Report tasks: get [all|taken|open|complete|deptree|task-<id>|<agent>]")
    get_p.add_argument("mode", nargs="?", default="all",
                        help="Filter: all (default), taken, open, complete, deptree, task-<id>, or agent name")
    get_p.add_argument("--json", action="store_true", help="Output in JSON format")
    list_p = sub.add_parser("list_plans", help="List available execution wave plans")
    list_p.add_argument("--plan-dir", dest="plan_dir", nargs="?", default=None,
                        help="Directory to search for plans")
    sub.add_parser("deptree", help="Show tasks in dependency order with parallel groups")
    swim_p = sub.add_parser("swim", help="SWIM deterministic tooling")
    swim_sub = swim_p.add_subparsers(dest="swim_command", required=True)
    swim_compile = swim_sub.add_parser(
        "compile-plan-json",
        help="Deterministically validate + canonicalize a swim execution-waves JSON plan",
    )
    swim_compile.add_argument("--in", dest="input_path", required=True, help="Input *-execution-waves.json path")
    swim_compile.add_argument("--out", dest="output_path", required=False, help="Output path (prints to stdout if omitted)")
    swim_compile_schedule = swim_sub.add_parser(
        "compile-schedule",
        help="Compile a SWIM execution schedule from a plan and waveagents file",
    )
    swim_compile_schedule.add_argument("--plan", required=True, help="Input plan JSON path")
    swim_compile_schedule.add_argument(
        "--agents",
        required=False,
        help="Input waveagents JSON path (default: ~/.config/waveplan-mcp/waveagents.json)",
    )
    swim_compile_schedule.add_argument("--out", required=False, help="Optional output schedule JSON path")
    swim_compile_schedule.add_argument(
        "--task-scope",
        choices=("all", "open"),
        default="all",
        help="Task scope to compile into the schedule",
    )
    swim_compile_schedule.add_argument(
        "--bootstrap-state",
        action="store_true",
        help="Create <plan>.state.json if it does not already exist",
    )
    swim_next = swim_sub.add_parser(
        "next",
        help="Resolve the next SWIM step without applying it",
    )
    swim_next.add_argument("--schedule", required=True, help="Input schedule JSON path")
    swim_next.add_argument("--journal", required=False, help="Optional journal JSON path")
    swim_next.add_argument("--state", required=False, help="Optional state JSON path")
    swim_step = swim_sub.add_parser(
        "step",
        help="Inspect, apply, or acknowledge a single SWIM step",
    )
    swim_step.add_argument("--schedule", required=False, help="Input schedule JSON path")
    swim_step.add_argument("--journal", required=False, help="Optional journal JSON path")
    swim_step.add_argument("--state", required=False, help="Optional state JSON path")
    seq_or_step = swim_step.add_mutually_exclusive_group()
    seq_or_step.add_argument("--seq", type=int, required=False, help="Target sequence number")
    seq_or_step.add_argument("--step-id", required=False, help="Target step_id")
    step_mode = swim_step.add_mutually_exclusive_group()
    step_mode.add_argument("--apply", action="store_true", help="Apply the selected step")
    swim_step.add_argument("--tail-logs", action="store_true",
                           help="After --apply, print tailed stdout/stderr logs to stderr")
    swim_step.add_argument("--tail-lines", type=int, default=40,
                           help="Number of lines to print per tailed log (default: 40)")
    step_mode.add_argument("--ack-unknown", metavar="STEP_ID", help="Acknowledge an unknown step by step_id")
    swim_step.add_argument("--as", dest="ack_as", choices=("failed", "waived"), required=False,
                           help="Outcome to record for --ack-unknown")
    swim_run = swim_sub.add_parser(
        "run",
        help="Run SWIM steps until a stop condition is met",
    )
    swim_run.add_argument("--schedule", required=True, help="Input schedule JSON path")
    swim_run.add_argument("--journal", required=False, help="Optional journal JSON path")
    swim_run.add_argument("--state", required=False, help="Optional state JSON path")
    swim_run.add_argument("--until", required=True, help="Stop condition: action, seq:N, or step:<id>")
    swim_run.add_argument("--dry-run", action="store_true", help="Resolve without mutating state")
    swim_run.add_argument("--max-steps", type=int, required=False, help="Maximum number of steps to process")
    swim_journal = swim_sub.add_parser(
        "journal",
        help="Inspect a SWIM journal",
    )
    swim_journal.add_argument("--schedule", required=True, help="Input schedule JSON path")
    swim_journal.add_argument("--journal", required=False, help="Optional journal JSON path")
    swim_journal.add_argument("--tail", type=int, required=False, help="Show the last N journal events")
    swim_validate = swim_sub.add_parser(
        "validate",
        help="Validate a SWIM artifact by kind",
    )
    swim_validate.add_argument("--kind", choices=("schedule", "journal", "plan"), required=True, help="Artifact kind")
    swim_validate.add_argument("--in", dest="input_path", required=True, help="Input artifact path")
    swim_refine_p = swim_sub.add_parser(
        "refine",
        help="Compile a coarse plan into a refinement sidecar (deterministic)",
    )
    swim_refine_p.add_argument("--plan", required=True, help="Input coarse *-execution-waves.json path")
    swim_refine_p.add_argument("--targets", required=True, nargs="+", metavar="UNIT_ID",
                               help="Unit IDs to refine (space-separated)")
    swim_refine_p.add_argument("--profile", default="8k", help="Refinement profile (v1: 8k only)")
    swim_refine_p.add_argument("--out", required=False, help="Output path (prints to stdout if omitted)")
    swim_refine_p.add_argument("--invoker", required=False,
                               help="Invoker script path used in emitted invoke.argv")
    swim_refine_run_p = swim_sub.add_parser(
        "refine-run",
        help="Execute a refinement sidecar's fine steps with parent rollup",
    )
    swim_refine_run_p.add_argument("--refine", required=True, help="Path to refinement sidecar JSON")
    swim_refine_run_p.add_argument("--refine-journal", dest="refine_journal", required=False,
                                   help="Fine journal path (default: <refine>.journal.json)")
    swim_refine_run_p.add_argument("--coarse-journal", dest="coarse_journal", required=False,
                                   help="Coarse journal path for rollup events")
    swim_refine_run_p.add_argument("--state", required=False,
                                   help="Live waveplan state file (required unless --dry-run)")
    swim_refine_run_p.add_argument("--dry-run", dest="dry_run", action="store_true",
                                   help="Resolve path without lock, invoke, or journal mutation")
    swim_refine_run_p.add_argument("--work-dir", dest="work_dir", required=False,
                                   help="Working directory passed to invoke")

    context_p = sub.add_parser("context", help="Context estimation tools")
    context_sub = context_p.add_subparsers(dest="context_command", required=True)

    context_estimate = context_sub.add_parser(
        "estimate",
        help="Estimate context footprint of an issue candidate",
    )
    context_estimate.add_argument("--candidate", required=True, help="Path to ContextCandidate JSON file")
    context_estimate.add_argument("--budget", default="64000:192000", help="Budget range min:max in tokens (default: 64000:192000)")
    context_estimate.add_argument("--base-dir", dest="base_dir", required=False, help="Root for resolving referenced file paths")

    args = parser.parse_args()

    if args.command == "swim" and args.swim_command == "compile-plan-json":
        try:
            _swim_compile_plan_json(args.input_path, args.output_path)
        except ValueError as e:
            print(f"ERROR: {e}", file=sys.stderr)
            sys.exit(1)
        return
    if args.command == "swim":
        if args.swim_command == "compile-schedule":
            _handle_swim_compile_schedule(args)
        elif args.swim_command == "next":
            schedule_path = _abs_user_path(args.schedule)
            journal_path = _abs_user_path(args.journal) or _default_swim_journal(schedule_path)
            state_path = _abs_user_path(args.state) or _derive_swim_state(schedule_path)
            if not state_path:
                _emit_json({"ok": False, "error": "could not derive state path", "subcommand": "next"}, 3)
            _handle_swim_subprocess("next-resolve", [
                "--schedule", schedule_path,
                "--journal", journal_path,
                "--state", state_path,
            ], "next")
        elif args.swim_command == "step":
            if args.ack_unknown:
                if not args.journal:
                    _emit_json({"ok": False, "error": "--journal is required for --ack-unknown", "subcommand": "step"}, 2)
                if not getattr(args, "ack_as", None):
                    _emit_json({"ok": False, "error": "--as is required for --ack-unknown", "subcommand": "step"}, 2)
                _handle_swim_subprocess("step", [
                    "--journal", _abs_user_path(args.journal),
                    "--ack-unknown", args.ack_unknown,
                    "--as", args.ack_as,
                ], "step")
                return
            schedule = _abs_user_path(args.schedule)
            if not schedule:
                _emit_json({"ok": False, "error": "--schedule is required", "subcommand": "step"}, 2)
            journal_path = _abs_user_path(args.journal) or _default_swim_journal(schedule)
            state_path = _abs_user_path(args.state) or _derive_swim_state(schedule)
            if not state_path:
                _emit_json({"ok": False, "error": "could not derive state path", "subcommand": "step"}, 3)
            tool_args = ["--schedule", schedule, "--journal", journal_path, "--state", state_path]
            if args.seq is not None:
                tool_args.extend(["--seq", str(args.seq)])
            if args.step_id:
                tool_args.extend(["--step-id", args.step_id])
            if args.apply:
                tool_args.append("--apply")
            proc = _run_swim_go("step", tool_args)
            stdout = proc.stdout.strip()
            stderr = proc.stderr.strip()
            if stdout:
                print(stdout)
            if args.apply and getattr(args, "tail_logs", False) and stdout:
                _tail_apply_logs(stdout, schedule, max(0, int(getattr(args, "tail_lines", 40))))
            if proc.returncode == 0:
                return
            if stdout:
                sys.exit(proc.returncode)
            _emit_json({
                "ok": False,
                "error": stderr or "swim-step failed",
                "subcommand": "step",
            }, proc.returncode if proc.returncode in (2, 3, 4) else 3)
        elif args.swim_command == "run":
            schedule_path = _abs_user_path(args.schedule)
            journal_path = _abs_user_path(args.journal) or _default_swim_journal(schedule_path)
            state_path = _abs_user_path(args.state) or _derive_swim_state(schedule_path)
            if not state_path:
                _emit_json({"ok": False, "error": "could not derive state path", "subcommand": "run"}, 3)
            tool_args = [
                "--schedule", schedule_path,
                "--journal", journal_path,
                "--state", state_path,
                "--until", args.until,
            ]
            if args.dry_run:
                tool_args.append("--dry-run")
            if args.max_steps is not None:
                tool_args.extend(["--max-steps", str(args.max_steps)])
            _handle_swim_subprocess("run", tool_args, "run")
        elif args.swim_command == "journal":
            schedule_path = _abs_user_path(args.schedule)
            journal_path = _abs_user_path(args.journal) or _default_swim_journal(schedule_path)
            tool_args = ["--schedule", schedule_path, "--journal", journal_path]
            if args.tail is not None:
                tool_args.extend(["--tail", str(args.tail)])
            _handle_swim_subprocess("journal", tool_args, "journal")
        elif args.swim_command == "validate":
            _handle_swim_validate(args)
        elif args.swim_command == "refine":
            _handle_swim_refine(args)
        elif args.swim_command == "refine-run":
            _handle_swim_refine_run(args)
        else:
            _swim_not_wired(args.swim_command)
        return

    if args.command == "context":
        if args.context_command == "estimate":
            _handle_context_estimate(args)
        else:
            _swim_not_wired(args.context_command)
        return

    server_bin = args.mcp_bin or _SERVER_BIN
    if not os.path.isfile(server_bin):
        print(f"ERROR: waveplan-mcp binary not found at '{server_bin}'. "
              f"Set WAVEPLAN_MCP_BIN or --mcp-bin.", file=sys.stderr)
        sys.exit(1)

    env = _build_env(args.plan)
    client = MCPPhone(server_bin, env)
    try:
        # Initialize the MCP session
        client._send("initialize", {
            "protocolVersion": MCP_PROTOCOL_VERSION,
            "capabilities": {},
        })
        client._send("notifications/initialized", None, notify=True)

        # Route CLI command -> MCP tool call
        cmd = args.command
        if cmd == "peek":
            result = client.call_tool("waveplan_peek")
        elif cmd == "pop":
            result = client.call_tool("waveplan_pop", {"agent": args.agent})
        elif cmd == "start_review":
            result = client.call_tool("waveplan_start_review", {
                "task_id": args.task_id,
                "reviewer": args.reviewer,
            })
        elif cmd == "start_fix":
            result = client.call_tool("waveplan_start_fix", {
                "task_id": args.task_id,
            })
        elif cmd == "end_review":
            result = client.call_tool("waveplan_end_review", {
                "task_id": args.task_id,
                "review_note": args.review_note or None,
            })
        elif cmd == "fin":
            result = client.call_tool("waveplan_fin", {
                "task_id": args.task_id,
                "git_sha": args.git_sha or None,
            })
        elif cmd == "get":
            result = client.call_tool("waveplan_get", {"mode": args.mode})
        elif cmd == "list_plans":
            result = client.call_tool("waveplan_list_plans", {
                "plan_dir": args.plan_dir or None,
            })
        elif cmd == "deptree":
            result = client.call_tool("waveplan_deptree", {})
        else:
            print(f"ERROR: unknown command '{cmd}'", file=sys.stderr)
            sys.exit(1)

        # Pretty-print the JSON result
        print(json.dumps(result, indent=2))

    except RuntimeError as e:
        print(f"ERROR: {e}", file=sys.stderr)
        sys.exit(1)
    finally:
        client.close()


if __name__ == "__main__":
    main()
