+	if reviewSchedulePath == "" {
+		return &schedule, nil
+	}
+
+	reviewRaw, err := os.ReadFile(reviewSchedulePath)
+	if err != nil {
+		return nil, fmt.Errorf("read review schedule sidecar: %w", err)
+	}
+	if err := ValidateReviewScheduleSidecar(reviewRaw, &schedule); err != nil {
