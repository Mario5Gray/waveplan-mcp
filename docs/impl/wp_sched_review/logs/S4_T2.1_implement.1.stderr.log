+			if _, ok := emitted[ins.ID]; ok {
+				return fmt.Errorf("duplicate insertion id during merge: %s", ins.ID)
+			}
+			emitted[ins.ID] = struct{}{}
+			merged = append(merged, scheduleRowFromInsertion(ins))
+			if err := appendChildren(ins.ID); err != nil {
+				return err
+			}
+		}
+		return nil
+	}
