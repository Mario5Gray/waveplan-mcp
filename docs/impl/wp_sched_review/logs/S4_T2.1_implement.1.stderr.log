+		BaseSchedulePath: baseSchedulePath,
+		Insertions:       insertions,
+	}, "", "  ")
+	if err != nil {
+		t.Fatalf("marshal review sidecar: %v", err)
+	}
+	body = append(body, '\n')
+	if err := os.WriteFile(path, body, 0o644); err != nil {
+		t.Fatalf("write review sidecar: %v", err)
+	}
+}

