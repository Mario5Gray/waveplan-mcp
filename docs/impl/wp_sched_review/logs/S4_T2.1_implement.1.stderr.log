+func mergeExecutionWithReviewInsertions(base []ScheduleRow, insertions []ReviewScheduleInsertion) ([]ScheduleRow, error) {
+	if len(insertions) == 0 {
+		out := append([]ScheduleRow(nil), base...)
+		for i := range out {
+			out[i].Seq = i + 1
+		}
+		return out, nil
+	}
