    11	)
    12	
    13	// SafeExecOptions wraps one-step execution with lock ownership and
    14	// snapshot-based race closure.
    15	type SafeExecOptions struct {
    16		SchedulePath       string
    17		ReviewSchedulePath string
    18		JournalPath        string
    19		StatePath          string
    20		ArtifactRoot       string
    21		LockPath           string
    22		WorkDir            string
    23		ExpectCursor       *int
    24		InvokeFn           func(argv []string, workDir string) error
    25		ReadSnapshotFn     func(path string) (*StateSnapshot, error)
    26	}
    27	
    28	// ExecuteNextStepSafe runs one schedule step under the T2.5 A/B/C protocol.
    29	func ExecuteNextStepSafe(opts SafeExecOptions) (*ExecNextResult, error) {
    30		if opts.SchedulePath == "" {
    31			return nil, fmt.Errorf("missing schedule path")
    32		}
    33		if opts.JournalPath == "" {
    34			return nil, fmt.Errorf("missing journal path")
    35		}
    36		if opts.StatePath == "" {
    37			return nil, fmt.Errorf("missing state path")
    38		}
    39	
    40		lockPath := opts.LockPath
    41		if lockPath == "" {
    42			lockPath = DeriveLockPath(opts.SchedulePath, opts.ArtifactRoot)
    43		}
    44		lock, err := AcquireLock(lockPath)
    45		if err != nil {
    46			return nil, err
    47		}
    48		defer func() {
    49			_ = lock.Release()
    50		}()
    51	
    52		if _, err := DetectAndMarkUnknown(opts.JournalPath); err != nil {
    53			return nil, err
    54		}
    55	
    56		schedule, err := loadSchedule(opts.SchedulePath, opts.ReviewSchedulePath)
    57		if err != nil {
    58			return nil, err
    59		}
    60		journal, err := loadOrInitJournal(opts.JournalPath, opts.SchedulePath)
    61		if err != nil {
    62			return nil, err
    63		}
    64		if opts.ExpectCursor != nil && journal.Cursor != *opts.ExpectCursor {
    65			return nil, fmt.Errorf("cursor mismatch: expected=%d actual=%d", *opts.ExpectCursor, journal.Cursor)
    66		}
    67	
    68		readSnapshot := opts.ReadSnapshotFn
    69		if readSnapshot == nil {
    70			readSnapshot = ReadStateSnapshotOrEmpty
    71		}
    72	
    73		snapA, err := readSnapshot(opts.StatePath)
    74		if err != nil {
    75			return nil, err
    76		}
    77	
    78		decision := ResolveNext(schedule, journal, snapA)
    79		recoverDispatch := false
    80		if decision.Action == ActionReady && isDispatchAction(decision.Row.Action) && anyDispatchReceiptExists(opts.SchedulePath, opts.ArtifactRoot, decision.Row.StepID) {
    81			if err := AdvanceStateSnapshot(opts.StatePath, opts.SchedulePath, decision.Row.TaskID, Predict(decision.Row), time.Now().UTC()); err != nil {
    82				return nil, err
    83			}
    84			return appendAdoptedAppliedResult(opts, journal, decision.Row, Predict(decision.Row), "receipt_adopt")
    85		}
    86		switch decision.Action {
    87		case ActionDone:
    88			if err := saveJournal(opts.JournalPath, journal); err != nil {
    89				return nil, err
    90			}
    91			return &ExecNextResult{
    92				Done:     true,
    93				Cursor:   journal.Cursor,
    94				Journal:  opts.JournalPath,
    95				Schedule: opts.SchedulePath,
    96			}, nil
    97		case ActionReady:
    98			// Continue.
    99		case ActionBlocked, ActionDrift:
   100			if decision.Row.StepID == "" {
   101				return &ExecNextResult{
   102					Done:     false,
   103					Cursor:   journal.Cursor,
   104					Outcome:  "blocked",
   105					Journal:  opts.JournalPath,
   106					Schedule: opts.SchedulePath,
   107				}, nil
   108			}
   109			if decision.Action == ActionDrift {
   110				actual := snapA.StatusOf(decision.Row.TaskID)
   111				if actual == Predict(decision.Row) {
   112					if isDispatchAction(decision.Row.Action) && !anyDispatchReceiptExists(opts.SchedulePath, opts.ArtifactRoot, decision.Row.StepID) {
   113						recoverDispatch = true
   114						break
   115					}
   116					return appendAdoptedAppliedResult(opts, journal, decision.Row, actual, "idempotent_adopt")
   117				}
   118			}
   119			return appendBlockedResult(opts, journal, decision.Row, decision.Reason, snapA.StatusOf(decision.Row.TaskID))
   120		default:
   121			return nil, fmt.Errorf("unsupported resolver action: %s", decision.Action)
   122		}
   123	
   124		snapB, err := readSnapshot(opts.StatePath)
   125		if err != nil {
   126			return nil, err
   127		}
   128		if snapA.Token() != snapB.Token() {
   129			actual := snapB.StatusOf(decision.Row.TaskID)
   130			reason := fmt.Sprintf(
   131				"state_token_mismatch: before=%s after=%s task=%s actual=%s",
   132				snapA.Token(),
   133				snapB.Token(),
   134				decision.Row.TaskID,
   135				actual,
   136			)
   137			return appendBlockedResult(opts, journal, decision.Row, reason, actual)
   138		}
   139		if recoverDispatch && snapB.StatusOf(decision.Row.TaskID) != Predict(decision.Row) {
   140			actual := snapB.StatusOf(decision.Row.TaskID)
   141			reason := fmt.Sprintf(
   142				"dispatch_recovery_lost_state: action=%s produces=%s actual=%s",
   143				decision.Row.Action,
   144				Predict(decision.Row),
   145				actual,
   146			)
   147			return appendBlockedResult(opts, journal, decision.Row, reason, actual)
   148		}
   149	
   150		eventIndex := len(journal.Events)
   151		event := makeInFlightEvent(journal, decision.Row)
   152		event.StdoutPath, event.StderrPath = deriveLogPaths(opts.SchedulePath, opts.ArtifactRoot, decision.Row.StepID, event.Attempt)
   153		stdoutAbsPath, stderrAbsPath := deriveLogAbsPaths(opts.SchedulePath, opts.ArtifactRoot, decision.Row.StepID, event.Attempt)
   154		receiptPath := ""
   155		extraEnv := map[string]string{}
   156		if isDispatchAction(decision.Row.Action) {
   157			receiptPath = deriveDispatchReceiptPath(opts.SchedulePath, opts.ArtifactRoot, decision.Row.StepID, event.Attempt)
   158			extraEnv["SWIM_DISPATCH_RECEIPT_PATH"] = dispatchReceiptAbsPath(opts.SchedulePath, opts.ArtifactRoot, decision.Row.StepID, event.Attempt)
   159			extraEnv["SWIM_STEP_ID"] = decision.Row.StepID
   160			extraEnv["SWIM_TASK_ID"] = decision.Row.TaskID
   161			extraEnv["SWIM_ACTION"] = decision.Row.Action
   162		}
   163		if decision.Row.Action == "fix" {
   164			for i := len(journal.Events) - 1; i >= 0; i-- {
   165				ev := journal.Events[i]
   166				if ev.Action != "review" || ev.TaskID != decision.Row.TaskID || ev.StdoutPath == "" {
   167					continue
   168				}
   169				if filepath.IsAbs(ev.StdoutPath) {
   170					extraEnv["SWIM_PRIOR_STDOUT_PATH"] = ev.StdoutPath
   171				} else {
   172					extraEnv["SWIM_PRIOR_STDOUT_PATH"] = filepath.Join(filepath.Dir(opts.SchedulePath), ev.StdoutPath)
   173				}
   174				break
   175			}
   176		}
   177		journal.Events = append(journal.Events, event)
   178		last := journal.Events[eventIndex]
   179		journal.LastEvent = &last
   180		if err := saveJournal(opts.JournalPath, journal); err != nil {
   181			return nil, err
   182		}
   183		if err := WriteLockHolder(lock.f, os.Getpid(), time.Now().UTC().Format(time.RFC3339)); err != nil {
   184			return nil, err
   185		}
   186	
   187		runErr := invokeArgv(decision.Row.Invoke.Argv, opts.WorkDir, stdoutAbsPath, stderrAbsPath, extraEnv, opts.InvokeFn)
   188		exitCode := 0
   189		outcome := "applied"
   190		reason := ""
   191		stateAfter := Predict(decision.Row)
   192		if runErr != nil {
   193			exitCode = exitCodeFromErr(runErr)
   194			if isDispatchAction(decision.Row.Action) {
   195				snapC, err := readSnapshot(opts.StatePath)
   196				if err != nil {
   197					return nil, err
   198				}
   199				actual := snapC.StatusOf(decision.Row.TaskID)
   200				if actual == Predict(decision.Row) && !dispatchReceiptExists(opts.SchedulePath, opts.ArtifactRoot, decision.Row.StepID, event.Attempt) {
   201					outcome = "blocked"
   202					reason = fmt.Sprintf(
   203						"incomplete_dispatch: action=%s produces=%s actual=%s receipt_missing=%s invoke_error=%s",
   204						decision.Row.Action,
   205						Predict(decision.Row),
   206						actual,
   207						receiptPath,
   208						runErr.Error(),
   209					)
   210					stateAfter = actual
   211				} else {
   212					outcome = "failed"
   213					reason = runErr.Error()
   214					stateAfter = Status(decision.Row.Requires.TaskStatus)
   215				}
   216			} else {
   217				outcome = "failed"
   218				reason = runErr.Error()
   219				stateAfter = Status(decision.Row.Requires.TaskStatus)
   220			}

