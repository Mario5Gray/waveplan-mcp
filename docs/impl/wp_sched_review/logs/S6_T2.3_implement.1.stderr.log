			StepID:        "S1_T1.1_review_r2",
			SeqHint:       1,
			TaskID:        "T1.1",
			Action:        "review",
			Requires:      StatusWrapper{TaskStatus: "taken"},
			Produces:      StatusWrapper{TaskStatus: "review_taken"},
