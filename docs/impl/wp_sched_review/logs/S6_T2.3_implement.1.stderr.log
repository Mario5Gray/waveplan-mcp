		t.Fatalf("Code = %q, want %q", d.Code, ResolutionUnknownPending)
	}
	if d.Cursor != 0 {
		t.Fatalf("Cursor = %d, want 0", d.Cursor)
	}
	if d.Reason == "" {
		t.Fatalf("Reason should be non-empty for unknown_pending")
	}
}

