   347	
   348	// RenderText renders a deterministic snapshot for --once style output.
   349	func RenderText(snapshot watch.Snapshot, options Options) string {
   350		var builder strings.Builder
   351		if !snapshot.LoadedAt.IsZero() {
   352			fmt.Fprintf(&builder, "Loaded: %s\n", snapshot.LoadedAt.Format(timeLayout))
   353		}
   354		if len(snapshot.Plans) == 0 {
   355			builder.WriteString("No plans loaded\n")
   356			return strings.TrimRight(builder.String(), "\n")
   357		}
   358	
   359		for planIndex, loaded := range snapshot.Plans {
   360			if planIndex > 0 {
   361				builder.WriteString("\n")
   362			}
   363			renderPlan(&builder, loaded, snapshot, options)
   364		}
   365		if len(snapshot.Plans) == 0 {
   366			builder.WriteString("No plans loaded\n")
   367		}
   368		renderTail(&builder, snapshot.States, options)
   369		renderJournals(&builder, snapshot.Journals, options)
   370		renderReviewSchedules(&builder, snapshot.ReviewSchedules)
   371		renderActiveLog(&builder, snapshot.Journals, snapshot.States, options)
   372		return strings.TrimRight(builder.String(), "\n")
   373	}
