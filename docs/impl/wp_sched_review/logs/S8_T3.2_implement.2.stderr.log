+func renderReviewSchedules(builder *strings.Builder, loadedReviewSchedules []watch.LoadedReviewSchedule) {
+	if len(loadedReviewSchedules) == 0 {
+		return
+	}
+	sorted := append([]watch.LoadedReviewSchedule(nil), loadedReviewSchedules...)
+	sort.Slice(sorted, func(left, right int) bool {
+		return sorted[left].Path < sorted[right].Path
+	})
+	builder.WriteString("\nReview Schedules\n")
+	for _, loaded := range sorted {
+		base := "-"
+		insertions := 0
+		if loaded.ReviewSchedule != nil {
+			insertions = len(loaded.ReviewSchedule.Insertions)
+			if loaded.ReviewSchedule.BaseSchedulePath != "" {
+				base = filepath.Base(loaded.ReviewSchedule.BaseSchedulePath)
+			}
+		}
+		fmt.Fprintf(builder, "  %s (insertions: %d, base: %s)\n", filepath.Base(loaded.Path), insertions, base)
+	}
+}
