        cmd = args.command
        if cmd == "peek":
            result = client.call_tool("waveplan_peek")
        elif cmd == "pop":
            result = client.call_tool("waveplan_pop", {"agent": args.agent})
        elif cmd == "start_review":
            result = client.call_tool("waveplan_start_review", {
                "task_id": args.task_id,
                "reviewer": args.reviewer,
            })
        elif cmd == "start_fix":
            result = client.call_tool("waveplan_start_fix", {
                "task_id": args.task_id,
            })
        elif cmd == "end_review":
            result = client.call_tool("waveplan_end_review", {
                "task_id": args.task_id,
                "review_note": args.review_note or None,
            })
        elif cmd == "fin":
            result = client.call_tool("waveplan_fin", {
                "task_id": args.task_id,
                "git_sha": args.git_sha or None,
            })
        elif cmd == "get":
            result = client.call_tool("waveplan_get", {"mode": args.mode})
        elif cmd == "list_plans":
            result = client.call_tool("waveplan_list_plans", {
                "plan_dir": args.plan_dir or None,
            })
        elif cmd == "deptree":
            result = client.call_tool("waveplan_deptree", {})
        else:
            print(f"ERROR: unknown command '{cmd}'", file=sys.stderr)
            sys.exit(1)

        # Pretty-print the JSON result
        print(json.dumps(result, indent=2))

    except RuntimeError as e:
        print(f"ERROR: {e}", file=sys.stderr)
        sys.exit(1)
    finally:
        client.close()


