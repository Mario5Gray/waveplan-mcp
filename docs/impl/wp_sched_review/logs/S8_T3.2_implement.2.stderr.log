+		t.Fatalf("insertion step = %q, want S1_T1.1_fix_r1", got)
+	}
+	if got := reviewSchedule.Insertions[0].SourceEventID; got != "E0001" {
+		t.Fatalf("source_event_id = %q, want E0001", got)
+	}
+}
