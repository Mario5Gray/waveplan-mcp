   489	def _tail_apply_logs(payload_text: str, schedule_path: str, tail_lines: int) -> None:
   490	    try:
   491	        payload = json.loads(payload_text)
   492	    except Exception:
   493	        return
   494	    if not isinstance(payload, dict):
   495	        return
   496	    for label, key in (("stdout", "stdout_path"), ("stderr", "stderr_path")):
   497	        path = payload.get(key)
   498	        if not isinstance(path, str) or not path:
   499	            continue
   500	        log_path = Path(path)
   501	        if not log_path.is_absolute():
   502	            log_path = Path(schedule_path).resolve().parent / log_path
   503	        if not log_path.exists():
   504	            print(f"==> {label}: {log_path} (missing)", file=sys.stderr)
   505	            continue
   506	        try:
   507	            lines = log_path.read_text(encoding="utf-8", errors="replace").splitlines()
   508	        except Exception as e:
   509	            print(f"==> {label}: {log_path} (read failed: {e})", file=sys.stderr)
   510	            continue
   511	        print(f"==> {label}: {log_path}", file=sys.stderr)
   512	        tail = lines[-tail_lines:] if tail_lines > 0 else lines
   513	        for line in tail:
   514	            print(line, file=sys.stderr)
