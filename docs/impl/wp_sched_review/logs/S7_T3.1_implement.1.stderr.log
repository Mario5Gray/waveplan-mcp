   845	def _derive_round_for_task(prefix: str, task_id: str, base_rows: list[dict], insertions: list[dict]) -> int:
   846	    pattern = re.compile(rf"^{re.escape(prefix)}_{re.escape(task_id)}_fix_r([0-9]+)$")
   847	    max_round = 0
   848	    for row in base_rows:
   849	        if row["task_id"] != task_id:
   850	            continue
   851	        match = pattern.match(row["step_id"])
   852	        if match:
   853	            max_round = max(max_round, int(match.group(1)))
   854	    for ins in insertions:
   855	        if ins.get("task_id") != task_id:
   856	            continue
   857	        step_id = ins.get("step_id")
   858	        if not isinstance(step_id, str):
   859	            continue
   860	        match = pattern.match(step_id)
   861	        if match:
   862	            max_round = max(max_round, int(match.group(1)))
   863	    return max_round + 1
   864	
   865	
   866	def _next_numeric_id(existing: list[str], regex: re.Pattern) -> int:
   867	    max_value = 0
   868	    for value in existing:
   869	        match = regex.match(value)
   870	        if not match:
   871	            continue
   872	        max_value = max(max_value, int(match.group(1)))
   873	    return max_value + 1
