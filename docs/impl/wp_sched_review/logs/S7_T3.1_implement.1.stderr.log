			ID:            "X1",
			AfterStepID:   "S1_T1.1_review",
			StepID:        "S1_T1.1_fix_r2",
			SeqHint:       2,
			TaskID:        "T1.1",
			Action:        "fix",
			Requires:      StatusWrapper{TaskStatus: "review_taken"},
			Produces:      StatusWrapper{TaskStatus: "taken"},
