+def _replace_or_append_mode(argv: list[str], mode: str) -> list[str]:
+    out = list(argv)
+    for i, token in enumerate(out):
+        if token == "--mode" and i + 1 < len(out):
+            out[i + 1] = mode
+            return out
+        if token.startswith("--mode="):
+            out[i] = f"--mode={mode}"
+            return out
+    out.extend(["--mode", mode])
+    return out
+
+
+def _ordered_review_insertion(row: dict) -> dict:
+    out: dict = {}
+    for key in _SIDECAR_INSERTION_FIELD_ORDER:
+        if key in row:
+            out[key] = row[key]
+    for key in sorted(row.keys()):
+        if key not in out:
+            out[key] = row[key]
+    return out
+
+
+def _canonicalize_review_sidecar(sidecar: dict) -> dict:
+    out: dict = {}
+    if "schema_version" in sidecar:
+        out["schema_version"] = sidecar["schema_version"]
+    if "base_schedule_path" in sidecar:
+        out["base_schedule_path"] = sidecar["base_schedule_path"]
+    insertions = sidecar.get("insertions", [])
+    if isinstance(insertions, list):
+        out["insertions"] = [_ordered_review_insertion(dict(row)) for row in insertions]
+    else:
+        out["insertions"] = []
+    for key in sorted(sidecar.keys()):
+        if key not in out:
+            out[key] = sidecar[key]
+    return out
+
