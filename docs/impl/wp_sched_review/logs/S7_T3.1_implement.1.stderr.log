  1084	            cmd.extend(["--base-dir", _abs_user_path(args.base_dir)])
  1085	        proc = subprocess.run(cmd, capture_output=True, text=True, cwd=_REPO_ROOT)
  1086	
  1087	    if proc.returncode != 0:
  1088	        _emit_json({
