+def _replace_or_append_mode(argv: list[str], mode: str) -> list[str]:
+    out = list(argv)
+    for i, token in enumerate(out):
+        if token == "--mode" and i + 1 < len(out):
+            out[i + 1] = mode
+            return out
+        if token.startswith("--mode="):
+            out[i] = f"--mode={mode}"
+            return out
+    out.extend(["--mode", mode])
+    return out
+
+
+def _ordered_review_insertion(row: dict) -> dict:
+    out: dict = {}
+    for key in _SIDECAR_INSERTION_FIELD_ORDER:
+        if key in row:
+            out[key] = row[key]
+    for key in sorted(row.keys()):
+        if key not in out:
+            out[key] = row[key]
+    return out
+
+
+def _canonicalize_review_sidecar(sidecar: dict) -> dict:
+    out: dict = {}
+    if "schema_version" in sidecar:
+        out["schema_version"] = sidecar["schema_version"]
+    if "base_schedule_path" in sidecar:
+        out["base_schedule_path"] = sidecar["base_schedule_path"]
+    insertions = sidecar.get("insertions", [])
+    if isinstance(insertions, list):
+        out["insertions"] = [_ordered_review_insertion(dict(row)) for row in insertions]
+    else:
+        out["insertions"] = []
+    for key in sorted(sidecar.keys()):
+        if key not in out:
+            out[key] = sidecar[key]
+    return out
+
+
+def _parse_schedule_rows_for_insert(schedule_path: str, subcommand: str) -> list[dict]:
+    if not schedule_path or not Path(schedule_path).is_file() or not os.access(schedule_path, os.R_OK):
+        _emit_json({
+            "ok": False,
+            "error": f"schedule path not readable: {schedule_path}",
+            "subcommand": subcommand,
+        }, 2)
+    try:
+        payload = json.loads(Path(schedule_path).read_text(encoding="utf-8"))
+    except Exception as e:
+        _emit_json({
+            "ok": False,
+            "error": f"read schedule failed: {e}",
+            "subcommand": subcommand,
+        }, 3)
+
+    if not isinstance(payload, dict):
+        _emit_json({
+            "ok": False,
+            "error": "invalid schedule: top-level JSON must be an object",
+            "subcommand": subcommand,
+        }, 3)
+    execution = payload.get("execution")
+    if not isinstance(execution, list) or not execution:
+        _emit_json({
+            "ok": False,
+            "error": "invalid schedule: execution must be a non-empty array",
+            "subcommand": subcommand,
+        }, 3)
+
+    rows: list[dict] = []
+    seen_step_ids: set[str] = set()
+    for idx, raw in enumerate(execution):
+        if not isinstance(raw, dict):
+            _emit_json({
+                "ok": False,
+                "error": f"invalid schedule row[{idx}]: row must be an object",
+                "subcommand": subcommand,
+            }, 3)
+        step_id = raw.get("step_id")
+        task_id = raw.get("task_id")
+        action = raw.get("action")
+        invoke = raw.get("invoke")
+        argv = invoke.get("argv") if isinstance(invoke, dict) else None
+        if not isinstance(step_id, str) or not step_id:
+            _emit_json({
+                "ok": False,
+                "error": f"invalid schedule row[{idx}]: missing step_id",
+                "subcommand": subcommand,
+            }, 3)
+        if step_id in seen_step_ids:
+            _emit_json({
+                "ok": False,
+                "error": f"invalid schedule: duplicate step_id {step_id}",
+                "subcommand": subcommand,
+            }, 3)
+        seen_step_ids.add(step_id)
+        if not isinstance(task_id, str) or not task_id:
+            _emit_json({
+                "ok": False,
+                "error": f"invalid schedule row[{idx}]: missing task_id",
+                "subcommand": subcommand,
+            }, 3)
+        if not isinstance(action, str) or not action:
+            _emit_json({
+                "ok": False,
+                "error": f"invalid schedule row[{idx}]: missing action",
+                "subcommand": subcommand,
+            }, 3)
+        if not isinstance(argv, list) or not argv or not all(isinstance(v, str) for v in argv):
+            _emit_json({
+                "ok": False,
+                "error": f"invalid schedule row[{idx}]: invoke.argv must be a non-empty string array",
+                "subcommand": subcommand,
+            }, 3)
+        rows.append({
+            "step_id": step_id,
+            "task_id": task_id,
+            "action": action,
+            "invoke_argv": list(argv),
+        })
+    return rows
+
+
+def _load_or_init_review_sidecar(review_schedule_path: str, schedule_path: str, subcommand: str) -> dict:
+    review_path = Path(review_schedule_path)
+    if not review_path.exists():
+        return {
+            "schema_version": 1,
+            "base_schedule_path": schedule_path,
+            "insertions": [],
+        }
+    try:
+        sidecar = json.loads(review_path.read_text(encoding="utf-8"))
+    except Exception as e:
+        _emit_json({
+            "ok": False,
+            "error": f"read review schedule sidecar failed: {e}",
+            "subcommand": subcommand,
+        }, 3)
+
+    if not isinstance(sidecar, dict):
+        _emit_json({
+            "ok": False,
+            "error": "invalid review schedule sidecar: top-level JSON must be an object",
+            "subcommand": subcommand,
+        }, 3)
+    if sidecar.get("schema_version") != 1:
+        _emit_json({
+            "ok": False,
+            "error": "invalid review schedule sidecar: schema_version must be 1",
+            "subcommand": subcommand,
+        }, 3)
+    base_schedule_path = sidecar.get("base_schedule_path")
+    if not isinstance(base_schedule_path, str) or not base_schedule_path.strip():
+        _emit_json({
+            "ok": False,
+            "error": "invalid review schedule sidecar: base_schedule_path must be a non-empty string",
+            "subcommand": subcommand,
+        }, 3)
+    try:
+        expected = str(Path(schedule_path).resolve())
+        got = str(Path(base_schedule_path).resolve())
+    except Exception:
+        expected = schedule_path
+        got = base_schedule_path
+    if got != expected:
+        _emit_json({
+            "ok": False,
+            "error": f"invalid review schedule sidecar: base_schedule_path {base_schedule_path!r} does not match --schedule {schedule_path!r}",
+            "subcommand": subcommand,
+        }, 2)
+
+    insertions = sidecar.get("insertions")
+    if not isinstance(insertions, list):
+        _emit_json({
+            "ok": False,
+            "error": "invalid review schedule sidecar: insertions must be an array",
+            "subcommand": subcommand,
+        }, 3)
+    for idx, row in enumerate(insertions):
+        if not isinstance(row, dict):
+            _emit_json({
+                "ok": False,
+                "error": f"invalid review schedule sidecar row[{idx}]: row must be an object",
+                "subcommand": subcommand,
+            }, 3)
+        for required_key in ("id", "after_step_id", "step_id", "seq_hint", "task_id", "action", "requires", "produces", "invoke", "reason", "source_event_id"):
+            if required_key not in row:
+                _emit_json({
+                    "ok": False,
+                    "error": f"invalid review schedule sidecar row[{idx}]: missing {required_key}",
+                    "subcommand": subcommand,
+                }, 3)
+        if not isinstance(row["id"], str) or not _SIDECAR_INSERTION_ID_RE.match(row["id"]):
+            _emit_json({
+                "ok": False,
+                "error": f"invalid review schedule sidecar row[{idx}]: id must match ^X[0-9]+$",
+                "subcommand": subcommand,
+            }, 3)
+        if not isinstance(row["step_id"], str) or not row["step_id"]:
+            _emit_json({
+                "ok": False,
+                "error": f"invalid review schedule sidecar row[{idx}]: step_id must be a non-empty string",
+                "subcommand": subcommand,
+            }, 3)
+        if not isinstance(row["after_step_id"], str) or not row["after_step_id"]:
+            _emit_json({
+                "ok": False,
+                "error": f"invalid review schedule sidecar row[{idx}]: after_step_id must be a non-empty string",
+                "subcommand": subcommand,
+            }, 3)
+        if not isinstance(row["seq_hint"], int) or row["seq_hint"] <= 0:
+            _emit_json({
+                "ok": False,
+                "error": f"invalid review schedule sidecar row[{idx}]: seq_hint must be a positive integer",
+                "subcommand": subcommand,
+            }, 3)
+        invoke = row.get("invoke")
+        argv = invoke.get("argv") if isinstance(invoke, dict) else None
+        if not isinstance(argv, list) or not argv or not all(isinstance(v, str) for v in argv):
+            _emit_json({
+                "ok": False,
+                "error": f"invalid review schedule sidecar row[{idx}]: invoke.argv must be a non-empty string array",
+                "subcommand": subcommand,
+            }, 3)
+    return sidecar
+
+
+def _extract_step_prefix(step_id: str) -> str | None:
+    match = _STEP_PREFIX_RE.match(step_id or "")
+    if not match:
+        return None
+    return match.group(1)
+
+
+def _derive_round_for_task(prefix: str, task_id: str, base_rows: list[dict], insertions: list[dict]) -> int:
+    pattern = re.compile(rf"^{re.escape(prefix)}_{re.escape(task_id)}_fix_r([0-9]+)$")
+    max_round = 0
+    for row in base_rows:
+        if row["task_id"] != task_id:
+            continue
+        match = pattern.match(row["step_id"])
+        if match:
+            max_round = max(max_round, int(match.group(1)))
+    for ins in insertions:
+        if ins.get("task_id") != task_id:
+            continue
+        step_id = ins.get("step_id")
+        if not isinstance(step_id, str):
+            continue
+        match = pattern.match(step_id)
+        if match:
+            max_round = max(max_round, int(match.group(1)))
+    return max_round + 1
+
+
+def _next_numeric_id(existing: list[str], regex: re.Pattern) -> int:
+    max_value = 0
+    for value in existing:
+        match = regex.match(value)
+        if not match:
+            continue
+        max_value = max(max_value, int(match.group(1)))
+    return max_value + 1
+
+
+def _handle_swim_insert_fix_loop(args: argparse.Namespace) -> None:
+    subcommand = "insert-fix-loop"
+    schedule_path = _abs_user_path(args.schedule)
+    if not schedule_path:
+        _emit_json({"ok": False, "error": "--schedule is required", "subcommand": subcommand}, 2)
+    review_schedule_path = _resolve_review_schedule_path(
+        schedule_path,
+        args.review_schedule,
+        subcommand=subcommand,
+        must_exist=False,
+    )
+    if not review_schedule_path:
+        _emit_json({"ok": False, "error": "missing review schedule", "subcommand": subcommand}, 2)
+
+    task_id = (args.task or "").strip()
+    if not task_id:
+        _emit_json({"ok": False, "error": "--task is required", "subcommand": subcommand}, 2)
+    if not _TASK_ID_RE.match(task_id):
+        _emit_json({"ok": False, "error": f"invalid task id: {task_id!r}", "subcommand": subcommand}, 2)
+
+    after_step = (args.after_step or "").strip()
+    if not after_step:
+        _emit_json({"ok": False, "error": "--after-step is required", "subcommand": subcommand}, 2)
+
+    if args.round is not None and args.round <= 0:
+        _emit_json({"ok": False, "error": "--round must be a positive integer", "subcommand": subcommand}, 2)
+
+    base_rows = _parse_schedule_rows_for_insert(schedule_path, subcommand)
+    sidecar = _load_or_init_review_sidecar(review_schedule_path, schedule_path, subcommand)
+    insertions = sidecar["insertions"]
+    if not isinstance(insertions, list):
+        _emit_json({"ok": False, "error": "invalid review schedule sidecar: insertions must be an array", "subcommand": subcommand}, 3)
+
+    base_by_step_id = {row["step_id"]: row for row in base_rows}
+    insertion_by_id = {row["id"]: row for row in insertions if isinstance(row, dict) and isinstance(row.get("id"), str)}
+    insertion_step_ids = {row["step_id"] for row in insertions if isinstance(row, dict) and isinstance(row.get("step_id"), str)}
+    all_step_ids = set(base_by_step_id.keys()) | insertion_step_ids
+
+    anchor_task_id = ""
+    anchor_step_id = ""
+    if after_step in base_by_step_id:
+        anchor = base_by_step_id[after_step]
+        anchor_task_id = anchor["task_id"]
+        anchor_step_id = anchor["step_id"]
+    elif after_step in insertion_by_id:
+        anchor = insertion_by_id[after_step]
+        anchor_task_id = anchor.get("task_id", "")
+        anchor_step_id = anchor.get("step_id", "")
+    else:
+        _emit_json({
+            "ok": False,
+            "error": f"--after-step must reference a base schedule step_id or sidecar insertion id: {after_step}",
+            "subcommand": subcommand,
+        }, 2)
+
+    if anchor_task_id != task_id:
+        _emit_json({
+            "ok": False,
+            "error": f"--after-step {after_step} belongs to task {anchor_task_id!r}, expected {task_id!r}",
+            "subcommand": subcommand,
+        }, 2)
+
+    step_prefix = _extract_step_prefix(anchor_step_id)
+    if not step_prefix:
+        _emit_json({
+            "ok": False,
+            "error": f"could not derive step prefix from anchor step_id: {anchor_step_id}",
+            "subcommand": subcommand,
+        }, 2)
+
+    round_num = int(args.round) if args.round is not None else _derive_round_for_task(step_prefix, task_id, base_rows, insertions)
+    if round_num <= 0:
+        _emit_json({
+            "ok": False,
+            "error": f"invalid round: {round_num}",
+            "subcommand": subcommand,
+        }, 2)
+
+    fix_step_id = f"{step_prefix}_{task_id}_fix_r{round_num}"
+    review_step_id = f"{step_prefix}_{task_id}_review_r{round_num + 1}"
+    if fix_step_id in all_step_ids:
+        _emit_json({
+            "ok": False,
+            "error": f"sidecar step_id already exists: {fix_step_id}",
+            "subcommand": subcommand,
+        }, 2)
+    if review_step_id in all_step_ids:
+        _emit_json({
+            "ok": False,
+            "error": f"sidecar step_id already exists: {review_step_id}",
+            "subcommand": subcommand,
+        }, 2)
+
+    implement_template = next((row for row in base_rows if row["task_id"] == task_id and row["action"] == "implement"), None)
+    review_template = next((row for row in base_rows if row["task_id"] == task_id and row["action"] == "review"), None)
+    if implement_template is None:
+        _emit_json({
+            "ok": False,
+            "error": f"task {task_id} missing implement row in base schedule",
+            "subcommand": subcommand,
+        }, 2)
+    if review_template is None:
+        _emit_json({
+            "ok": False,
+            "error": f"task {task_id} missing review row in base schedule",
+            "subcommand": subcommand,
+        }, 2)
+
+    next_insert_num = _next_numeric_id(
+        [row.get("id", "") for row in insertions if isinstance(row, dict)],
+        _SIDECAR_INSERTION_ID_RE,
+    )
+    fix_insert_id = f"X{next_insert_num}"
+    review_insert_id = f"X{next_insert_num + 1}"
+
+    next_event_num = _next_numeric_id(
+        [row.get("source_event_id", "") for row in insertions if isinstance(row, dict)],
+        _SIDECAR_EVENT_ID_RE,
+    )
+    fix_event_id = f"E{next_event_num:04d}"
+    review_event_id = f"E{next_event_num + 1:04d}"
+
+    existing_hints = [
+        row.get("seq_hint", 0)
+        for row in insertions
+        if isinstance(row, dict) and row.get("after_step_id") == after_step and isinstance(row.get("seq_hint"), int)
+    ]
+    fix_seq_hint = (max(existing_hints) if existing_hints else 0) + 1
+
+    fix_row = _ordered_review_insertion({
+        "id": fix_insert_id,
+        "after_step_id": after_step,
+        "step_id": fix_step_id,
+        "seq_hint": fix_seq_hint,
+        "task_id": task_id,
+        "action": "fix",
+        "requires": {"task_status": "review_taken"},
+        "produces": {"task_status": "taken"},
+        "invoke": {"argv": _replace_or_append_mode(implement_template["invoke_argv"], "fix")},
+        "reason": f"insert-fix-loop round {round_num}: task {task_id} after {after_step}",
+        "source_event_id": fix_event_id,
+    })
+    review_row = _ordered_review_insertion({
+        "id": review_insert_id,
+        "after_step_id": fix_insert_id,
+        "step_id": review_step_id,
+        "seq_hint": 1,
+        "task_id": task_id,
+        "action": "review",
+        "requires": {"task_status": "taken"},
+        "produces": {"task_status": "review_taken"},
+        "invoke": {"argv": _replace_or_append_mode(review_template["invoke_argv"], "review")},
+        "reason": f"insert-fix-loop round {round_num + 1}: task {task_id} after {fix_insert_id}",
+        "source_event_id": review_event_id,
+    })
+
+    insertions.append(fix_row)
+    insertions.append(review_row)
+    sidecar = _canonicalize_review_sidecar(sidecar)
+
+    review_path = Path(review_schedule_path)
+    review_path.parent.mkdir(parents=True, exist_ok=True)
+    try:
+        review_path.write_text(json.dumps(sidecar, indent=2) + "\n", encoding="utf-8")
+    except Exception as e:
+        _emit_json({
+            "ok": False,
+            "error": f"write review schedule sidecar failed: {e}",
+            "subcommand": subcommand,
+        }, 3)
+
+    _emit_json({
+        "ok": True,
+        "subcommand": subcommand,
+        "schedule": schedule_path,
+        "review_schedule": str(review_path),
+        "task": task_id,
+        "after_step": after_step,
+        "round": round_num,
+        "inserted": [fix_row, review_row],
+    })
+
