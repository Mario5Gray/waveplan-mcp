+def _derive_round_for_task(prefix: str, task_id: str, base_rows: list[dict], insertions: list[dict]) -> int:
+    pattern = re.compile(rf"^{re.escape(prefix)}_{re.escape(task_id)}_fix_r([0-9]+)$")
+    max_round = 0
+    for row in base_rows:
+        if row["task_id"] != task_id:
+            continue
+        match = pattern.match(row["step_id"])
+        if match:
+            max_round = max(max_round, int(match.group(1)))
+    for ins in insertions:
+        if ins.get("task_id") != task_id:
+            continue
+        step_id = ins.get("step_id")
+        if not isinstance(step_id, str):
+            continue
+        match = pattern.match(step_id)
+        if match:
+            max_round = max(max_round, int(match.group(1)))
+    return max_round + 1
+
+
+def _next_numeric_id(existing: list[str], regex: re.Pattern[str]) -> int:
+    max_value = 0
+    for value in existing:
+        match = regex.match(value)
+        if not match:
+            continue
+        max_value = max(max_value, int(match.group(1)))
+    return max_value + 1
+
