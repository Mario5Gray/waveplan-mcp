+            "subcommand": subcommand,
+        }, 2)
+    try:
+        payload = json.loads(Path(schedule_path).read_text(encoding="utf-8"))
+    except Exception as e:
+        _emit_json({
+            "ok": False,
+            "error": f"read schedule failed: {e}",
+            "subcommand": subcommand,
+        }, 3)
+
+    if not isinstance(payload, dict):
+        _emit_json({
+            "ok": False,
+            "error": "invalid schedule: top-level JSON must be an object",
+            "subcommand": subcommand,
+        }, 3)
+    execution = payload.get("execution")
+    if not isinstance(execution, list) or not execution:
+        _emit_json({
+            "ok": False,
+            "error": "invalid schedule: execution must be a non-empty array",
+            "subcommand": subcommand,
+        }, 3)
+
+    rows: list[dict] = []
+    seen_step_ids: set[str] = set()
+    for idx, raw in enumerate(execution):
+        if not isinstance(raw, dict):
+            _emit_json({
+                "ok": False,
+                "error": f"invalid schedule row[{idx}]: row must be an object",
+                "subcommand": subcommand,
+            }, 3)
+        step_id = raw.get("step_id")
+        task_id = raw.get("task_id")
+        action = raw.get("action")
+        invoke = raw.get("invoke")
+        argv = invoke.get("argv") if isinstance(invoke, dict) else None
+        if not isinstance(step_id, str) or not step_id:
+            _emit_json({
+                "ok": False,
+                "error": f"invalid schedule row[{idx}]: missing step_id",
+                "subcommand": subcommand,
+            }, 3)
+        if step_id in seen_step_ids:
+            _emit_json({
+                "ok": False,
+                "error": f"invalid schedule: duplicate step_id {step_id}",
+                "subcommand": subcommand,
+            }, 3)
+        seen_step_ids.add(step_id)
+        if not isinstance(task_id, str) or not task_id:
+            _emit_json({
+                "ok": False,
+                "error": f"invalid schedule row[{idx}]: missing task_id",
+                "subcommand": subcommand,
+            }, 3)
+        if not isinstance(action, str) or not action:
+            _emit_json({
+                "ok": False,
+                "error": f"invalid schedule row[{idx}]: missing action",
+                "subcommand": subcommand,
+            }, 3)
+        if not isinstance(argv, list) or not argv or not all(isinstance(v, str) for v in argv):
+            _emit_json({
+                "ok": False,
+                "error": f"invalid schedule row[{idx}]: invoke.argv must be a non-empty string array",
+                "subcommand": subcommand,
+            }, 3)
+        rows.append({
+            "step_id": step_id,
+            "task_id": task_id,
+            "action": action,
+            "invoke_argv": list(argv),
+        })
+    return rows
