   119	func runDry(opts RunOptions, cond untilCond, report *RunReport) (*RunReport, error) {
   120		schedule, err := loadSchedule(opts.SchedulePath, opts.ReviewSchedulePath)
   121		if err != nil {
   122			return nil, err
   123		}
   124		journal, err := loadOrInitJournal(opts.JournalPath, opts.SchedulePath)
   125		if err != nil {
   126			return nil, err
   127		}
