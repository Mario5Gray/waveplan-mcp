   165	// TestEvaluate_LiveSchedule asserts every emitted row in the live schedule is
   166	// allowed when paired with a state where the task already holds the row's
   167	// required status. Catches drift between emitter and evaluator on real data.
   168	func TestEvaluate_LiveSchedule(t *testing.T) {
   169		root, err := findRepoRoot()
   170		if err != nil {
   171			t.Fatalf("findRepoRoot: %v", err)
   172		}
   173		body, err := os.ReadFile(filepath.Join(root, "docs", "plans", "2026-05-05-swim-execution-schedule.json"))
   174		if err != nil {
   175			t.Fatalf("read live schedule: %v", err)
   176		}
   177		var sched Schedule
   178		if err := json.Unmarshal(body, &sched); err != nil {
   179			t.Fatalf("parse live schedule: %v", err)
   180		}
   181		if len(sched.Execution) == 0 {
   182			t.Fatal("live schedule has no rows")
   183		}
   184		for _, row := range sched.Execution {
   185			want := Status(row.Requires.TaskStatus)
   186			snap := snapshotWithTaskStatus(row.TaskID, want)
   187			res := Evaluate(row, snap)
   188			if !res.Allowed {
   189				t.Errorf("%s: expected allowed when status=%s, got code=%s reason=%s",
   190					row.StepID, want, res.Code, res.Reason)
   191			}
