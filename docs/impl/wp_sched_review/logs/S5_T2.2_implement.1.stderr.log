   139		for opts.MaxSteps == 0 || len(report.Steps) < opts.MaxSteps {
   140			decision := ResolveNext(schedule, shadowJournal, shadowSnap)
   141			step := ApplyReport{}
   142			switch decision.Action {
   143			case ActionDone:
   144				step.Status = "done"
   145				step.Boundary = "done"
   146				report.Steps = append(report.Steps, step)
   147				report.Stopped = "done"
   148				report.Boundary = "done"
   149				return report, nil
   150			case ActionReady:
   151				step = ApplyReport{
   152					Status: "would_apply",
   153					StepID: decision.Row.StepID,
   154					TaskID: decision.Row.TaskID,
   155					Seq:    decision.Row.Seq,
   156					Reason: strings.Join(decision.Row.Invoke.Argv, " "),
   157				}
