     9	// DetectAndMarkUnknown promotes orphan in-flight events to terminal unknown.
    10	// Orphan signature: started_on set, outcome empty, completed_on empty.
    11	func DetectAndMarkUnknown(journalPath string) (int, error) {
    12		journal, err := loadOrInitJournal(journalPath, "")
    13		if err != nil {
    14			return 0, err
    15		}
    16		count := 0
    17		now := time.Now().UTC().Format(time.RFC3339)
    18		for i := range journal.Events {
    19			e := &journal.Events[i]
    20			if e.StartedOn != "" && e.Outcome == "" && e.CompletedOn == "" {
    21				e.Outcome = "unknown"
    22				e.CompletedOn = now
    23				count++
    24			}
    25		}
    26		if count > 0 {
    27			last := journal.Events[len(journal.Events)-1]
    28			journal.LastEvent = &last
    29			if err := saveJournal(journalPath, journal); err != nil {
    30				return 0, err
    31			}
    32		}
    33		return count, nil
    34	}
    35	
    36	// AckUnknown converts the latest unknown event for stepID into either failed or waived.
    37	func AckUnknown(journalPath, stepID, outcome string) error {
    38		if stepID == "" {
    39			return fmt.Errorf("missing step_id")
    40		}
    41		if outcome != "failed" && outcome != "waived" {
    42			return fmt.Errorf("invalid outcome %q", outcome)
    43		}
    44	
    45		journal, err := loadOrInitJournal(journalPath, "")
    46		if err != nil {
    47			return err
    48		}
    49	
    50		var target *JournalEvent
    51		for i := len(journal.Events) - 1; i >= 0; i-- {
    52			if journal.Events[i].StepID == stepID && journal.Events[i].Outcome == "unknown" {
    53				target = &journal.Events[i]
    54				break
    55			}
    56		}
    57		if target == nil {
    58			return fmt.Errorf("unknown step not found: %s", stepID)
    59		}
    60	
    61		now := time.Now().UTC().Format(time.RFC3339)
    62		target.Outcome = outcome
    63		target.CompletedOn = now
    64		if outcome == "waived" {
    65			target.Operator = ackOperator()
    66			target.Reason = "operator_ack_unknown"
    67			target.WaivedOn = now
    68		}
    69	
    70		last := journal.Events[len(journal.Events)-1]
    71		journal.LastEvent = &last
    72		return saveJournal(journalPath, journal)
    73	}
    74	
    75	func ackOperator() string {
    76		if user := os.Getenv("USER"); user != "" {
    77			return user
    78		}
    79		return "waveplan-cli"
    80	}

