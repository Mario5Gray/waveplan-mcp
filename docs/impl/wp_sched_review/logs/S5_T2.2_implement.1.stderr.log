   154	func loadOrInitJournal(journalPath, schedulePath string) (*Journal, error) {
   155		raw, err := os.ReadFile(journalPath)
   156		if err != nil {
   157			if !errors.Is(err, os.ErrNotExist) {
   158				return nil, fmt.Errorf("read journal: %w", err)
   159			}
   160			return &Journal{
   161				SchemaVersion: 1,
   162				SchedulePath:  schedulePath,
   163				Cursor:        0,
   164				Events:        []JournalEvent{},
   165			}, nil
   166		}
   167		if len(bytes.TrimSpace(raw)) == 0 {
   168			return &Journal{
   169				SchemaVersion: 1,
   170				SchedulePath:  schedulePath,
   171				Cursor:        0,
   172				Events:        []JournalEvent{},
   173			}, nil
   174		}
   175		if err := ValidateJournal(raw); err != nil {
   176			return nil, fmt.Errorf("invalid journal: %w", err)
   177		}
   178		var journal Journal
   179		if err := json.Unmarshal(raw, &journal); err != nil {
   180			return nil, fmt.Errorf("decode journal: %w", err)
   181		}
   182		if schedulePath != "" && journal.SchedulePath != "" && journal.SchedulePath != schedulePath {
   183			return nil, fmt.Errorf("journal schedule_path mismatch: journal=%q schedule=%q", journal.SchedulePath, schedulePath)
   184		}
   185		if schedulePath != "" && journal.SchedulePath == "" {
   186			journal.SchedulePath = schedulePath
   187		}
   188		return &journal, nil
   189	}
   190	
   191	func saveJournal(path string, journal *Journal) error {
   192		body, err := json.MarshalIndent(journal, "", "  ")
   193		if err != nil {
   194			return fmt.Errorf("marshal journal: %w", err)
   195		}
   196		body = append(body, '\n')
   197		if err := ValidateJournal(body); err != nil {
   198			return fmt.Errorf("journal write would violate schema: %w", err)
   199		}
   200	
   201		dir := filepath.Dir(path)
   202		if err := os.MkdirAll(dir, 0o755); err != nil {
   203			return fmt.Errorf("create journal dir: %w", err)
   204		}
   205		tmp, err := os.CreateTemp(dir, ".swim-journal-*.tmp")
   206		if err != nil {
   207			return fmt.Errorf("create temp journal file: %w", err)
   208		}
   209		tmpPath := tmp.Name()
   210		defer func() {
   211			_ = os.Remove(tmpPath)
   212		}()
   213	
   214		if _, err := tmp.Write(body); err != nil {
   215			_ = tmp.Close()
   216			return fmt.Errorf("write temp journal: %w", err)
   217		}
   218		if err := tmp.Close(); err != nil {
   219			return fmt.Errorf("close temp journal: %w", err)
   220		}
   221		if err := os.Rename(tmpPath, path); err != nil {
   222			return fmt.Errorf("atomic rename journal: %w", err)
   223		}
   224		return nil
   225	}
   226	
   227	func exitCodeFromErr(err error) int {
   228		var ee *exec.ExitError
   229		if errors.As(err, &ee) {
   230			return ee.ExitCode()
   231		}
   232		return 1
   233	}
   234	
   235	func invokeArgv(argv []string, workDir, stdoutPath, stderrPath string, extraEnv map[string]string, fn func(argv []string, workDir string) error) error {
   236		stdoutFile, stderrFile, err := openLogFiles(stdoutPath, stderrPath)
   237		if err != nil {
   238			return err
   239		}
   240		defer func() {
   241			_ = stdoutFile.Close()
   242			_ = stderrFile.Close()
   243		}()
   244	
   245		if fn != nil {
   246			restore := applyEnv(extraEnv)
   247			defer restore()
   248			return fn(argv, workDir)
   249		}
   250	
   251		cmd := exec.Command(argv[0], argv[1:]...)
   252		if workDir != "" {
   253			cmd.Dir = workDir
   254		}
   255		if len(extraEnv) > 0 {
   256			cmd.Env = os.Environ()
   257			for k, v := range extraEnv {
   258				cmd.Env = append(cmd.Env, k+"="+v)
   259			}
   260		}
   261		cmd.Stdout = stdoutFile
   262		cmd.Stderr = stderrFile
   263		return cmd.Run()
   264	}
   265	
   266	func applyEnv(extraEnv map[string]string) func() {
   267		if len(extraEnv) == 0 {
   268			return func() {}
   269		}
   270		type envRestore struct {
   271			key     string
   272			value   string
   273			present bool
   274		}
   275		restore := make([]envRestore, 0, len(extraEnv))
   276		for k, v := range extraEnv {
   277			prev, ok := os.LookupEnv(k)
   278			restore = append(restore, envRestore{key: k, value: prev, present: ok})
   279			_ = os.Setenv(k, v)
   280		}
   281		return func() {
   282			for i := len(restore) - 1; i >= 0; i-- {
   283				r := restore[i]
   284				if r.present {
   285					_ = os.Setenv(r.key, r.value)
   286				} else {
   287					_ = os.Unsetenv(r.key)
   288				}
   289			}
   290		}
   291	}
   292	
   293	func openLogFiles(stdoutAbs, stderrAbs string) (*os.File, *os.File, error) {
   294		if err := os.MkdirAll(filepath.Dir(stdoutAbs), 0o755); err != nil {
   295			return nil, nil, fmt.Errorf("create stdout log dir: %w", err)
   296		}
   297		if err := os.MkdirAll(filepath.Dir(stderrAbs), 0o755); err != nil {
   298			return nil, nil, fmt.Errorf("create stderr log dir: %w", err)
   299		}
   300		stdoutFile, err := os.OpenFile(stdoutAbs, os.O_CREATE|os.O_WRONLY|os.O_TRUNC, 0o644)
   301		if err != nil {
   302			return nil, nil, fmt.Errorf("open stdout log: %w", err)
   303		}
   304		stderrFile, err := os.OpenFile(stderrAbs, os.O_CREATE|os.O_WRONLY|os.O_TRUNC, 0o644)
   305		if err != nil {
   306			_ = stdoutFile.Close()
   307			return nil, nil, fmt.Errorf("open stderr log: %w", err)
   308		}
   309		return stdoutFile, stderrFile, nil
   310	}

