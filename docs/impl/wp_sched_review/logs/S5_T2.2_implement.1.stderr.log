    36	type untilKind string
    37	
    38	const (
    39		untilNone   untilKind = ""
    40		untilAction untilKind = "action"
    41		untilSeq    untilKind = "seq"
    42		untilStep   untilKind = "step"
    43		untilTask   untilKind = "task"
    44	)
    45	
    46	type untilCond struct {
    47		kind   untilKind
