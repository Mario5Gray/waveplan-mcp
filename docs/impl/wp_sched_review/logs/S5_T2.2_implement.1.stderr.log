     4	
     5	// FailureCode is a deterministic machine-readable failure category.
     6	type FailureCode string
     7	
     8	const (
     9		FailureCodePreconditionUnmet   FailureCode = "precondition_unmet"
    10		FailureCodeUnknownAction       FailureCode = "unknown_action"
    11		FailureCodeBadStatusInSchedule FailureCode = "bad_status_in_schedule"
    12	)
    13	
    14	// EvalResult is the deterministic precondition evaluation result.
    15	type EvalResult struct {
    16		Allowed bool        `json:"allowed"`
    17		Reason  string      `json:"reason"`
    18		Code    FailureCode `json:"code"`
    19	}
    20	
    21	// Evaluate checks whether row.requires matches current runtime state for row.task_id.
    22	// It also defends against schedule tampering by enforcing canonical action->status
    23	// mapping for both requires and produces.
    24	func Evaluate(row ScheduleRow, snap *StateSnapshot) EvalResult {
    25		expected, ok := statusByAction[row.Action]
    26		if !ok {
    27			return EvalResult{
    28				Allowed: false,
    29				Code:    FailureCodeUnknownAction,
    30				Reason:  fmt.Sprintf("unknown_action: action=%s", row.Action),
    31			}
    32		}
    33	
    34		requires := Status(row.Requires.TaskStatus)
    35		produces := Status(row.Produces.TaskStatus)
    36		if !isCanonicalStatus(requires) || !isCanonicalStatus(produces) ||
    37			requires != Status(expected.requires) || produces != Status(expected.produces) {
    38			return EvalResult{
    39				Allowed: false,
    40				Code:    FailureCodeBadStatusInSchedule,
    41				Reason:  fmt.Sprintf("bad_status_in_schedule: action=%s requires=%s produces=%s", row.Action, requires, produces),
    42			}
    43		}
    44	
    45		actual := Status("<nil>")
    46		if snap != nil {
    47			actual = snap.StatusOf(row.TaskID)
    48		}
    49		if actual != requires {
    50			return EvalResult{
    51				Allowed: false,
    52				Code:    FailureCodePreconditionUnmet,
    53				Reason:  fmt.Sprintf("precondition_unmet: action=%s requires=%s actual=%s", row.Action, requires, actual),
    54			}
    55		}
    56	
    57		return EvalResult{Allowed: true}
    58	}
    59	
    60	// Predict returns the postcondition status encoded on the schedule row.
    61	func Predict(row ScheduleRow) Status {
    62		return Status(row.Produces.TaskStatus)
    63	}
    64	
    65	func isCanonicalStatus(s Status) bool {
    66		switch s {
    67		case StatusAvailable, StatusTaken, StatusReviewTaken, StatusReviewEnded, StatusCompleted:
    68			return true
    69		default:
    70			return false
    71		}
    72	}

