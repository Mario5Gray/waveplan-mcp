    41		StatusCompleted:   4,
    42	}
    43	
    44	// ResolveNext returns what should happen next for journal.cursor without
    45	// mutating journal or state.
    46	func ResolveNext(sched *Schedule, journal *Journal, snap *StateSnapshot) Decision {
    47		n := len(sched.Execution)
    48		cur := journal.Cursor
    49		if cur < 0 || cur > n {
    50			return Decision{
    51				Action: ActionBlocked,
    52				Code:   ResolutionBadCursor,
    53				Cursor: cur,
    54				Reason: fmt.Sprintf("bad_cursor: cursor=%d execution_len=%d", cur, n),
    55			}
    56		}
    57		if ev, ok := firstUnknownPending(journal, cur); ok {
    58			return Decision{
    59				Action: ActionBlocked,
    60				Code:   ResolutionUnknownPending,
    61				Cursor: cur,
    62				Reason: fmt.Sprintf("unknown_pending: event_id=%s step_id=%s seq=%d", ev.EventID, ev.StepID, ev.Seq),
    63			}
    64		}
    65		if cur == n {
    66			return Decision{Action: ActionDone, Code: ResolutionDone, Cursor: cur}
    67		}
    68	
    69		row := sched.Execution[cur]
    70		e := Evaluate(row, snap)
    71		if e.Allowed {
    72			return Decision{Action: ActionReady, Row: row, Code: ResolutionReady, Cursor: cur}
    73		}
    74	
    75		if e.Code == FailureCodePreconditionUnmet {
    76			actual := Status("<nil>")
    77			if snap != nil {
    78				actual = snap.StatusOf(row.TaskID)
    79			}
    80			required := Status(row.Requires.TaskStatus)
    81			aRank, aOK := statusOrder[actual]
    82			rRank, rOK := statusOrder[required]
    83			if aOK && rOK && aRank > rRank {
    84				return Decision{
    85					Action: ActionDrift,
    86					Row:    row,
    87					Code:   ResolutionCursorDrift,
    88					Cursor: cur,
    89					Reason: fmt.Sprintf("cursor_drift: action=%s requires=%s actual=%s (state ahead)", row.Action, required, actual),
    90				}
    91			}
    92			return Decision{Action: ActionBlocked, Row: row, Code: ResolutionBlockedPrecondition, Cursor: cur, Reason: e.Reason}
    93		}
    94	
    95		return Decision{Action: ActionBlocked, Row: row, Code: ResolutionCode(e.Code), Cursor: cur, Reason: e.Reason}
    96	}
    97	
    98	func firstUnknownPending(journal *Journal, cursor int) (JournalEvent, bool) {
    99		if journal == nil {
   100			return JournalEvent{}, false
   101		}
   102		for _, ev := range journal.Events {
   103			// seq is 1-based, cursor is 0-based index into execution rows.
   104			if ev.Outcome == "unknown" && cursor < ev.Seq {
   105				return ev, true
   106			}
   107		}
   108		return JournalEvent{}, false
   109	}

