    53	
    54	// Run executes repeated Apply() calls until a stop condition is met.
    55	func Run(opts RunOptions) (*RunReport, error) {
    56		cond, err := parseUntil(opts.Until)
    57		if err != nil {
    58			return nil, err
    59		}
    60		if cond.kind == untilTask {
    61			schedule, err := loadSchedule(opts.SchedulePath, opts.ReviewSchedulePath)
    62			if err != nil {
    63				return nil, err
    64			}
    65			lastSeq, ok := lastSeqForTask(schedule, cond.taskID)
    66			if !ok {
    67				return nil, fmt.Errorf("invalid until %q: task not present in schedule", opts.Until)
    68			}
    69			cond.kind = untilSeq
    70			cond.seq = lastSeq
    71		}
    72		report := &RunReport{DryRun: opts.DryRun}
    73		if opts.DryRun {
    74			return runDry(opts, cond, report)
    75		}
    76		return runWet(opts, cond, report)
    77	}
    78	
    79	func runWet(opts RunOptions, cond untilCond, report *RunReport) (*RunReport, error) {
    80		for opts.MaxSteps == 0 || len(report.Steps) < opts.MaxSteps {
    81			step, err := Apply(ApplyOptions{
    82				SchedulePath:       opts.SchedulePath,
    83				ReviewSchedulePath: opts.ReviewSchedulePath,
    84				JournalPath:        opts.JournalPath,
    85				StatePath:          opts.StatePath,
    86				ArtifactRoot:       opts.ArtifactRoot,
    87				LockPath:           opts.LockPath,
    88				WorkDir:            opts.WorkDir,
    89				InvokeFn:           opts.InvokeFn,
    90				ReadSnapshotFn:     opts.ReadSnapshotFn,
    91			})
    92			if err != nil {
    93				return nil, err
    94			}
    95			report.Steps = append(report.Steps, *step)
    96	
    97			if step.Status != "applied" {
    98				report.Stopped = step.Status
    99				report.Boundary = step.Boundary
   100				report.InquiryRequired = step.InquiryRequired
   101				report.InquirySource = step.InquirySource
   102				report.InquiryHint = step.InquiryHint
   103				return report, nil
   104			}
   105			if matchesUntil(cond, step) {
   106				report.Stopped = "until"
   107				report.Boundary = "until_reached"
   108				report.ReachedUntil = true
   109				return report, nil
   110			}
   111		}
   112		if opts.MaxSteps > 0 && len(report.Steps) == opts.MaxSteps {
   113			report.Stopped = "max_steps"
   114			report.Boundary = "max_steps"
   115		}
   116		return report, nil
   117	}
