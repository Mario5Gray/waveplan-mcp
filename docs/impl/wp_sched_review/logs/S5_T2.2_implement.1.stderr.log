     9	// ApplyOptions exposes one operator-facing apply invocation.
    10	type ApplyOptions struct {
    11		SchedulePath       string
    12		ReviewSchedulePath string
    13		JournalPath        string
    14		StatePath          string
    15		ArtifactRoot       string
    16		LockPath           string
    17		WorkDir            string
    18		ExpectCursor       *int
    19		InvokeFn           func(argv []string, workDir string) error
    20		ReadSnapshotFn     func(path string) (*StateSnapshot, error)
    21	}
    22	
    23	// ApplyReport is the stable JSON-friendly report for CLI and MCP callers.
    24	type ApplyReport struct {
    25		Status          string `json:"status"`
    26		StepID          string `json:"step_id,omitempty"`
    27		TaskID          string `json:"task_id,omitempty"`
    28		Seq             int    `json:"seq,omitempty"`
    29		ExitCode        int    `json:"exit_code,omitempty"`
    30		StdoutPath      string `json:"stdout_path,omitempty"`
    31		StderrPath      string `json:"stderr_path,omitempty"`
    32		Reason          string `json:"reason,omitempty"`
    33		Hint            string `json:"hint,omitempty"`
    34		Boundary        string `json:"boundary,omitempty"`
    35		InquiryRequired bool   `json:"inquiry_required,omitempty"`
    36		InquirySource   string `json:"inquiry_source,omitempty"`
    37		InquiryHint     string `json:"inquiry_hint,omitempty"`
    38	}
    39	
    40	// Apply executes exactly one safe apply attempt and normalizes the result
    41	// into stable operator-facing statuses.
    42	func Apply(opts ApplyOptions) (*ApplyReport, error) {
    43		if _, err := DetectAndMarkUnknown(opts.JournalPath); err != nil {
    44			return nil, err
    45		}
    46	
    47		res, err := ExecuteNextStepSafe(SafeExecOptions{
    48			SchedulePath:       opts.SchedulePath,
    49			ReviewSchedulePath: opts.ReviewSchedulePath,
    50			JournalPath:        opts.JournalPath,
    51			StatePath:          opts.StatePath,
    52			ArtifactRoot:       opts.ArtifactRoot,
    53			LockPath:           opts.LockPath,
    54			WorkDir:            opts.WorkDir,
    55			ExpectCursor:       opts.ExpectCursor,
    56			InvokeFn:           opts.InvokeFn,
    57			ReadSnapshotFn:     opts.ReadSnapshotFn,
    58		})
    59		if err != nil {
    60			if errors.Is(err, ErrLockBusy) {
    61				return lockBusyReport(opts.LockPath, opts.SchedulePath, opts.ArtifactRoot), nil
    62			}
    63			return nil, err
    64		}
    65	
    66		journal, err := loadOrInitJournal(opts.JournalPath, opts.SchedulePath)
    67		if err != nil {
    68			return nil, err
    69		}
    70		if ev, ok := firstUnknownPending(journal, journal.Cursor); ok {
    71			return &ApplyReport{
    72				Status:   "unknown_pending",
    73				StepID:   ev.StepID,
    74				Seq:      ev.Seq,
    75				Reason:   fmt.Sprintf("unknown_pending: event_id=%s step_id=%s seq=%d", ev.EventID, ev.StepID, ev.Seq),
    76				Hint:     "Resolve with swim step --ack-unknown <step_id> before retrying apply.",
    77				Boundary: "unknown_pending",
    78			}, nil
    79		}
    80	
    81		if res.Done {
    82			return &ApplyReport{Status: "done", Boundary: "done"}, nil
    83		}
    84	
    85		event := journal.LastEvent
    86		if event == nil {
    87			return &ApplyReport{Status: "blocked", Reason: "missing_last_event", Boundary: "blocked"}, nil
    88		}
    89		report := &ApplyReport{
    90			StepID:     event.StepID,
    91			TaskID:     event.TaskID,
    92			Seq:        event.Seq,
    93			ExitCode:   derefInt(event.ExitCode),
    94			StdoutPath: event.StdoutPath,
    95			StderrPath: event.StderrPath,
    96		}
    97	
    98		switch event.Outcome {
    99		case "applied":
   100			report.Status = "applied"
   101			return report, nil
   102		case "failed":
   103			report.Status = "blocked"
   104			report.Boundary = "blocked"
   105			report.Reason = fmt.Sprintf("invoke_exit: step_id=%s exit_code=%d", event.StepID, report.ExitCode)
   106			applyReceiptInquiry(report, opts.SchedulePath, opts.ArtifactRoot, event)
   107			return report, nil
   108		case "blocked":
   109			report.Reason = normalizeBlockedReason(event.Reason)
   110			if strings.Contains(report.Reason, "incomplete_dispatch:") {
   111				report.Status = "incomplete_dispatch"
   112				report.Boundary = "incomplete_dispatch"
   113				report.Hint = "Re-run the same swim step to continue dispatch without re-claiming the task."
   114				applyReceiptInquiry(report, opts.SchedulePath, opts.ArtifactRoot, event)
   115				return report, nil
   116			}
   117			report.Status = "blocked"
   118			report.Boundary = "blocked"
   119			applyReceiptInquiry(report, opts.SchedulePath, opts.ArtifactRoot, event)
   120			return report, nil
   121		default:
   122			report.Status = "blocked"
   123			report.Boundary = "blocked"
   124			report.Reason = event.Reason
   125			applyReceiptInquiry(report, opts.SchedulePath, opts.ArtifactRoot, event)
   126			return report, nil
   127		}
   128	}
   129	
   130	func lockBusyReport(lockPath, schedulePath, artifactRoot string) *ApplyReport {
   131		if lockPath == "" {
   132			lockPath = DeriveLockPath(schedulePath, artifactRoot)
   133		}
   134		report := &ApplyReport{Status: "lock_busy"}
   135		report.Boundary = "blocked"
   136		pid, startedAt, err := ReadLockHolder(lockPath)
   137		if err == nil && pid > 0 {
   138			report.Hint = fmt.Sprintf("Lock held by pid=%d started_at=%s", pid, startedAt)
   139		}
   140		return report
   141	}
   142	
   143	func normalizeBlockedReason(reason string) string {
   144		if strings.Contains(reason, "postcondition_unmet:") {
   145			return strings.Replace(reason, "postcondition_unmet:", "postcondition_mismatch:", 1)
   146		}
   147		return reason
   148	}
   149	
   150	func derefInt(v *int) int {
   151		if v == nil {
   152			return 0
   153		}
   154		return *v
   155	}
   156	
   157	func applyReceiptInquiry(report *ApplyReport, schedulePath, artifactRoot string, event *JournalEvent) {
   158		if report == nil || event == nil || !isDispatchAction(event.Action) {
   159			return
   160		}
   161		receipt, err := loadDispatchReceipt(schedulePath, artifactRoot, event.StepID, event.Attempt)
   162		if err != nil || receipt == nil || !receipt.InquiryRequired {
   163			return
   164		}
   165		report.InquiryRequired = true
   166		report.InquirySource = receipt.InquirySource
   167		report.InquiryHint = receipt.InquiryHint
   168	}

