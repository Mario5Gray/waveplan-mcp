   291	func loadSchedule(schedulePath, reviewSchedulePath string) (*Schedule, error) {
   292		scheduleRaw, err := os.ReadFile(schedulePath)
   293		if err != nil {
   294			return nil, fmt.Errorf("read schedule: %w", err)
   295		}
   296		if err := ValidateSchedule(scheduleRaw); err != nil {
   297			return nil, fmt.Errorf("invalid schedule: %w", err)
   298		}
   299		var schedule Schedule
   300		if err := json.Unmarshal(scheduleRaw, &schedule); err != nil {
   301			return nil, fmt.Errorf("decode schedule: %w", err)
   302		}
   303		if reviewSchedulePath == "" {
   304			return &schedule, nil
   305		}
   306	
   307		reviewRaw, err := os.ReadFile(reviewSchedulePath)
   308		if err != nil {
   309			return nil, fmt.Errorf("read review schedule sidecar: %w", err)
   310		}
   311		if err := ValidateReviewScheduleSidecar(reviewRaw, &schedule); err != nil {
   312			return nil, fmt.Errorf("invalid review schedule sidecar: %w", err)
   313		}
   314		var reviewSidecar ReviewScheduleSidecar
   315		if err := json.Unmarshal(reviewRaw, &reviewSidecar); err != nil {
   316			return nil, fmt.Errorf("decode review schedule sidecar: %w", err)
   317		}
   318		merged, err := mergeExecutionWithReviewInsertions(schedule.Execution, reviewSidecar.Insertions)
   319		if err != nil {
   320			return nil, err
   321		}
   322		schedule.Execution = merged
   323		return &schedule, nil
   324	}
   325	
   326	func mergeExecutionWithReviewInsertions(base []ScheduleRow, insertions []ReviewScheduleInsertion) ([]ScheduleRow, error) {
   327		if len(insertions) == 0 {
   328			out := append([]ScheduleRow(nil), base...)
   329			for i := range out {
   330				out[i].Seq = i + 1
   331			}
   332			return out, nil
   333		}
   334	
   335		children := make(map[string][]ReviewScheduleInsertion)
   336		for _, ins := range insertions {
   337			children[ins.AfterStepID] = append(children[ins.AfterStepID], ins)
   338		}
   339		for anchor := range children {
   340			rows := children[anchor]
   341			sort.Slice(rows, func(i, j int) bool {
   342				if rows[i].SeqHint == rows[j].SeqHint {
   343					return rows[i].ID < rows[j].ID
   344				}
   345				return rows[i].SeqHint < rows[j].SeqHint
   346			})
   347			children[anchor] = rows
   348		}
   349	
   350		merged := make([]ScheduleRow, 0, len(base)+len(insertions))
   351		emitted := make(map[string]struct{}, len(insertions))
   352		var appendChildren func(anchor string) error
   353		appendChildren = func(anchor string) error {
   354			for _, ins := range children[anchor] {
   355				if _, ok := emitted[ins.ID]; ok {
   356					return fmt.Errorf("duplicate insertion id during merge: %s", ins.ID)
   357				}
   358				emitted[ins.ID] = struct{}{}
   359				merged = append(merged, scheduleRowFromInsertion(ins))
   360				if err := appendChildren(ins.ID); err != nil {
   361					return err
   362				}
   363			}
   364			return nil
   365		}
   366	
   367		for _, row := range base {
   368			merged = append(merged, row)
   369			if err := appendChildren(row.StepID); err != nil {
   370				return nil, err
   371			}
   372		}
   373		if len(emitted) != len(insertions) {
   374			return nil, fmt.Errorf("failed to merge all review insertions: merged=%d insertions=%d", len(emitted), len(insertions))
   375		}
   376		for i := range merged {
   377			merged[i].Seq = i + 1
   378		}
   379		return merged, nil
   380	}
   381	
   382	func scheduleRowFromInsertion(ins ReviewScheduleInsertion) ScheduleRow {
   383		return ScheduleRow{
   384			StepID:   ins.StepID,
   385			TaskID:   ins.TaskID,
   386			Action:   ins.Action,
   387			Requires: ins.Requires,
   388			Produces: ins.Produces,
   389			Invoke: InvokeSpec{
   390				Argv: append([]string(nil), ins.Invoke.Argv...),
   391			},
   392		}
   393	}
