   169			if row.Seq != expectedSeq {
   170				return fmt.Errorf("seq not strictly increasing from 1: row=%d got=%d want=%d", i, row.Seq, expectedSeq)
   171			}
   172			expectedSeq++
   173	
   174			if prev, ok := seenStepIDs[row.StepID]; ok {
   175				return fmt.Errorf("duplicate step_id: %s (rows %d and %d)", row.StepID, prev, i)
