   181			report.Stopped = "max_steps"
   182			report.Boundary = "max_steps"
   183		}
   184		return report, nil
   185	}
   186	
   187	func parseUntil(raw string) (untilCond, error) {
   188		if raw == "" {
   189			return untilCond{kind: untilNone}, nil
   190		}
   191		switch raw {
   192		case "implement", "review", "end_review", "finish", "fix":
   193			return untilCond{kind: untilAction, action: raw}, nil
   194		}
   195		if strings.HasPrefix(raw, "seq:") {
   196			var seq int
   197			if _, err := fmt.Sscanf(raw, "seq:%d", &seq); err != nil || seq <= 0 {
   198				return untilCond{}, fmt.Errorf("invalid until %q: expected seq:N", raw)
   199			}
   200			return untilCond{kind: untilSeq, seq: seq}, nil
   201		}
   202		if strings.HasPrefix(raw, "step:") {
   203			stepID := strings.TrimPrefix(raw, "step:")
   204			if stepID == "" {
   205				return untilCond{}, fmt.Errorf("invalid until %q: expected step:<step_id>", raw)
   206			}
   207			return untilCond{kind: untilStep, stepID: stepID}, nil
   208		}
   209		if strings.HasPrefix(raw, "task:") {
   210			taskID := strings.TrimPrefix(raw, "task:")
   211			if !isTaskUntilID(taskID) {
   212				return untilCond{}, fmt.Errorf("invalid until %q: expected task:Tn", raw)
   213			}
   214			return untilCond{kind: untilTask, taskID: taskID}, nil
   215		}
   216		if isTaskUntilID(raw) {
   217			return untilCond{kind: untilTask, taskID: raw}, nil
   218		}
   219		return untilCond{}, fmt.Errorf("invalid until %q", raw)
   220	}
   221	
   222	func matchesUntil(cond untilCond, step *ApplyReport) bool {
   223		switch cond.kind {
   224		case untilNone:
   225			return false
   226		case untilAction:
   227			suffix := "_" + cond.action
   228			return strings.HasSuffix(step.StepID, suffix) ||
   229				strings.Contains(step.StepID, suffix+"_r")
   230		case untilSeq:
   231			return step.Seq == cond.seq
   232		case untilStep:
   233			return step.StepID == cond.stepID
   234		case untilTask:
   235			return step.TaskID == cond.taskID || strings.HasPrefix(step.TaskID, cond.taskID+".")
   236		default:
   237			return false
   238		}
   239	}
   240	
   241	func isTaskUntilID(raw string) bool {
   242		if raw == "" || raw[0] != 'T' {
   243			return false
   244		}
   245		for i := 1; i < len(raw); i++ {
   246			if raw[i] < '0' || raw[i] > '9' {
   247				return false
   248			}
   249		}
   250		return len(raw) > 1
   251	}
   252	
   253	func lastSeqForTask(schedule *Schedule, taskID string) (int, bool) {
   254		if schedule == nil {
   255			return 0, false
   256		}
   257		lastSeq := 0
   258		found := false
   259		for _, row := range schedule.Execution {
   260			if row.TaskID == taskID || strings.HasPrefix(row.TaskID, taskID+".") {
   261				if row.Seq > lastSeq {
   262					lastSeq = row.Seq
   263				}
   264				found = true
   265			}
   266		}
   267		return lastSeq, found
   268	}
   269	
   270	func cloneJournal(j *Journal) *Journal {
   271		if j == nil {
   272			return &Journal{SchemaVersion: 1, Events: []JournalEvent{}}
   273		}
   274		out := *j
   275		out.Events = append([]JournalEvent(nil), j.Events...)
   276		if j.LastEvent != nil {
   277			last := *j.LastEvent
   278			out.LastEvent = &last
   279		}
   280		return &out
   281	}
   282	
   283	func cloneSnapshot(s *StateSnapshot) *StateSnapshot {
   284		out := &StateSnapshot{
   285			raw: rawState{
   286				Plan:      s.raw.Plan,
   287				Taken:     map[string]takenEntry{},
   288				Completed: map[string]completedEntry{},
   289			},
   290		}
   291		for k, v := range s.raw.Taken {
   292			out.raw.Taken[k] = v
   293		}
   294		for k, v := range s.raw.Completed {
   295			out.raw.Completed[k] = v
   296		}
   297		out.canonBody = canonicalize(out.raw)
   298		return out
   299	}
   300	
   301	func applyShadow(j *Journal, s *StateSnapshot, row ScheduleRow) {
   302		j.Cursor++
   303		taskID := row.TaskID
   304		switch Status(row.Produces.TaskStatus) {
   305		case StatusTaken:
   306			s.raw.Taken[taskID] = takenEntry{TakenBy: "dry-run", StartedAt: "2026-05-09T00:00:00Z"}
   307		case StatusReviewTaken:
   308			entry := s.raw.Taken[taskID]
   309			entry.ReviewEnteredAt = "2026-05-09T00:00:00Z"
   310			s.raw.Taken[taskID] = entry
   311		case StatusReviewEnded:
   312			entry := s.raw.Taken[taskID]
   313			entry.ReviewEndedAt = "2026-05-09T00:00:00Z"
   314			s.raw.Taken[taskID] = entry
   315		case StatusCompleted:
   316			delete(s.raw.Taken, taskID)
   317			s.raw.Completed[taskID] = completedEntry{TakenBy: "dry-run", StartedAt: "2026-05-09T00:00:00Z", FinishedAt: "2026-05-09T00:00:00Z"}
   318		}
   319		s.canonBody = canonicalize(s.raw)
   320	}

