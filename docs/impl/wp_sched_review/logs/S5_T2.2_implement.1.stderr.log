   195	func snapshotWithTaskStatus(taskID string, status Status) *StateSnapshot {
   196		s := &StateSnapshot{raw: rawState{Taken: map[string]takenEntry{}, Completed: map[string]completedEntry{}}}
   197		switch status {
   198		case StatusAvailable:
   199			// absent in both maps
   200		case StatusTaken:
   201			s.raw.Taken[taskID] = takenEntry{TakenBy: "phi", StartedAt: "2026-05-08 10:00"}
   202		case StatusReviewTaken:
   203			s.raw.Taken[taskID] = takenEntry{TakenBy: "phi", StartedAt: "2026-05-08 10:00", ReviewEnteredAt: "2026-05-08 10:01"}
   204		case StatusReviewEnded:
