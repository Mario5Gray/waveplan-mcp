    22	}
    23	
    24	// RunReport captures a multi-step wet or dry run.
    25	type RunReport struct {
    26		Steps           []ApplyReport `json:"steps"`
    27		Stopped         string        `json:"stopped"`
    28		ReachedUntil    bool          `json:"reached_until"`
    29		DryRun          bool          `json:"dry_run"`
    30		Boundary        string        `json:"boundary,omitempty"`
    31		InquiryRequired bool          `json:"inquiry_required,omitempty"`
    32		InquirySource   string        `json:"inquiry_source,omitempty"`
    33		InquiryHint     string        `json:"inquiry_hint,omitempty"`
