   164		}
   165	
   166		seenStepIDs := map[string]int{}
   167		expectedSeq := 1
   168		for i, row := range sched.Execution {
   169			if row.Seq != expectedSeq {
   170				return fmt.Errorf("seq not strictly increasing from 1: row=%d got=%d want=%d", i, row.Seq, expectedSeq)
   171			}
   172			expectedSeq++
   173	
   174			if prev, ok := seenStepIDs[row.StepID]; ok {
   175				return fmt.Errorf("duplicate step_id: %s (rows %d and %d)", row.StepID, prev, i)
   176			}
   177			seenStepIDs[row.StepID] = i
   178	
   179			if len(row.Invoke.Argv) == 0 {
   180				return fmt.Errorf("malformed argv: row=%d has empty argv", i)
   181			}
   182			if strings.TrimSpace(row.Invoke.Argv[0]) == "" {
   183				return fmt.Errorf("malformed argv: row=%d has empty argv[0]", i)
   184			}
   185	
   186			expected, ok := statusByAction[row.Action]
   187			if !ok {
   188				return fmt.Errorf("invalid action: %q", row.Action)
   189			}
   190			if row.Requires.TaskStatus != expected.requires || row.Produces.TaskStatus != expected.produces {
   191				return fmt.Errorf(
   192					"requires/produces mismatch for action %s: requires=%s produces=%s want requires=%s produces=%s",
   193					row.Action,
   194					row.Requires.TaskStatus,
   195					row.Produces.TaskStatus,
   196					expected.requires,
   197					expected.produces,
   198				)
   199			}
   200		}
   201	
   202		return nil
   203	}
