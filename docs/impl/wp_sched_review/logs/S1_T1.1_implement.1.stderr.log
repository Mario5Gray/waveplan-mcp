   371	func compileSchemaFromResolvedPath(relPath, resourceURL string) (*jsonschema.Schema, error) {
   372		abs, err := resolveSchemaPath(relPath)
   373		if err != nil {
   374			return nil, err
   375		}
   376		raw, err := os.ReadFile(abs)
   377		if err != nil {
   378			return nil, fmt.Errorf("read schema %s: %w", abs, err)
   379		}
   380		compiler := jsonschema.NewCompiler()
   381		compiler.AssertFormat = true
   382		if err := compiler.AddResource(resourceURL, bytes.NewReader(raw)); err != nil {
   383			return nil, fmt.Errorf("add schema resource %s: %w", relPath, err)
   384		}
   385		sch, err := compiler.Compile(resourceURL)
   386		if err != nil {
   387			return nil, fmt.Errorf("compile schema %s: %w", relPath, err)
   388		}
   389		return sch, nil
   390	}
   391	
   392	func resolveSchemaPath(relPath string) (string, error) {
   393		name := filepath.Base(relPath)
   394		if exePath, err := os.Executable(); err == nil && exePath != "" {
   395			shareCandidate := filepath.Join(filepath.Dir(filepath.Dir(exePath)), "share", "waveplan", "specs", name)
   396			if _, err := os.Stat(shareCandidate); err == nil {
   397				return shareCandidate, nil
   398			}
   399			siblingCandidate := filepath.Join(filepath.Dir(exePath), name)
   400			if _, err := os.Stat(siblingCandidate); err == nil {
   401				return siblingCandidate, nil
   402			}
   403		}
   404		// Repo root takes priority over user share so that `go test` always uses
   405		// the checked-in schema rather than a potentially stale installed copy.
   406		if root, err := findRepoRoot(); err == nil {
   407			abs := filepath.Join(root, relPath)
   408			if _, err := os.Stat(abs); err == nil {
   409				return abs, nil
   410			}
   411		}
   412		if home, err := os.UserHomeDir(); err == nil && home != "" {
   413			userShare := filepath.Join(home, ".local", "share", "waveplan", "specs", name)
   414			if _, err := os.Stat(userShare); err == nil {
   415				return userShare, nil
   416			}
   417		}
   418		return "", fmt.Errorf("schema %s not found in install share dir or repo root", relPath)
   419	}
