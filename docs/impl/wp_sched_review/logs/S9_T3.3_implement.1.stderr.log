+ROOT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/../.." && pwd)"
+TMP_DIR="$(mktemp -d)"
+trap 'rm -rf "$TMP_DIR"' EXIT
+
+REVIEW_SIDECAR="$ROOT_DIR/tests/swim/fixtures/review-loop-sidecar.json"
+
+(
