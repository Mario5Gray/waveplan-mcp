+# T7.3 — thread review-schedule through swim next/step/run subprocess invocations.
+set -euo pipefail
+
+ROOT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/../.." && pwd)"
+CLI="$ROOT_DIR/waveplan-cli"
+TMP_DIR="$(mktemp -d)"
+trap 'rm -rf "$TMP_DIR"' EXIT
+
+cat >"$TMP_DIR/schedule.json" <<'JSON'
+{
+  "schema_version": 2,
+  "execution": [
+    {
+      "seq": 1,
+      "step_id": "S1_T1.1_implement",
+      "task_id": "T1.1",
+      "action": "implement",
+      "requires": {"task_status": "available"},
+      "produces": {"task_status": "taken"},
+      "invoke": {"argv": ["/bin/true"]}
+    },
+    {
+      "seq": 2,
+      "step_id": "S1_T1.1_review",
+      "task_id": "T1.1",
+      "action": "review",
+      "requires": {"task_status": "taken"},
+      "produces": {"task_status": "review_taken"},
+      "invoke": {"argv": ["/bin/true"]}
+    },
+    {
+      "seq": 3,
+      "step_id": "S1_T1.1_end_review",
+      "task_id": "T1.1",
+      "action": "end_review",
+      "requires": {"task_status": "review_taken"},
+      "produces": {"task_status": "review_ended"},
+      "invoke": {"argv": ["/bin/true"]}
+    },
+    {
+      "seq": 4,
+      "step_id": "S1_T1.1_finish",
+      "task_id": "T1.1",
+      "action": "finish",
+      "requires": {"task_status": "review_ended"},
+      "produces": {"task_status": "completed"},
+      "invoke": {"argv": ["/bin/true"]}
+    }
+  ]
+}
+JSON
+
+cat >"$TMP_DIR/review-sidecar.json" <<JSON
+{
+  "schema_version": 1,
+  "base_schedule_path": "$TMP_DIR/schedule.json",
+  "insertions": [
+    {
+      "id": "X1",
+      "after_step_id": "S1_T1.1_review",
+      "step_id": "S1_T1.1_fix_r1",
+      "seq_hint": 1,
+      "task_id": "T1.1",
+      "action": "fix",
+      "requires": {"task_status": "review_taken"},
+      "produces": {"task_status": "taken"},
+      "invoke": {"argv": ["/bin/true"]},
+      "reason": "review finding requires fix",
+      "source_event_id": "E0001"
+    },
+    {
+      "id": "X2",
+      "after_step_id": "X1",
+      "step_id": "S1_T1.1_review_r2",
+      "seq_hint": 1,
+      "task_id": "T1.1",
+      "action": "review",
+      "requires": {"task_status": "taken"},
+      "produces": {"task_status": "review_taken"},
+      "invoke": {"argv": ["/bin/true"]},
+      "reason": "follow-up review",
+      "source_event_id": "E0002"
+    }
+  ]
+}
+JSON
+
+cat >"$TMP_DIR/state.json" <<'JSON'
+{
+  "plan": "demo-execution-waves.json",
+  "taken": {
+    "T1.1": {
+      "taken_by": "phi",
+      "started_at": "2026-05-14 15:44",
+      "review_entered_at": "2026-05-14 15:50",
+      "review_ended_at": "",
+      "reviewer": "sigma"
+    }
+  },
+  "completed": {}
+}
+JSON
+
+cat >"$TMP_DIR/journal.json" <<'JSON'
+{
+  "schema_version": 1,
+  "schedule_path": "demo-schedule.json",
+  "cursor": 0,
+  "events": []
+}
+JSON
+
+"$CLI" swim next \
+  --schedule "$TMP_DIR/schedule.json" \
+  --review-schedule "$TMP_DIR/review-sidecar.json" \
+  --state "$TMP_DIR/state.json" \
+  --journal "$TMP_DIR/journal.json" >"$TMP_DIR/next.json"
+jq -e '.action == "ready" and .row.step_id == "S1_T1.1_fix_r1"' "$TMP_DIR/next.json" >/dev/null
+
+"$CLI" swim step \
+  --schedule "$TMP_DIR/schedule.json" \
+  --review-schedule "$TMP_DIR/review-sidecar.json" \
+  --state "$TMP_DIR/state.json" \
+  --journal "$TMP_DIR/journal.json" \
+  --step-id "S1_T1.1_fix_r1" >"$TMP_DIR/step.json"
+jq -e '.action == "ready" and .row.step_id == "S1_T1.1_fix_r1"' "$TMP_DIR/step.json" >/dev/null
+
+"$CLI" swim run \
+  --schedule "$TMP_DIR/schedule.json" \
+  --review-schedule "$TMP_DIR/review-sidecar.json" \
+  --state "$TMP_DIR/state.json" \
+  --journal "$TMP_DIR/journal.json" \
+  --until "step:S1_T1.1_fix_r1" \
+  --dry-run >"$TMP_DIR/run.json"
+jq -e '.dry_run == true and .reached_until == true and (.steps[0].step_id == "S1_T1.1_fix_r1")' "$TMP_DIR/run.json" >/dev/null
+
+"$CLI" swim journal \
+  --schedule "$TMP_DIR/schedule.json" \
+  --review-schedule "$TMP_DIR/review-sidecar.json" \
+  --journal "$TMP_DIR/journal.json" \
+  --tail 1 >"$TMP_DIR/journal-view.json"
+jq -e '.cursor == 0 and (.events | length == 0)' "$TMP_DIR/journal-view.json" >/dev/null
+
+echo "PASS: T7.3 review-schedule passthrough"

