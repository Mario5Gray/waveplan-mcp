def _swim_compile_plan_json(in_path: str, out_path: str | None) -> None:
    src = Path(in_path)
    if not src.exists():
        raise ValueError(f"input file not found: {in_path}")
    try:
        payload = json.loads(src.read_text(encoding="utf-8"))
    except json.JSONDecodeError as e:
        raise ValueError(f"invalid JSON in input file: {e}") from e
    if not isinstance(payload, dict):
        raise ValueError("top-level JSON must be an object")

    canonical = _validate_and_canonicalize_plan_json(payload)
    rendered = json.dumps(canonical, indent=2) + "\n"
    if out_path:
        Path(out_path).write_text(rendered, encoding="utf-8")
        print(json.dumps({"ok": True, "input": str(src), "output": str(Path(out_path)), "mode": "write"}, indent=2))
        return
    print(rendered, end="")


def _swim_not_wired(subcommand: str) -> None:
    print(json.dumps({
        "ok": False,
        "error": "not_wired_yet",
        "subcommand": subcommand,
    }, indent=2))
    sys.exit(2)


def _emit_json(obj: dict, code: int = 0) -> None:
    print(json.dumps(obj, indent=2))
    sys.exit(code)


def _default_swim_journal(schedule_path: str) -> str:
    return schedule_path + ".journal.json"


def _resolve_review_schedule_path(
    schedule_path: str,
    cli_review_schedule: str | None,
    *,
    subcommand: str,
    required: bool = True,
    must_exist: bool = True,
) -> str | None:
    candidate = (cli_review_schedule or "").strip()
    if not candidate:
        candidate = (os.environ.get("WAVEPLAN_SCHED_REVIEW") or "").strip()
    if not candidate:
        if required:
            _emit_json({
                "ok": False,
                "error": "missing review schedule: set --review-schedule or WAVEPLAN_SCHED_REVIEW",
                "subcommand": subcommand,
            }, 2)
        return None
    resolved = _abs_user_path(candidate)
    if not resolved:
        if required:
            _emit_json({
                "ok": False,
                "error": "missing review schedule: set --review-schedule or WAVEPLAN_SCHED_REVIEW",
                "subcommand": subcommand,
            }, 2)
        return None
    resolved_path = Path(resolved).resolve()
    schedule_resolved = Path(schedule_path).resolve()
    if resolved_path == schedule_resolved:
        _emit_json({
            "ok": False,
            "error": "review schedule must differ from --schedule",
            "subcommand": subcommand,
        }, 2)
    if must_exist:
        if not resolved_path.is_file() or not os.access(resolved_path, os.R_OK):
            _emit_json({
                "ok": False,
                "error": f"review schedule path not readable: {resolved_path}",
                "subcommand": subcommand,
            }, 2)
        return str(resolved_path)

    if resolved_path.exists() and (not resolved_path.is_file() or not os.access(resolved_path, os.R_OK)):
        _emit_json({
            "ok": False,
            "error": f"review schedule path not readable: {resolved_path}",
            "subcommand": subcommand,
        }, 2)
    parent = resolved_path.parent
    if not parent.exists() or not parent.is_dir():
        _emit_json({
            "ok": False,
            "error": f"review schedule parent directory not found: {parent}",
            "subcommand": subcommand,
        }, 2)
    return str(resolved_path)


def _derive_swim_state(schedule_path: str) -> str | None:
    env_state = os.environ.get("WAVEPLAN_STATE")
    if env_state:
        return env_state
    try:
        payload = json.loads(Path(schedule_path).read_text(encoding="utf-8"))
    except Exception:
        return None
    execution = payload.get("execution")
    if not isinstance(execution, list):
        return None
    for row in execution:
        if not isinstance(row, dict):
            continue
        invoke = row.get("invoke", {})
        argv = invoke.get("argv") if isinstance(invoke, dict) else None
        if not isinstance(argv, list):
            continue
        for i, token in enumerate(argv):
            if token == "--plan" and i + 1 < len(argv):
                return str(argv[i + 1]) + ".state.json"
    return None


def _run_swim_go(tool: str, tool_args: list[str]) -> subprocess.CompletedProcess:
    bin_name = f"swim-{tool}"
    cmd_main = _REPO_ROOT / "cmd" / bin_name / "main.go"
    if cmd_main.exists():
        return subprocess.run(
            ["go", "run", f"./cmd/{bin_name}", *tool_args],
            cwd=_REPO_ROOT,
            capture_output=True,
            text=True,
        )
    resolved = _resolve_local_tool(bin_name)
    if resolved:
        return subprocess.run(
            [resolved, *tool_args],
            capture_output=True,
            text=True,
        )
    return subprocess.CompletedProcess([bin_name, *tool_args], 3, "", f"{bin_name} not found")


def _handle_swim_subprocess(tool: str, tool_args: list[str], subcommand: str) -> None:
    proc = _run_swim_go(tool, tool_args)
    stdout = proc.stdout.strip()
    stderr = proc.stderr.strip()
    if proc.returncode == 0:
        if stdout:
            print(stdout)
        return
    if stdout:
        print(stdout)
        sys.exit(proc.returncode)
    _emit_json({
        "ok": False,
        "error": stderr or f"swim-{tool} failed",
        "subcommand": subcommand,
    }, proc.returncode if proc.returncode in (2, 3, 4) else 3)


def _tail_apply_logs(payload_text: str, schedule_path: str, tail_lines: int) -> None:
    try:
        payload = json.loads(payload_text)
    except Exception:
        return
    if not isinstance(payload, dict):
        return
    for label, key in (("stdout", "stdout_path"), ("stderr", "stderr_path")):
        path = payload.get(key)
        if not isinstance(path, str) or not path:
            continue
        log_path = Path(path)
        if not log_path.is_absolute():
            log_path = Path(schedule_path).resolve().parent / log_path
        if not log_path.exists():
            print(f"==> {label}: {log_path} (missing)", file=sys.stderr)
            continue
        try:
            lines = log_path.read_text(encoding="utf-8", errors="replace").splitlines()
        except Exception as e:
            print(f"==> {label}: {log_path} (read failed: {e})", file=sys.stderr)
            continue
        print(f"==> {label}: {log_path}", file=sys.stderr)
        tail = lines[-tail_lines:] if tail_lines > 0 else lines
        for line in tail:
            print(line, file=sys.stderr)


def _handle_swim_compile_schedule(args: argparse.Namespace) -> None:
    plan_path = _abs_user_path(args.plan)
    agents_path = _abs_user_path(args.agents or _default_waveagents_path())
    out_path = _abs_user_path(args.out)
    emitter = _resolve_local_tool("wp-emit-wave-execution.sh") or str(_REPO_ROOT / "wp-emit-wave-execution.sh")
    cmd = [
        emitter,
        "--plan", plan_path,
        "--agents", agents_path,
        "--task-scope", args.task_scope,
    ]
    if out_path:
        cmd.extend(["--out", out_path])
    env = {**os.environ, "WAVEPLAN_CLI_BIN": str(_SCRIPT_PATH)}
    proc = subprocess.run(cmd, capture_output=True, text=True, env=env)
    if proc.returncode != 0:
        _emit_json({
            "ok": False,
            "error": proc.stderr.strip() or proc.stdout.strip() or "compile-schedule failed",
            "subcommand": "compile-schedule",
        }, proc.returncode if proc.returncode in (2, 3, 4) else 3)
    state_path = plan_path + ".state.json"
    state_bootstrapped = False
    if getattr(args, "bootstrap_state", False) and not Path(state_path).exists():
        Path(state_path).write_text(json.dumps({
            "plan": Path(plan_path).name,
            "taken": {},
            "completed": {},
        }, indent=2) + "\n", encoding="utf-8")
        state_bootstrapped = True
    if out_path:
        _emit_json({
            "ok": True,
            "output": out_path,
            "subcommand": "compile-schedule",
            "state_bootstrapped": state_bootstrapped,
            "state_path": state_path,
            "agents": agents_path,
        })
    print(proc.stdout, end="")


def _handle_swim_refine(args: argparse.Namespace) -> None:
    tool_args = [
        "--plan", _abs_user_path(args.plan),
        "--targets", ",".join(args.targets),
    ]
    if args.profile:
        tool_args.extend(["--profile", args.profile])
    if args.out:
        tool_args.extend(["--out", _abs_user_path(args.out)])
    if getattr(args, "invoker", None):
        tool_args.extend(["--invoker", args.invoker])
    _handle_swim_subprocess("refine-compile", tool_args, "refine")


def _handle_swim_refine_run(args: argparse.Namespace) -> None:
    tool_args = ["--refine", _abs_user_path(args.refine)]
    if getattr(args, "refine_journal", None):
        tool_args.extend(["--refine-journal", _abs_user_path(args.refine_journal)])
    if getattr(args, "coarse_journal", None):
        tool_args.extend(["--coarse-journal", _abs_user_path(args.coarse_journal)])
    if getattr(args, "state", None):
        tool_args.extend(["--state", _abs_user_path(args.state)])
    if getattr(args, "dry_run", False):
        tool_args.append("--dry-run")
    if getattr(args, "work_dir", None):
        tool_args.extend(["--work-dir", _abs_user_path(args.work_dir)])
    _handle_swim_subprocess("refine-run", tool_args, "refine-run")


def _handle_swim_validate(args: argparse.Namespace) -> None:
    if args.kind == "plan":
        try:
            payload = json.loads(Path(args.input_path).read_text(encoding="utf-8"))
            if not isinstance(payload, dict):
                raise ValueError("top-level JSON must be an object")
            _validate_and_canonicalize_plan_json(payload)
        except Exception as e:
            _emit_json({"ok": False, "error": str(e), "subcommand": "validate"}, 3)
        _emit_json({"ok": True, "kind": args.kind, "input": args.input_path})
    proc = _run_swim_go("validate", ["--kind", args.kind, "--in", args.input_path])
    if proc.returncode != 0:
        _emit_json({
            "ok": False,
            "error": proc.stderr.strip() or proc.stdout.strip() or "validate failed",
            "subcommand": "validate",
        }, proc.returncode if proc.returncode in (2, 3, 4) else 3)
    _emit_json({"ok": True, "kind": args.kind, "input": args.input_path})


def _replace_or_append_mode(argv: list[str], mode: str) -> list[str]:
    out = list(argv)
    for i, token in enumerate(out):
        if token == "--mode" and i + 1 < len(out):
            out[i + 1] = mode
            return out
        if token.startswith("--mode="):
            out[i] = f"--mode={mode}"
            return out
    out.extend(["--mode", mode])
    return out


def _ordered_review_insertion(row: dict) -> dict:
    out: dict = {}
    for key in _SIDECAR_INSERTION_FIELD_ORDER:
        if key in row:
            out[key] = row[key]
    for key in sorted(row.keys()):
        if key not in out:
            out[key] = row[key]
    return out


def _canonicalize_review_sidecar(sidecar: dict) -> dict:
    out: dict = {}
    if "schema_version" in sidecar:
        out["schema_version"] = sidecar["schema_version"]
    if "base_schedule_path" in sidecar:
        out["base_schedule_path"] = sidecar["base_schedule_path"]
    insertions = sidecar.get("insertions", [])
    if isinstance(insertions, list):
        out["insertions"] = [_ordered_review_insertion(dict(row)) for row in insertions]
    else:
        out["insertions"] = []
    for key in sorted(sidecar.keys()):
        if key not in out:
            out[key] = sidecar[key]
    return out


def _parse_schedule_rows_for_insert(schedule_path: str, subcommand: str) -> list[dict]:
    if not schedule_path or not Path(schedule_path).is_file() or not os.access(schedule_path, os.R_OK):
        _emit_json({
            "ok": False,
            "error": f"schedule path not readable: {schedule_path}",
            "subcommand": subcommand,
        }, 2)
    try:
        payload = json.loads(Path(schedule_path).read_text(encoding="utf-8"))
    except Exception as e:
        _emit_json({
            "ok": False,
            "error": f"read schedule failed: {e}",
            "subcommand": subcommand,
        }, 3)

    if not isinstance(payload, dict):
        _emit_json({
            "ok": False,
            "error": "invalid schedule: top-level JSON must be an object",
            "subcommand": subcommand,
        }, 3)
    execution = payload.get("execution")
    if not isinstance(execution, list) or not execution:
        _emit_json({
            "ok": False,
            "error": "invalid schedule: execution must be a non-empty array",
            "subcommand": subcommand,
        }, 3)

    rows: list[dict] = []
    seen_step_ids: set[str] = set()
    for idx, raw in enumerate(execution):
        if not isinstance(raw, dict):
            _emit_json({
                "ok": False,
                "error": f"invalid schedule row[{idx}]: row must be an object",
                "subcommand": subcommand,
            }, 3)
        step_id = raw.get("step_id")
        task_id = raw.get("task_id")
        action = raw.get("action")
        invoke = raw.get("invoke")
        argv = invoke.get("argv") if isinstance(invoke, dict) else None
        if not isinstance(step_id, str) or not step_id:
            _emit_json({
                "ok": False,
                "error": f"invalid schedule row[{idx}]: missing step_id",
                "subcommand": subcommand,
            }, 3)
        if step_id in seen_step_ids:
            _emit_json({
                "ok": False,
                "error": f"invalid schedule: duplicate step_id {step_id}",
                "subcommand": subcommand,
            }, 3)
        seen_step_ids.add(step_id)
        if not isinstance(task_id, str) or not task_id:
            _emit_json({
                "ok": False,
                "error": f"invalid schedule row[{idx}]: missing task_id",
                "subcommand": subcommand,
            }, 3)
        if not isinstance(action, str) or not action:
            _emit_json({
                "ok": False,
                "error": f"invalid schedule row[{idx}]: missing action",
                "subcommand": subcommand,
            }, 3)
        if not isinstance(argv, list) or not argv or not all(isinstance(v, str) for v in argv):
            _emit_json({
                "ok": False,
                "error": f"invalid schedule row[{idx}]: invoke.argv must be a non-empty string array",
                "subcommand": subcommand,
            }, 3)
        rows.append({
            "step_id": step_id,
            "task_id": task_id,
            "action": action,
            "invoke_argv": list(argv),
        })
    return rows


