def _swim_compile_plan_json(in_path: str, out_path: str | None) -> None:
    src = Path(in_path)
    if not src.exists():
        raise ValueError(f"input file not found: {in_path}")
    try:
        payload = json.loads(src.read_text(encoding="utf-8"))
    except json.JSONDecodeError as e:
        raise ValueError(f"invalid JSON in input file: {e}") from e
    if not isinstance(payload, dict):
        raise ValueError("top-level JSON must be an object")

    canonical = _validate_and_canonicalize_plan_json(payload)
    rendered = json.dumps(canonical, indent=2) + "\n"
    if out_path:
        Path(out_path).write_text(rendered, encoding="utf-8")
        print(json.dumps({"ok": True, "input": str(src), "output": str(Path(out_path)), "mode": "write"}, indent=2))
        return
    print(rendered, end="")


def _swim_not_wired(subcommand: str) -> None:
    print(json.dumps({
        "ok": False,
        "error": "not_wired_yet",
        "subcommand": subcommand,
    }, indent=2))
    sys.exit(2)


def _emit_json(obj: dict, code: int = 0) -> None:
    print(json.dumps(obj, indent=2))
    sys.exit(code)


def _default_swim_journal(schedule_path: str) -> str:
    return schedule_path + ".journal.json"


def _derive_swim_state(schedule_path: str) -> str | None:
    env_state = os.environ.get("WAVEPLAN_STATE")
    if env_state:
        return env_state
    try:
        payload = json.loads(Path(schedule_path).read_text(encoding="utf-8"))
    except Exception:
        return None
    execution = payload.get("execution")
    if not isinstance(execution, list):
        return None
    for row in execution:
        if not isinstance(row, dict):
            continue
        invoke = row.get("invoke", {})
        argv = invoke.get("argv") if isinstance(invoke, dict) else None
        if not isinstance(argv, list):
            continue
        for i, token in enumerate(argv):
            if token == "--plan" and i + 1 < len(argv):
                return str(argv[i + 1]) + ".state.json"
    return None


def _run_swim_go(tool: str, tool_args: list[str]) -> subprocess.CompletedProcess:
    bin_name = f"swim-{tool}"
    cmd_main = _REPO_ROOT / "cmd" / bin_name / "main.go"
    if cmd_main.exists():
        return subprocess.run(
            ["go", "run", f"./cmd/{bin_name}", *tool_args],
            cwd=_REPO_ROOT,
            capture_output=True,
            text=True,
        )
    resolved = _resolve_local_tool(bin_name)
    if resolved:
        return subprocess.run(
            [resolved, *tool_args],
            capture_output=True,
            text=True,
        )
    return subprocess.CompletedProcess([bin_name, *tool_args], 3, "", f"{bin_name} not found")


def _handle_swim_subprocess(tool: str, tool_args: list[str], subcommand: str) -> None:
    proc = _run_swim_go(tool, tool_args)
    stdout = proc.stdout.strip()
    stderr = proc.stderr.strip()
    if proc.returncode == 0:
        if stdout:
            print(stdout)
        return
    if stdout:
        print(stdout)
        sys.exit(proc.returncode)
    _emit_json({
        "ok": False,
        "error": stderr or f"swim-{tool} failed",
        "subcommand": subcommand,
    }, proc.returncode if proc.returncode in (2, 3, 4) else 3)


def _tail_apply_logs(payload_text: str, schedule_path: str, tail_lines: int) -> None:
    try:
        payload = json.loads(payload_text)
    except Exception:
        return
    if not isinstance(payload, dict):
        return
    for label, key in (("stdout", "stdout_path"), ("stderr", "stderr_path")):
        path = payload.get(key)
        if not isinstance(path, str) or not path:
            continue
        log_path = Path(path)
        if not log_path.is_absolute():
            log_path = Path(schedule_path).resolve().parent / log_path
        if not log_path.exists():
            print(f"==> {label}: {log_path} (missing)", file=sys.stderr)
            continue
        try:
            lines = log_path.read_text(encoding="utf-8", errors="replace").splitlines()
        except Exception as e:
            print(f"==> {label}: {log_path} (read failed: {e})", file=sys.stderr)
            continue
        print(f"==> {label}: {log_path}", file=sys.stderr)
        tail = lines[-tail_lines:] if tail_lines > 0 else lines
        for line in tail:
            print(line, file=sys.stderr)


def _handle_swim_compile_schedule(args: argparse.Namespace) -> None:
    plan_path = _abs_user_path(args.plan)
    agents_path = _abs_user_path(args.agents or _default_waveagents_path())
    out_path = _abs_user_path(args.out)
    emitter = _resolve_local_tool("wp-emit-wave-execution.sh") or str(_REPO_ROOT / "wp-emit-wave-execution.sh")
    cmd = [
        emitter,
        "--plan", plan_path,
        "--agents", agents_path,
        "--task-scope", args.task_scope,
    ]
    if out_path:
        cmd.extend(["--out", out_path])
    env = {**os.environ, "WAVEPLAN_CLI_BIN": str(_SCRIPT_PATH)}
    proc = subprocess.run(cmd, capture_output=True, text=True, env=env)
    if proc.returncode != 0:
        _emit_json({
            "ok": False,
            "error": proc.stderr.strip() or proc.stdout.strip() or "compile-schedule failed",
            "subcommand": "compile-schedule",
        }, proc.returncode if proc.returncode in (2, 3, 4) else 3)

