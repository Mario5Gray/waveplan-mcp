)
_TASK_FIELD_ORDER = (
    "title", "plan_line", "doc_refs", "files", "description", "notes",
)


def _ordered(d: dict, known: tuple[str, ...]) -> dict:
    """Return a new dict with `known` fields first (in given order, present-only),
    then remaining keys alphabetically. Preserves every input key — never drops."""
    out: dict = {}
    for k in known:
        if k in d:
            out[k] = d[k]
    for k in sorted(d.keys()):
        if k not in out:
            out[k] = d[k]
    return out

# Where the repo keeps its execution-wave plan files.
_SCRIPT_PATH = Path(__file__).resolve()
_SCRIPT_DIR = _SCRIPT_PATH.parent
_REPO_PLAN_DIR = _SCRIPT_DIR / "docs" / "plans"
_REPO_ROOT = _SCRIPT_DIR


def _waveplan_config_dir() -> Path:
    xdg = os.environ.get("XDG_CONFIG_HOME")
    if xdg:
        return Path(xdg) / "waveplan-mcp"
    return Path.home() / ".config" / "waveplan-mcp"


def _default_waveagents_path() -> str:
    return str(_waveplan_config_dir() / "waveagents.json")


def _abs_user_path(path: str | None) -> str | None:
    if not path:
        return path
    p = Path(path)
    if p.is_absolute():
        return str(p)
    return str((Path.cwd() / p).resolve())


def _resolve_local_tool(name: str) -> str | None:
    sibling = _SCRIPT_DIR / name
    if sibling.exists():
        return str(sibling)
    found = shutil.which(name)
    if found:
        return found
    return None


def _find_auto_plan() -> Path | None:
    """Find the *-execution-waves.json file in the repo plan directory tree."""
    matches = sorted(_REPO_PLAN_DIR.rglob("*-execution-waves.json"))
    if len(matches) == 1:
        return matches[0]
    # If multiple exist, prefer the one with a .state.json sibling (active plan).
    for m in matches:
        if (m.with_name(m.name + ".state.json")).exists():
            return m
    # Fall back to the first one.
    if matches:
        return matches[0]
    return None


def _build_env(plan_arg: str | None = None) -> dict:
    """Build environment for the waveplan-mcp subprocess.

    Auto-detects WAVEPLAN_PLAN from the repo if not already set in the
    environment or via --plan.
    """
    env = {}

    # WAVEPLAN_PLAN: explicit arg > env var > auto-detect from repo.
    plan_path = plan_arg or os.environ.get("WAVEPLAN_PLAN")
    if not plan_path:
        auto = _find_auto_plan()
        if auto:
            plan_path = str(auto)

    if plan_path:
        env["WAVEPLAN_PLAN"] = plan_path

