{"type":"tool_use","timestamp":1778783277732,"sessionID":"ses_1d8461b99ffelloRWu4Z0us23q","part":{"type":"tool","tool":"read","callID":"call_10127a95bbb64e0baa250418","state":{"status":"completed","input":{"filePath":"/Users/darkbit1001/workspace/waveplan-mcp/internal/contextsize/types.go"},"output":"<path>/Users/darkbit1001/workspace/waveplan-mcp/internal/contextsize/types.go</path>\n<type>file</type>\n<content>\n1: package contextsize\n2: \n3: // SectionRef references a heading within a file.\n4: type SectionRef struct {\n5: \tPath    string `json:\"path\"`\n6: \tHeading string `json:\"heading\"`\n7: }\n8: \n9: // ContextCandidate is a source-agnostic issue candidate for context estimation.\n10: type ContextCandidate struct {\n11: \tID                 string        `json:\"id\"`\n12: \tTitle              string        `json:\"title\"`\n13: \tDescription        string        `json:\"description\"`\n14: \tReferencedFiles    []string      `json:\"referenced_files\"`\n15: \tReferencedSections []SectionRef  `json:\"referenced_sections\"`\n16: \tDependsOn          []string      `json:\"depends_on\"`\n17: \tSource             string        `json:\"source\"`\n18: }\n19: \n20: // Budget defines the acceptable token range.\n21: type Budget struct {\n22: \tMinTokens int\n23: \tMaxTokens int\n24: }\n25: \n26: // ContextEstimate is the output of context estimation.\n27: type ContextEstimate struct {\n28: \tEstimatedTokens   int          `json:\"estimated_tokens\"`\n29: \tBudgetMin         int          `json:\"budget_min\"`\n30: \tBudgetMax         int          `json:\"budget_max\"`\n31: \tFit               string       `json:\"fit\"`\n32: \tConfidence        string       `json:\"confidence\"`\n33: \tDrivers           []string     `json:\"drivers\"`\n34: \tRecommendation    string       `json:\"recommendation\"`\n35: \tMissingFiles      []string     `json:\"missing_files\"`\n36: \tMissingSections   []SectionRef `json:\"missing_sections\"`\n37: \tUnknownFiles      []string     `json:\"unknown_files\"`\n38: \tSplitCandidates   []string     `json:\"split_candidates\"`\n39: \tMergeCandidates   []string     `json:\"merge_candidates\"`\n40: }\n\n(End of file - total 40 lines)\n</content>","metadata":{"preview":"package contextsize\n\n// SectionRef references a heading within a file.\ntype SectionRef struct {\n\tPath    string `json:\"path\"`\n\tHeading string `json:\"heading\"`\n}\n\n// ContextCandidate is a source-agnostic issue candidate for context estimation.\ntype ContextCandidate struct {\n\tID                 string        `json:\"id\"`\n\tTitle              string        `json:\"title\"`\n\tDescription        string        `json:\"description\"`\n\tReferencedFiles    []string      `json:\"referenced_files\"`\n\tReferencedSections []SectionRef  `json:\"referenced_sections\"`\n\tDependsOn          []string      `json:\"depends_on\"`\n\tSource             string        `json:\"source\"`\n}\n\n// Budget defines the acceptable token range.","truncated":false,"loaded":[]},"title":"internal/contextsize/types.go","time":{"start":1778783277720,"end":1778783277728}},"id":"prt_e27bed297001kWYaIZ7mK8AqDe","sessionID":"ses_1d8461b99ffelloRWu4Z0us23q","messageID":"msg_e27bea953001ClZBz3JmEiAZFP"}}
{"type":"tool_use","timestamp":1778783277732,"sessionID":"ses_1d8461b99ffelloRWu4Z0us23q","part":{"type":"tool","tool":"read","callID":"call_0840d24f51b3452592bd4672","state":{"status":"completed","input":{"filePath":"/Users/darkbit1001/workspace/waveplan-mcp/internal/contextsize/json.go"},"output":"<path>/Users/darkbit1001/workspace/waveplan-mcp/internal/contextsize/json.go</path>\n<type>file</type>\n<content>\n1: package contextsize\n2: \n3: import (\n4: \t\"bytes\"\n5: \t\"encoding/json\"\n6: )\n7: \n8: // DecodeCandidateJSON decodes a ContextCandidate from JSON with strict decoding.\n9: func DecodeCandidateJSON(data []byte) (ContextCandidate, error) {\n10: \tvar c ContextCandidate\n11: \tdecoder := json.NewDecoder(bytes.NewReader(data))\n12: \tdecoder.DisallowUnknownFields()\n13: \tif err := decoder.Decode(&c); err != nil {\n14: \t\treturn ContextCandidate{}, err\n15: \t}\n16: \treturn c, nil\n17: }\n18: \n19: // EncodeEstimateJSON encodes a ContextEstimate to pretty-printed JSON.\n20: func EncodeEstimateJSON(e ContextEstimate) ([]byte, error) {\n21: \tbuf := &bytes.Buffer{}\n22: \tencoder := json.NewEncoder(buf)\n23: \tencoder.SetIndent(\"\", \"  \")\n24: \tif err := encoder.Encode(e); err != nil {\n25: \t\treturn nil, err\n26: \t}\n27: \treturn buf.Bytes(), nil\n28: }\n\n(End of file - total 28 lines)\n</content>","metadata":{"preview":"package contextsize\n\nimport (\n\t\"bytes\"\n\t\"encoding/json\"\n)\n\n// DecodeCandidateJSON decodes a ContextCandidate from JSON with strict decoding.\nfunc DecodeCandidateJSON(data []byte) (ContextCandidate, error) {\n\tvar c ContextCandidate\n\tdecoder := json.NewDecoder(bytes.NewReader(data))\n\tdecoder.DisallowUnknownFields()\n\tif err := decoder.Decode(&c); err != nil {\n\t\treturn ContextCandidate{}, err\n\t}\n\treturn c, nil\n}\n\n// EncodeEstimateJSON encodes a ContextEstimate to pretty-printed JSON.\nfunc EncodeEstimateJSON(e ContextEstimate) ([]byte, error) {","truncated":false,"loaded":[]},"title":"internal/contextsize/json.go","time":{"start":1778783277721,"end":1778783277729}},"id":"prt_e27bed298002JkbRoXxk3OVbzA","sessionID":"ses_1d8461b99ffelloRWu4Z0us23q","messageID":"msg_e27bea953001ClZBz3JmEiAZFP"}}
{"type":"tool_use","timestamp":1778783277732,"sessionID":"ses_1d8461b99ffelloRWu4Z0us23q","part":{"type":"tool","tool":"read","callID":"call_f3827fdc0805455db676bac2","state":{"status":"completed","input":{"filePath":"/Users/darkbit1001/workspace/waveplan-mcp/internal/contextsize/adapter/waveplan.go"},"output":"<path>/Users/darkbit1001/workspace/waveplan-mcp/internal/contextsize/adapter/waveplan.go</path>\n<type>file</type>\n<content>\n1: package adapter\n2: \n3: import (\n4: \t\"encoding/json\"\n5: \t\"fmt\"\n6: \t\"os\"\n7: \t\"slices\"\n8: \n9: \t\"github.com/darkbit1001/Stability-Toys/waveplan-mcp/internal/contextsize\"\n10: )\n11: \n12: // waveplanPlan is the minimal structure parsed from execution-waves JSON.\n13: type waveplanPlan struct {\n14: \tTasks   map[string]waveplanTask   `json:\"tasks\"`\n15: \tUnits   map[string]waveplanUnit   `json:\"units\"`\n16: \tDocIndex map[string]docIndexEntry `json:\"doc_index\"`\n17: }\n18: \n19: type waveplanTask struct {\n20: \tTitle   string   `json:\"title\"`\n21: \tDocRefs []string `json:\"doc_refs\"`\n22: \tFiles   []string `json:\"files\"`\n23: }\n24: \n25: type waveplanUnit struct {\n26: \tTask      string   `json:\"task\"`\n27: \tTitle     string   `json:\"title\"`\n28: \tDependsOn []string `json:\"depends_on\"`\n29: \tDocRefs   []string `json:\"doc_refs\"`\n30: }\n31: \n32: type docIndexEntry struct {\n33: \tPath string `json:\"path\"`\n34: }\n35: \n36: // FromWaveplanTask converts a Waveplan task into a ContextCandidate.\n37: // The referenced_files are the union of task files and doc_refs resolved\n38: // through doc_index, deduplicated and sorted.\n39: // depends_on is collapsed from unit-level edges: all direct external unit\n40: // dependencies (units in other tasks) are collected and deduplicated.\n41: func FromWaveplanTask(planPath string, taskID string) (contextsize.ContextCandidate, error) {\n42: \tplan, err := loadPlan(planPath)\n43: \tif err != nil {\n44: \t\treturn contextsize.ContextCandidate{}, err\n45: \t}\n46: \n47: \ttask, ok := plan.Tasks[taskID]\n48: \tif !ok {\n49: \t\treturn contextsize.ContextCandidate{}, fmt.Errorf(\"task %q not found in plan\", taskID)\n50: \t}\n51: \n52: \t// Validate all doc_refs exist in doc_index.\n53: \tfor _, ref := range task.DocRefs {\n54: \t\tif _, ok := plan.DocIndex[ref]; !ok {\n55: \t\t\treturn contextsize.ContextCandidate{}, fmt.Errorf(\"task %q has doc_ref %q not found in doc_index\", taskID, ref)\n56: \t\t}\n57: \t}\n58: \n59: \t// Resolve doc_refs through doc_index.\n60: \tresolvedRefs := resolveDocRefs(task.DocRefs, plan.DocIndex)\n61: \n62: \t// Union task files + resolved doc_refs, deduplicate and sort.\n63: \tfiles := make([]string, 0, len(task.Files)+len(resolvedRefs))\n64: \tfiles = append(files, task.Files...)\n65: \tfiles = append(files, resolvedRefs...)\n66: \tfiles = dedupSorted(files)\n67: \n68: \t// Collapse external dependencies from unit-level edges.\n69: \tdependsOn := collapseTaskDeps(plan, taskID)\n70: \n71: \treturn contextsize.ContextCandidate{\n72: \t\tID:                 taskID,\n73: \t\tTitle:              task.Title,\n74: \t\tDescription:        \"\",\n75: \t\tReferencedFiles:    files,\n76: \t\tReferencedSections: []contextsize.SectionRef{},\n77: \t\tDependsOn:          dependsOn,\n78: \t\tSource:             \"waveplan\",\n79: \t}, nil\n80: }\n81: \n82: // FromWaveplanUnit converts a Waveplan unit into a ContextCandidate.\n83: // referenced_files are the unit's doc_refs resolved through doc_index,\n84: // deduplicated and sorted. depends_on is the unit's direct depends_on.\n85: func FromWaveplanUnit(planPath string, unitID string) (contextsize.ContextCandidate, error) {\n86: \tplan, err := loadPlan(planPath)\n87: \tif err != nil {\n88: \t\treturn contextsize.ContextCandidate{}, err\n89: \t}\n90: \n91: \tunit, ok := plan.Units[unitID]\n92: \tif !ok {\n93: \t\treturn contextsize.ContextCandidate{}, fmt.Errorf(\"unit %q not found in plan\", unitID)\n94: \t}\n95: \n96: \t// Resolve doc_refs through doc_index.\n97: \tresolvedRefs := resolveDocRefs(unit.DocRefs, plan.DocIndex)\n98: \tresolvedRefs = dedupSorted(resolvedRefs)\n99: \n100: \treturn contextsize.ContextCandidate{\n101: \t\tID:                 unitID,\n102: \t\tTitle:              unit.Title,\n103: \t\tDescription:        \"\",\n104: \t\tReferencedFiles:    resolvedRefs,\n105: \t\tReferencedSections: []contextsize.SectionRef{},\n106: \t\tDependsOn:          unit.DependsOn,\n107: \t\tSource:             \"waveplan\",\n108: \t}, nil\n109: }\n110: \n111: func loadPlan(planPath string) (*waveplanPlan, error) {\n112: \tif planPath == \"\" {\n113: \t\treturn nil, fmt.Errorf(\"plan path is required\")\n114: \t}\n115: \n116: \tdata, err := os.ReadFile(planPath)\n117: \tif err != nil {\n118: \t\treturn nil, fmt.Errorf(\"read plan %s: %w\", planPath, err)\n119: \t}\n120: \n121: \tvar plan waveplanPlan\n122: \tif err := json.Unmarshal(data, &plan); err != nil {\n123: \t\treturn nil, fmt.Errorf(\"parse plan %s: %w\", planPath, err)\n124: \t}\n125: \n126: \treturn &plan, nil\n127: }\n128: \n129: // resolveDocRefs resolves doc_ref keys through doc_index, returning file paths.\n130: // Returns error if any doc_ref key is not found in doc_index.\n131: func resolveDocRefs(docRefs []string, docIndex map[string]docIndexEntry) []string {\n132: \tpaths := make([]string, 0, len(docRefs))\n133: \tfor _, ref := range docRefs {\n134: \t\tentry, ok := docIndex[ref]\n135: \t\tif !ok {\n136: \t\t\t// Return nil to signal missing ref (caller can detect).\n137: \t\t\treturn nil\n138: \t\t}\n139: \t\tpaths = append(paths, entry.Path)\n140: \t}\n141: \treturn paths\n142: }\n143: \n144: // dedupSorted removes duplicates and sorts the slice.\n145: func dedupSorted(values []string) []string {\n146: \tseen := make(map[string]struct{})\n147: \tunique := make([]string, 0)\n148: \tfor _, v := range values {\n149: \t\tif _, ok := seen[v]; !ok {\n150: \t\t\tseen[v] = struct{}{}\n151: \t\t\tunique = append(unique, v)\n152: \t\t}\n153: \t}\n154: \tslices.Sort(unique)\n155: \treturn unique\n156: }\n157: \n158: // collapseTaskDeps collects all direct external unit dependencies for a task.\n159: // A dependency is external if the depended-on unit belongs to a different task.\n160: // Returns deduplicated, sorted external dependency unit IDs.\n161: func collapseTaskDeps(plan *waveplanPlan, taskID string) []string {\n162: \t// Build a map of unitID -> taskID for all units.\n163: \tunitToTask := make(map[string]string)\n164: \tfor unitID, unit := range plan.Units {\n165: \t\tunitToTask[unitID] = unit.Task\n166: \t}\n167: \n168: \t// Collect all units belonging to this task.\n169: \ttaskUnits := make(map[string]struct{})\n170: \tfor unitID, unit := range plan.Units {\n171: \t\tif unit.Task == taskID {\n172: \t\t\ttaskUnits[unitID] = struct{}{}\n173: \t\t}\n174: \t}\n175: \n176: \t// Gather external dependencies: unit deps that point to units in other tasks.\n177: \texternalDeps := make(map[string]struct{})\n178: \tfor unitID := range taskUnits {\n179: \t\tunit := plan.Units[unitID]\n180: \t\tfor _, dep := range unit.DependsOn {\n181: \t\t\tdepTask, ok := unitToTask[dep]\n182: \t\t\tif !ok {\n183: \t\t\t\t// dep is not a known unit; skip (could be a task ID, but we only\n184: \t\t\t\t// collapse unit-level edges per spec).\n185: \t\t\t\tcontinue\n186: \t\t\t}\n187: \t\t\tif depTask != taskID {\n188: \t\t\t\texternalDeps[dep] = struct{}{}\n189: \t\t\t}\n190: \t\t}\n191: \t}\n192: \n193: \tresult := make([]string, 0, len(externalDeps))\n194: \tfor dep := range externalDeps {\n195: \t\tresult = append(result, dep)\n196: \t}\n197: \tslices.Sort(result)\n198: \treturn result\n199: }\n200: \n\n(End of file - total 200 lines)\n</content>","metadata":{"preview":"package adapter\n\nimport (\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"os\"\n\t\"slices\"\n\n\t\"github.com/darkbit1001/Stability-Toys/waveplan-mcp/internal/contextsize\"\n)\n\n// waveplanPlan is the minimal structure parsed from execution-waves JSON.\ntype waveplanPlan struct {\n\tTasks   map[string]waveplanTask   `json:\"tasks\"`\n\tUnits   map[string]waveplanUnit   `json:\"units\"`\n\tDocIndex map[string]docIndexEntry `json:\"doc_index\"`\n}\n\ntype waveplanTask struct {\n\tTitle   string   `json:\"title\"`","truncated":false,"loaded":[]},"title":"internal/contextsize/adapter/waveplan.go","time":{"start":1778783277716,"end":1778783277730}},"id":"prt_e27bed2910014x06hzgPDZB7h2","sessionID":"ses_1d8461b99ffelloRWu4Z0us23q","messageID":"msg_e27bea953001ClZBz3JmEiAZFP"}}
{"type":"tool_use","timestamp":1778783277732,"sessionID":"ses_1d8461b99ffelloRWu4Z0us23q","part":{"type":"tool","tool":"read","callID":"call_0f3583db26044f1f9b6fc74d","state":{"status":"completed","input":{"filePath":"/Users/darkbit1001/workspace/waveplan-mcp/internal/contextsize/adapter/waveplan_test.go"},"output":"<path>/Users/darkbit1001/workspace/waveplan-mcp/internal/contextsize/adapter/waveplan_test.go</path>\n<type>file</type>\n<content>\n1: package adapter\n2: \n3: import (\n4: \t\"os\"\n5: \t\"path/filepath\"\n6: \t\"testing\"\n7: \n8: \t\"github.com/darkbit1001/Stability-Toys/waveplan-mcp/internal/contextsize\"\n9: )\n10: \n11: // fixturePlan is a minimal execution-waves JSON for testing the adapter.\n12: var fixturePlan = `{\n13:   \"schema_version\": 1,\n14:   \"generated_on\": \"2026-05-13\",\n15:   \"plan\": {\n16:     \"id\": \"test-plan\",\n17:     \"title\": \"Test Plan\"\n18:   },\n19:   \"tasks\": {\n20:     \"T1\": {\n21:       \"title\": \"Do something\",\n22:       \"plan_line\": 10,\n23:       \"doc_refs\": [\n24:         \"plan\",\n25:         \"spec\"\n26:       ],\n27:       \"files\": [\n28:         \"internal/foo/bar.go\",\n29:         \"internal/foo/baz.go\"\n30:       ]\n31:     },\n32:     \"T2\": {\n33:       \"title\": \"Do another thing\",\n34:       \"plan_line\": 20,\n35:       \"doc_refs\": [\n36:         \"plan\"\n37:       ],\n38:       \"files\": [\n39:         \"internal/bar/thing.go\"\n40:       ]\n41:     }\n42:   },\n43:   \"units\": {\n44:     \"T1.1\": {\n45:       \"task\": \"T1\",\n46:       \"title\": \"Unit one\",\n47:       \"kind\": \"impl\",\n48:       \"wave\": 1,\n49:       \"plan_line\": 30,\n50:       \"depends_on\": [],\n51:       \"doc_refs\": [\n52:         \"plan\",\n53:         \"spec\"\n54:       ]\n55:     },\n56:     \"T1.2\": {\n57:       \"task\": \"T1\",\n58:       \"title\": \"Unit two\",\n59:       \"kind\": \"impl\",\n60:       \"wave\": 2,\n61:       \"plan_line\": 40,\n62:       \"depends_on\": [\n63:         \"T1.1\"\n64:       ],\n65:       \"doc_refs\": [\n66:         \"spec\"\n67:       ]\n68:     },\n69:     \"T2.1\": {\n70:       \"task\": \"T2\",\n71:       \"title\": \"Unit three\",\n72:       \"kind\": \"test\",\n73:       \"wave\": 3,\n74:       \"plan_line\": 50,\n75:       \"depends_on\": [\n76:         \"T1.2\"\n77:       ],\n78:       \"doc_refs\": [\n79:         \"plan\"\n80:       ]\n81:     }\n82:   },\n83:   \"doc_index\": {\n84:     \"plan\": {\n85:       \"path\": \"docs/superpowers/plans/test-plan.md\",\n86:       \"line\": 1,\n87:       \"kind\": \"plan\"\n88:     },\n89:     \"spec\": {\n90:       \"path\": \"docs/superpowers/specs/test-spec.md\",\n91:       \"line\": 1,\n92:       \"kind\": \"spec\"\n93:     }\n94:   }\n95: }`\n96: \n97: func makeFixturePlan(t *testing.T) string {\n98: \tt.Helper()\n99: \tdir := t.TempDir()\n100: \tp := filepath.Join(dir, \"test-plan-execution-waves.json\")\n101: \tif err := os.WriteFile(p, []byte(fixturePlan), 0644); err != nil {\n102: \t\tt.Fatalf(\"write fixture plan: %v\", err)\n103: \t}\n104: \treturn p\n105: }\n106: \n107: func TestFromWaveplanTask_ResolvesFilesAndDocRefs(t *testing.T) {\n108: \tplanPath := makeFixturePlan(t)\n109: \n110: \tcandidate, err := FromWaveplanTask(planPath, \"T1\")\n111: \tif err != nil {\n112: \t\tt.Fatalf(\"unexpected error: %v\", err)\n113: \t}\n114: \n115: \tif candidate.ID != \"T1\" {\n116: \t\tt.Errorf(\"expected id 'T1', got '%s'\", candidate.ID)\n117: \t}\n118: \tif candidate.Title != \"Do something\" {\n119: \t\tt.Errorf(\"expected title 'Do something', got '%s'\", candidate.Title)\n120: \t}\n121: \tif candidate.Source != \"waveplan\" {\n122: \t\tt.Errorf(\"expected source 'waveplan', got '%s'\", candidate.Source)\n123: \t}\n124: \tif candidate.Description != \"\" {\n125: \t\tt.Errorf(\"expected empty description, got '%s'\", candidate.Description)\n126: \t}\n127: \n128: \t// Should union task files + resolved doc_refs, deduplicated and sorted.\n129: \texpectedFiles := []string{\n130: \t\t\"docs/superpowers/plans/test-plan.md\",\n131: \t\t\"docs/superpowers/specs/test-spec.md\",\n132: \t\t\"internal/foo/bar.go\",\n133: \t\t\"internal/foo/baz.go\",\n134: \t}\n135: \tif len(candidate.ReferencedFiles) != len(expectedFiles) {\n136: \t\tt.Fatalf(\"expected %d referenced_files, got %d: %v\", len(expectedFiles), len(candidate.ReferencedFiles), candidate.ReferencedFiles)\n137: \t}\n138: \tfor i, f := range candidate.ReferencedFiles {\n139: \t\tif f != expectedFiles[i] {\n140: \t\t\tt.Errorf(\"expected referenced_files[%d] = '%s', got '%s'\", i, expectedFiles[i], f)\n141: \t\t}\n142: \t}\n143: }\n144: \n145: func TestFromWaveplanUnit_ResolvesDocRefs(t *testing.T) {\n146: \tplanPath := makeFixturePlan(t)\n147: \n148: \tcandidate, err := FromWaveplanUnit(planPath, \"T1.1\")\n149: \tif err != nil {\n150: \t\tt.Fatalf(\"unexpected error: %v\", err)\n151: \t}\n152: \n153: \tif candidate.ID != \"T1.1\" {\n154: \t\tt.Errorf(\"expected id 'T1.1', got '%s'\", candidate.ID)\n155: \t}\n156: \tif candidate.Title != \"Unit one\" {\n157: \t\tt.Errorf(\"expected title 'Unit one', got '%s'\", candidate.Title)\n158: \t}\n159: \tif candidate.Source != \"waveplan\" {\n160: \t\tt.Errorf(\"expected source 'waveplan', got '%s'\", candidate.Source)\n161: \t}\n162: \n163: \t// Unit doc_refs: [\"plan\", \"spec\"] resolved through doc_index.\n164: \texpectedFiles := []string{\n165: \t\t\"docs/superpowers/plans/test-plan.md\",\n166: \t\t\"docs/superpowers/specs/test-spec.md\",\n167: \t}\n168: \tif len(candidate.ReferencedFiles) != len(expectedFiles) {\n169: \t\tt.Fatalf(\"expected %d referenced_files, got %d: %v\", len(expectedFiles), len(candidate.ReferencedFiles), candidate.ReferencedFiles)\n170: \t}\n171: \tfor i, f := range candidate.ReferencedFiles {\n172: \t\tif f != expectedFiles[i] {\n173: \t\t\tt.Errorf(\"expected referenced_files[%d] = '%s', got '%s'\", i, expectedFiles[i], f)\n174: \t\t}\n175: \t}\n176: }\n177: \n178: func TestFromWaveplanTask_UnknownTaskID_ReturnsError(t *testing.T) {\n179: \tplanPath := makeFixturePlan(t)\n180: \n181: \t_, err := FromWaveplanTask(planPath, \"T99\")\n182: \tif err == nil {\n183: \t\tt.Fatal(\"expected error for unknown task ID, got nil\")\n184: \t}\n185: }\n186: \n187: func TestFromWaveplanUnit_UnknownUnitID_ReturnsError(t *testing.T) {\n188: \tplanPath := makeFixturePlan(t)\n189: \n190: \t_, err := FromWaveplanUnit(planPath, \"T99.1\")\n191: \tif err == nil {\n192: \t\tt.Fatal(\"expected error for unknown unit ID, got nil\")\n193: \t}\n194: }\n195: \n196: func TestFromWaveplanTask_DedupedSortedReferencedFiles(t *testing.T) {\n197: \t// Plan where doc_refs overlap with task files.\n198: \toverlappingPlan := `{\n199:   \"schema_version\": 1,\n200:   \"generated_on\": \"2026-05-13\",\n201:   \"plan\": {\"id\": \"overlap\", \"title\": \"Overlap Plan\"},\n202:   \"tasks\": {\n203:     \"T1\": {\n204:       \"title\": \"Overlapping\",\n205:       \"plan_line\": 10,\n206:       \"doc_refs\": [\"plan\", \"shared_ref\"],\n207:       \"files\": [\"docs/superpowers/plans/test-plan.md\", \"internal/unique.go\"]\n208:     }\n209:   },\n210:   \"units\": {},\n211:   \"doc_index\": {\n212:     \"plan\": {\"path\": \"docs/superpowers/plans/test-plan.md\", \"line\": 1, \"kind\": \"plan\"},\n213:     \"shared_ref\": {\"path\": \"internal/unique.go\", \"line\": 5, \"kind\": \"code\"}\n214:   }\n215: }`\n216: \tdir := t.TempDir()\n217: \tp := filepath.Join(dir, \"overlap.json\")\n218: \tos.WriteFile(p, []byte(overlappingPlan), 0644)\n219: \n220: \tcandidate, err := FromWaveplanTask(p, \"T1\")\n221: \tif err != nil {\n222: \t\tt.Fatalf(\"unexpected error: %v\", err)\n223: \t}\n224: \n225: \t// Should be deduplicated: \"docs/superpowers/plans/test-plan.md\" and \"internal/unique.go\"\n226: \texpectedFiles := []string{\"docs/superpowers/plans/test-plan.md\", \"internal/unique.go\"}\n227: \tif len(candidate.ReferencedFiles) != len(expectedFiles) {\n228: \t\tt.Fatalf(\"expected %d deduplicated files, got %d: %v\", len(expectedFiles), len(candidate.ReferencedFiles), candidate.ReferencedFiles)\n229: \t}\n230: \tfor i, f := range expectedFiles {\n231: \t\tif candidate.ReferencedFiles[i] != f {\n232: \t\t\tt.Errorf(\"expected [%d] = '%s', got '%s'\", i, f, candidate.ReferencedFiles[i])\n233: \t\t}\n234: \t}\n235: }\n236: \n237: func TestFromWaveplanTask_TaskDependsOnCollapsesFromUnitEdges(t *testing.T) {\n238: \t// T2.1 depends on T1.2, T1.2 depends on T1.1.\n239: \t// T2's depends_on should collapse to [\"T1.1\", \"T1.2\"] (all external unit deps transitively).\n240: \tplanPath := makeFixturePlan(t)\n241: \n242: \tcandidate, err := FromWaveplanTask(planPath, \"T2\")\n243: \tif err != nil {\n244: \t\tt.Fatalf(\"unexpected error: %v\", err)\n245: \t}\n246: \n247: \t// T2.1 depends on [\"T1.2\"], T1.2 is a unit in a different task (T1), so it's external.\n248: \t// T1.2 depends on [\"T1.1\"], T1.1 is in same task T1, so it's internal.\n249: \t// Collapsed external deps for T2: [\"T1.2\"]\n250: \tif len(candidate.DependsOn) != 1 {\n251: \t\tt.Fatalf(\"expected 1 depends_on, got %d: %v\", len(candidate.DependsOn), candidate.DependsOn)\n252: \t}\n253: \tif len(candidate.DependsOn) > 0 && candidate.DependsOn[0] != \"T1.2\" {\n254: \t\tt.Errorf(\"expected depends_on ['T1.2'], got %v\", candidate.DependsOn)\n255: \t}\n256: }\n257: \n258: func TestFromWaveplanTask_NoExternalDeps_EmptyDependsOn(t *testing.T) {\n259: \t// T1's units (T1.1, T1.2) only depend on each other, no external deps.\n260: \tplanPath := makeFixturePlan(t)\n261: \n262: \tcandidate, err := FromWaveplanTask(planPath, \"T1\")\n263: \tif err != nil {\n264: \t\tt.Fatalf(\"unexpected error: %v\", err)\n265: \t}\n266: \n267: \tif len(candidate.DependsOn) != 0 {\n268: \t\tt.Errorf(\"expected empty depends_on for T1, got %v\", candidate.DependsOn)\n269: \t}\n270: }\n271: \n272: func TestFromWaveplanUnit_DependsOnFromUnit(t *testing.T) {\n273: \tplanPath := makeFixturePlan(t)\n274: \n275: \t// T1.2 depends on [\"T1.1\"]\n276: \tcandidate, err := FromWaveplanUnit(planPath, \"T1.2\")\n277: \tif err != nil {\n278: \t\tt.Fatalf(\"unexpected error: %v\", err)\n279: \t}\n280: \n281: \tif len(candidate.DependsOn) != 1 {\n282: \t\tt.Fatalf(\"expected 1 depends_on, got %d: %v\", len(candidate.DependsOn), candidate.DependsOn)\n283: \t}\n284: \tif candidate.DependsOn[0] != \"T1.1\" {\n285: \t\tt.Errorf(\"expected depends_on ['T1.1'], got %v\", candidate.DependsOn)\n286: \t}\n287: }\n288: \n289: func TestFromWaveplanTask_EmptyPlanPath_ReturnsError(t *testing.T) {\n290: \t_, err := FromWaveplanTask(\"\", \"T1\")\n291: \tif err == nil {\n292: \t\tt.Fatal(\"expected error for empty plan path, got nil\")\n293: \t}\n294: }\n295: \n296: func TestFromWaveplanUnit_EmptyPlanPath_ReturnsError(t *testing.T) {\n297: \t_, err := FromWaveplanUnit(\"\", \"T1.1\")\n298: \tif err == nil {\n299: \t\tt.Fatal(\"expected error for empty plan path, got nil\")\n300: \t}\n301: }\n302: \n303: func TestFromWaveplanTask_MissingDocRef_ReturnsError(t *testing.T) {\n304: \t// Plan with a doc_ref that doesn't exist in doc_index.\n305: \tbrokenPlan := `{\n306:   \"schema_version\": 1,\n307:   \"generated_on\": \"2026-05-13\",\n308:   \"plan\": {\"id\": \"broken\", \"title\": \"Broken Plan\"},\n309:   \"tasks\": {\n310:     \"T1\": {\n311:       \"title\": \"Broken\",\n312:       \"plan_line\": 10,\n313:       \"doc_refs\": [\"plan\", \"nonexistent_ref\"],\n314:       \"files\": []\n315:     }\n316:   },\n317:   \"units\": {},\n318:   \"doc_index\": {\n319:     \"plan\": {\"path\": \"docs/plan.md\", \"line\": 1, \"kind\": \"plan\"}\n320:   }\n321: }`\n322: \tdir := t.TempDir()\n323: \tp := filepath.Join(dir, \"broken.json\")\n324: \tos.WriteFile(p, []byte(brokenPlan), 0644)\n325: \n326: \t_, err := FromWaveplanTask(p, \"T1\")\n327: \tif err == nil {\n328: \t\tt.Fatal(\"expected error for missing doc_ref, got nil\")\n329: \t}\n330: }\n331: \n332: func TestCandidate_SourceIsWaveplan(t *testing.T) {\n333: \tplanPath := makeFixturePlan(t)\n334: \n335: \ttaskCandidate, err := FromWaveplanTask(planPath, \"T1\")\n336: \tif err != nil {\n337: \t\tt.Fatalf(\"unexpected error: %v\", err)\n338: \t}\n339: \tif taskCandidate.Source != \"waveplan\" {\n340: \t\tt.Errorf(\"expected task candidate source 'waveplan', got '%s'\", taskCandidate.Source)\n341: \t}\n342: \n343: \tunitCandidate, err := FromWaveplanUnit(planPath, \"T1.1\")\n344: \tif err != nil {\n345: \t\tt.Fatalf(\"unexpected error: %v\", err)\n346: \t}\n347: \tif unitCandidate.Source != \"waveplan\" {\n348: \t\tt.Errorf(\"expected unit candidate source 'waveplan', got '%s'\", unitCandidate.Source)\n349: \t}\n350: }\n351: \n352: func TestCandidate_StructurallyValidForEstimator(t *testing.T) {\n353: \t// Verify the candidate is structurally valid for contextsize.ContextCandidate.\n354: \tplanPath := makeFixturePlan(t)\n355: \n356: \tcandidate, err := FromWaveplanTask(planPath, \"T1\")\n357: \tif err != nil {\n358: \t\tt.Fatalf(\"unexpected error: %v\", err)\n359: \t}\n360: \n361: \t// Should be a valid ContextCandidate that can be used with the estimator.\n362: \t// This test verifies no nil slices or invalid fields.\n363: \tvar _ contextsize.ContextCandidate = candidate\n364: \tif candidate.ID == \"\" {\n365: \t\tt.Error(\"expected non-empty ID\")\n366: \t}\n367: \tif candidate.Title == \"\" {\n368: \t\tt.Error(\"expected non-empty title\")\n369: \t}\n370: }\n\n(End of file - total 370 lines)\n</content>","metadata":{"preview":"package adapter\n\nimport (\n\t\"os\"\n\t\"path/filepath\"\n\t\"testing\"\n\n\t\"github.com/darkbit1001/Stability-Toys/waveplan-mcp/internal/contextsize\"\n)\n\n// fixturePlan is a minimal execution-waves JSON for testing the adapter.\nvar fixturePlan = `{\n  \"schema_version\": 1,\n  \"generated_on\": \"2026-05-13\",\n  \"plan\": {\n    \"id\": \"test-plan\",\n    \"title\": \"Test Plan\"\n  },\n  \"tasks\": {\n    \"T1\": {","truncated":false,"loaded":[]},"title":"internal/contextsize/adapter/waveplan_test.go","time":{"start":1778783277718,"end":1778783277731}},"id":"prt_e27bed295001zroHC7bBuQTi3K","sessionID":"ses_1d8461b99ffelloRWu4Z0us23q","messageID":"msg_e27bea953001ClZBz3JmEiAZFP"}}
