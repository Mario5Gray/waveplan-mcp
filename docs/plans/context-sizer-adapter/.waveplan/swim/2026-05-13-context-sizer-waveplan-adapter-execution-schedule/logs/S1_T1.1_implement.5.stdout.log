         \"T4.7\"\n612:       ]\n613:     },\n614:     {\n615:       \"wave\": 17,\n616:       \"units\": [\n617:         \"T5.1\"\n618:       ]\n619:     },\n620:     {\n621:       \"wave\": 18,\n622:       \"units\": [\n623:         \"T5.2\"\n624:       ]\n625:     },\n626:     {\n627:       \"wave\": 19,\n628:       \"units\": [\n629:         \"T5.3\"\n630:       ]\n631:     }\n632:   ]\n633: }\n\n(End of file - total 633 lines)\n</content>","metadata":{"preview":"{\n  \"schema_version\": 1,\n  \"generated_on\": \"2026-05-13\",\n  \"plan\": {\n    \"id\": \"cloudflare-ai-worker\",\n    \"title\": \"Cloudflare AI Worker Integration\",\n    \"plan_doc\": {\n      \"path\": \"docs/superpowers/plans/2026-05-13-cloudflare-ai-worker.md\",\n      \"line\": 1\n    },\n    \"spec_doc\": {\n      \"path\": \"docs/superpowers/plans/2026-05-13-cloudflare-ai-worker.md\",\n      \"line\": 1\n    }\n  },\n  \"tasks\": {\n    \"T1\": {\n      \"title\": \"Cloudflare Worker\",\n      \"plan_line\": 27,\n      \"doc_refs\": [","truncated":false,"loaded":[]},"title":"docs/plans/2026-05-13-cloudflare-ai-worker-execution-waves.json","time":{"start":1778783267020,"end":1778783267041}},"id":"prt_e27bea8ca001fkgU3quFZr0nc4","sessionID":"ses_1d8461b99ffelloRWu4Z0us23q","messageID":"msg_e27be78b10014Gzx8oxfubC9RB"}}
{"type":"tool_use","timestamp":1778783267043,"sessionID":"ses_1d8461b99ffelloRWu4Z0us23q","part":{"type":"tool","tool":"read","callID":"call_bdccf46e563641eea98d0b8d","state":{"status":"completed","input":{"filePath":"/Users/darkbit1001/workspace/waveplan-mcp/docs/superpowers/plans/2026-05-13-context-sizer-waveplan-adapter.md"},"output":"<path>/Users/darkbit1001/workspace/waveplan-mcp/docs/superpowers/plans/2026-05-13-context-sizer-waveplan-adapter.md</path>\n<type>file</type>\n<content>\n1: # Context Sizer Waveplan Adapter Plan\n2: \n3: > **For agentic workers:** REQUIRED SUB-SKILL: Use superpowers:subagent-driven-development (recommended) or superpowers:executing-plans to implement this plan task-by-task. Steps use checkbox (`- [ ]`) syntax for tracking.\n4: \n5: **Goal:** Add the missing Waveplan-native adapter layer so context estimation can run directly against `*-execution-waves.json` tasks and units without hand-authoring `ContextCandidate` JSON.\n6: \n7: **Parent FP Issue:** `FP-pkymdlbv` — Contextsize: native Waveplan adapter and CLI selectors\n8: \n9: **Child FP Issues:**\n10: - `FP-rrxobrej` — CSIZE-ADAPTER-01: Waveplan task/unit -> ContextCandidate mapping\n11: - `FP-ljdtcbbi` — CSIZE-ADAPTER-02: waveplan-cli native `--plan/--task/--unit` support\n12: - `FP-kaxwxxpx` — CSIZE-ADAPTER-03: adapter e2e verification and docs cutover\n13: \n14: **Spec:** [2026-05-13-context-sizer-design.md](/Users/darkbit1001/workspace/waveplan-mcp/docs/superpowers/specs/2026-05-13-context-sizer-design.md:290)\n15: \n16: **Architecture:** Keep `internal/contextsize` as the source-agnostic estimator. Add a Waveplan-specific adapter layer that decodes execution-waves JSON and maps tasks or units into `ContextCandidate`. Extend `waveplan-cli context estimate` to call that adapter when `--plan` is supplied. Keep raw `--candidate` mode for advanced/manual use.\n17: \n18: **Files:**\n19: - Create: `internal/contextsize/adapter/waveplan.go`\n20: - Create: `internal/contextsize/adapter/waveplan_test.go`\n21: - Modify: `waveplan-cli`\n22: - Modify: `docs/superpowers/specs/2026-05-13-context-sizer-design.md`\n23: \n24: ---\n25: \n26: ### Task 1: Add Waveplan adapter mapping\n27: \n28: **FP Ref:** `FP-rrxobrej`\n29: \n30: - [ ] **Step 1: Write adapter tests first**\n31: \n32: Cover:\n33: - task-level conversion from execution-waves JSON\n34: - unit-level conversion from execution-waves JSON\n35: - `doc_refs` resolution through `doc_index`\n36: - deterministic rejection for unknown task/unit IDs\n37: - deduped, sorted `referenced_files`\n38: - task dependency collapse from unit-level edges\n39: \n40: - [ ] **Step 2: Implement adapter conversion**\n41: \n42: Add adapter helpers with this surface:\n43: \n44: ```go\n45: func FromWaveplanTask(planPath string, taskID string) (contextsize.ContextCandidate, error)\n46: func FromWaveplanUnit(planPath string, unitID string) (contextsize.ContextCandidate, error)\n47: ```\n48: \n49: Mapping rules:\n50: - task candidate uses union of task `files` and resolved task `doc_refs`\n51: - unit candidate uses resolved unit `doc_refs`\n52: - `description` remains empty for deterministic V1\n53: - `source` is always `\"waveplan\"`\n54: \n55: - [ ] **Step 3: Verify adapter tests**\n56: \n57: Run:\n58: \n59: ```bash\n60: go test ./internal/contextsize/adapter -v\n61: ```\n62: \n63: ---\n64: \n65: ### Task 2: Extend `waveplan-cli context estimate`\n66: \n67: **FP Ref:** `FP-ljdtcbbi`\n68: \n69: - [ ] **Step 1: Add native selector flags**\n70: \n71: Extend the wrapper to support:\n72: \n73: ```bash\n74: python waveplan-cli context estimate --plan <waves.json> --task T1\n75: python waveplan-cli context estimate --plan <waves.json> --unit T1.1\n76: ```\n77: \n78: Retain:\n79: \n80: ```bash\n81: python waveplan-cli context estimate --candidate issue.json\n82: ```\n83: \n84: - [ ] **Step 2: Enforce deterministic argument validation**\n85: \n86: Reject:\n87: - `--candidate` together with `--plan`\n88: - `--task` together with `--unit`\n89: - `--plan` without a selector\n90: - selector without `--plan`\n91: \n92: - [ ] **Step 3: Route native plan input through the adapter**\n93: \n94: The wrapper should:\n95: 1. resolve the plan path\n96: 2. build a `ContextCandidate` internally from task/unit selection\n97: 3. invoke `contextsize`\n98: 4. print the same `ContextEstimate` JSON\n99: \n100: - [ ] **Step 4: Verify both paths**\n101: \n102: Run:\n103: \n104: ```bash\n105: python waveplan-cli context estimate --candidate /tmp/test-candidate.json\n106: python waveplan-cli context estimate --plan docs/plans/<plan>-execution-waves.json --task T1\n107: python waveplan-cli context estimate --plan docs/plans/<plan>-execution-waves.json --unit T1.1\n108: ```\n109: \n110: ---\n111: \n112: ### Task 3: End-to-end verification and docs cutover\n113: \n114: **FP Ref:** `FP-kaxwxxpx`\n115: \n116: - [ ] **Step 1: Add fixture-backed end-to-end tests**\n117: \n118: Cover:\n119: - valid task estimate from real execution-waves JSON\n120: - valid unit estimate from real execution-waves JSON\n121: - missing referenced files surfaced as `missing_files`\n122: - invalid selector combinations return exit code `2`\n123: \n124: - [ ] **Step 2: Update docs**\n125: \n126: Make the normal usage path explicit:\n127: - Waveplan users should use `--plan` with `--task` or `--unit`\n128: - raw `ContextCandidate` JSON is advanced/manual mode\n129: \n130: - [ ] **Step 3: Verify install path**\n131: \n132: Run:\n133: \n134: ```bash\n135: make install-contextsize\n136: python waveplan-cli context estimate --plan docs/plans/<plan>-execution-waves.json --task T1\n137: ```\n138: \n139: Expected:\n140: - installed `contextsize` matches repo build\n141: - wrapper uses native plan input without requiring hand-authored candidate JSON\n142: \n143: ---\n144: \n145: ## Completion Criteria\n146: \n147: - `waveplan-cli context estimate` supports native Waveplan plan input\n148: - `ContextCandidate` remains an internal adapter boundary for normal Waveplan usage\n149: - adapter mapping is deterministic and covered by tests\n150: - docs no longer imply that hand-authored candidate JSON is the normal workflow\n\n(End of file - total 150 lines)\n</content>","metadata":{"preview":"# Context Sizer Waveplan Adapter Plan\n\n> **For agentic workers:** REQUIRED SUB-SKILL: Use superpowers:subagent-driven-development (recommended) or superpowers:executing-plans to implement this plan task-by-task. Steps use checkbox (`- [ ]`) syntax for tracking.\n\n**Goal:** Add the missing Waveplan-native adapter layer so context estimation can run directly against `*-execution-waves.json` tasks and units without hand-authoring `ContextCandidate` JSON.\n\n**Parent FP Issue:** `FP-pkymdlbv` — Contextsize: native Waveplan adapter and CLI selectors\n\n**Child FP Issues:**\n- `FP-rrxobrej` — CSIZE-ADAPTER-01: Waveplan task/unit -> ContextCandidate mapping\n- `FP-ljdtcbbi` — CSIZE-ADAPTER-02: waveplan-cli native `--plan/--task/--unit` support\n- `FP-kaxwxxpx` — CSIZE-ADAPTER-03: adapter e2e verification and docs cutover\n\n**Spec:** [2026-05-13-context-sizer-design.md](/Users/darkbit1001/workspace/waveplan-mcp/docs/superpowers/specs/2026-05-13-context-sizer-design.md:290)\n\n**Architecture:** Keep `internal/contextsize` as the source-agnostic estimator. Add a Waveplan-specific adapter layer that decodes execution-waves JSON and maps tasks or units into `ContextCandidate`. Extend `waveplan-cli context estimate` to call that adapter when `--plan` is supplied. Keep raw `--candidate` mode for advanced/manual use.\n\n**Files:**\n- Create: `internal/contextsize/adapter/waveplan.go`\n- Create: `internal/contextsize/adapter/waveplan_test.go`","truncated":false,"loaded":[]},"title":"docs/superpowers/plans/2026-05-13-context-sizer-waveplan-adapter.md","time":{"start":1778783267017,"end":1778783267043}},"id":"prt_e27bea8c7001cKTS0Etfip5gEr","sessionID":"ses_1d8461b99ffelloRWu4Z0us23q","messageID":"msg_e27be78b10014Gzx8oxfubC9RB"}}
