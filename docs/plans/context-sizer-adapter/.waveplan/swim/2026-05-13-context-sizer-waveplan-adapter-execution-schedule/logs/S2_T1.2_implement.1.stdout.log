json:\"unknown_files\"`\n38: \tSplitCandidates   []string     `json:\"split_candidates\"`\n39: \tMergeCandidates   []string     `json:\"merge_candidates\"`\n40: }\n\n(End of file - total 40 lines)\n</content>","metadata":{"preview":"package contextsize\n\n// SectionRef references a heading within a file.\ntype SectionRef struct {\n\tPath    string `json:\"path\"`\n\tHeading string `json:\"heading\"`\n}\n\n// ContextCandidate is a source-agnostic issue candidate for context estimation.\ntype ContextCandidate struct {\n\tID                 string        `json:\"id\"`\n\tTitle              string        `json:\"title\"`\n\tDescription        string        `json:\"description\"`\n\tReferencedFiles    []string      `json:\"referenced_files\"`\n\tReferencedSections []SectionRef  `json:\"referenced_sections\"`\n\tDependsOn          []string      `json:\"depends_on\"`\n\tSource             string        `json:\"source\"`\n}\n\n// Budget defines the acceptable token range.","truncated":false,"loaded":[]},"title":"internal/contextsize/types.go","time":{"start":1778783716276,"end":1778783716288}},"id":"prt_e27c583b30022M6G5tQ0mwD31P","sessionID":"ses_1d83af79fffedWQViHmEZd7IV3","messageID":"msg_e27c56068002QCQLGZV3sF28Hm"}}
{"type":"tool_use","timestamp":1778783716291,"sessionID":"ses_1d83af79fffedWQViHmEZd7IV3","part":{"type":"tool","tool":"read","callID":"call_f6128bc9ab724ea08b4d2ce8","state":{"status":"completed","input":{"filePath":"/Users/darkbit1001/workspace/waveplan-mcp/internal/contextsize/adapter/waveplan_test.go"},"output":"<path>/Users/darkbit1001/workspace/waveplan-mcp/internal/contextsize/adapter/waveplan_test.go</path>\n<type>file</type>\n<content>\n1: package adapter\n2: \n3: import (\n4: \t\"os\"\n5: \t\"path/filepath\"\n6: \t\"testing\"\n7: \n8: \t\"github.com/darkbit1001/Stability-Toys/waveplan-mcp/internal/contextsize\"\n9: )\n10: \n11: // fixturePlan is a minimal execution-waves JSON for testing the adapter.\n12: var fixturePlan = `{\n13:   \"schema_version\": 1,\n14:   \"generated_on\": \"2026-05-13\",\n15:   \"plan\": {\n16:     \"id\": \"test-plan\",\n17:     \"title\": \"Test Plan\"\n18:   },\n19:   \"tasks\": {\n20:     \"T1\": {\n21:       \"title\": \"Do something\",\n22:       \"plan_line\": 10,\n23:       \"doc_refs\": [\n24:         \"plan\",\n25:         \"spec\"\n26:       ],\n27:       \"files\": [\n28:         \"internal/foo/bar.go\",\n29:         \"internal/foo/baz.go\"\n30:       ]\n31:     },\n32:     \"T2\": {\n33:       \"title\": \"Do another thing\",\n34:       \"plan_line\": 20,\n35:       \"doc_refs\": [\n36:         \"plan\"\n37:       ],\n38:       \"files\": [\n39:         \"internal/bar/thing.go\"\n40:       ]\n41:     }\n42:   },\n43:   \"units\": {\n44:     \"T1.1\": {\n45:       \"task\": \"T1\",\n46:       \"title\": \"Unit one\",\n47:       \"kind\": \"impl\",\n48:       \"wave\": 1,\n49:       \"plan_line\": 30,\n50:       \"depends_on\": [],\n51:       \"doc_refs\": [\n52:         \"plan\",\n53:         \"spec\"\n54:       ]\n55:     },\n56:     \"T1.2\": {\n57:       \"task\": \"T1\",\n58:       \"title\": \"Unit two\",\n59:       \"kind\": \"impl\",\n60:       \"wave\": 2,\n61:       \"plan_line\": 40,\n62:       \"depends_on\": [\n63:         \"T1.1\"\n64:       ],\n65:       \"doc_refs\": [\n66:         \"spec\"\n67:       ]\n68:     },\n69:     \"T2.1\": {\n70:       \"task\": \"T2\",\n71:       \"title\": \"Unit three\",\n72:       \"kind\": \"test\",\n73:       \"wave\": 3,\n74:       \"plan_line\": 50,\n75:       \"depends_on\": [\n76:         \"T1.2\"\n77:       ],\n78:       \"doc_refs\": [\n79:         \"plan\"\n80:       ]\n81:     }\n82:   },\n83:   \"doc_index\": {\n84:     \"plan\": {\n85:       \"path\": \"docs/superpowers/plans/test-plan.md\",\n86:       \"line\": 1,\n87:       \"kind\": \"plan\"\n88:     },\n89:     \"spec\": {\n90:       \"path\": \"docs/superpowers/specs/test-spec.md\",\n91:       \"line\": 1,\n92:       \"kind\": \"spec\"\n93:     }\n94:   }\n95: }`\n96: \n97: func makeFixturePlan(t *testing.T) string {\n98: \tt.Helper()\n99: \tdir := t.TempDir()\n100: \tp := filepath.Join(dir, \"test-plan-execution-waves.json\")\n101: \tif err := os.WriteFile(p, []byte(fixturePlan), 0644); err != nil {\n102: \t\tt.Fatalf(\"write fixture plan: %v\", err)\n103: \t}\n104: \treturn p\n105: }\n106: \n107: func TestFromWaveplanTask_ResolvesFilesAndDocRefs(t *testing.T) {\n108: \tplanPath := makeFixturePlan(t)\n109: \n110: \tcandidate, err := FromWaveplanTask(planPath, \"T1\")\n111: \tif err != nil {\n112: \t\tt.Fatalf(\"unexpected error: %v\", err)\n113: \t}\n114: \n115: \tif candidate.ID != \"T1\" {\n116: \t\tt.Errorf(\"expected id 'T1', got '%s'\", candidate.ID)\n117: \t}\n118: \tif candidate.Title != \"Do something\" {\n119: \t\tt.Errorf(\"expected title 'Do something', got '%s'\", candidate.Title)\n120: \t}\n121: \tif candidate.Source != \"waveplan\" {\n122: \t\tt.Errorf(\"expected source 'waveplan', got '%s'\", candidate.Source)\n123: \t}\n124: \tif candidate.Description != \"\" {\n125: \t\tt.Errorf(\"expected empty description, got '%s'\", candidate.Description)\n126: \t}\n127: \n128: \t// Should union task files + resolved doc_refs, deduplicated and sorted.\n129: \texpectedFiles := []string{\n130: \t\t\"docs/superpowers/plans/test-plan.md\",\n131: \t\t\"docs/superpowers/specs/test-spec.md\",\n132: \t\t\"internal/foo/bar.go\",\n133: \t\t\"internal/foo/baz.go\",\n134: \t}\n135: \tif len(candidate.ReferencedFiles) != len(expectedFiles) {\n136: \t\tt.Fatalf(\"expected %d referenced_files, got %d: %v\", len(expectedFiles), len(candidate.ReferencedFiles), candidate.ReferencedFiles)\n137: \t}\n138: \tfor i, f := range candidate.ReferencedFiles {\n139: \t\tif f != expectedFiles[i] {\n140: \t\t\tt.Errorf(\"expected referenced_files[%d] = '%s', got '%s'\", i, expectedFiles[i], f)\n141: \t\t}\n142: \t}\n143: }\n144: \n145: func TestFromWaveplanUnit_ResolvesDocRefs(t *testing.T) {\n146: \tplanPath := makeFixturePlan(t)\n147: \n148: \tcandidate, err := FromWaveplanUnit(planPath, \"T1.1\")\n149: \tif err != nil {\n150: \t\tt.Fatalf(\"unexpected error: %v\", err)\n151: \t}\n152: \n153: \tif candidate.ID != \"T1.1\" {\n154: \t\tt.Errorf(\"expected id 'T1.1', got '%s'\", candidate.ID)\n155: \t}\n156: \tif candidate.Title != \"Unit one\" {\n157: \t\tt.Errorf(\"expected title 'Unit one', got '%s'\", candidate.Title)\n158: \t}\n159: \tif candidate.Source != \"waveplan\" {\n160: \t\tt.Errorf(\"expected source 'waveplan', got '%s'\", candidate.Source)\n161: \t}\n162: \n163: \t// Unit doc_refs: [\"plan\", \"spec\"] resolved through doc_index.\n164: \texpectedFiles := []string{\n165: \t\t\"docs/superpowers/plans/test-plan.md\",\n166: \t\t\"docs/superpowers/specs/test-spec.md\",\n167: \t}\n168: \tif len(candidate.ReferencedFiles) != len(expectedFiles) {\n169: \t\tt.Fatalf(\"expected %d referenced_files, got %d: %v\", len(expectedFiles), len(candidate.ReferencedFiles), candidate.ReferencedFiles)\n170: \t}\n171: \tfor i, f := range candidate.ReferencedFiles {\n172: \t\tif f != expectedFiles[i] {\n173: \t\t\tt.Errorf(\"expected referenced_files[%d] = '%s', got '%s'\", i, expectedFiles[i], f)\n174: \t\t}\n175: \t}\n176: }\n177: \n178: func TestFromWaveplanTask_UnknownTaskID_ReturnsError(t *testing.T) {\n179: \tplanPath := makeFixturePlan(t)\n180: \n181: \t_, err := FromWaveplanTask(planPath, \"T99\")\n182: \tif err == nil {\n183: \t\tt.Fatal(\"expected error for unknown task ID, got nil\")\n184: \t}\n185: }\n186: \n187: func TestFromWaveplanUnit_UnknownUnitID_ReturnsError(t *testing.T) {\n188: \tplanPath := makeFixturePlan(t)\n189: \n190: \t_, err := FromWaveplanUnit(planPath, \"T99.1\")\n191: \tif err == nil {\n192: \t\tt.Fatal(\"expected error for unknown unit ID, got nil\")\n193: \t}\n194: }\n195: \n196: func TestFromWaveplanTask_DedupedSortedReferencedFiles(t *testing.T) {\n197: \t// Plan where doc_refs overlap with task files.\n198: \toverlappingPlan := `{\n199:   \"schema_version\": 1,\n200:   \"generated_on\": \"2026-05-13\",\n201:   \"plan\": {\"id\": \"overlap\", \"title\": \"Overlap Plan\"},\n202:   \"tasks\": {\n203:     \"T1\": {\n204:       \"title\": \"Overlapping\",\n205:       \"plan_line\": 10,\n206:       \"doc_refs\": [\"plan\", \"shared_ref\"],\n207:       \"files\": [\"docs/superpowers/plans/test-plan.md\", \"internal/unique.go\"]\n208:     }\n209:   },\n210:   \"units\": {},\n211:   \"doc_index\": {\n212:     \"plan\": {\"path\": \"docs/superpowers/plans/test-plan.md\", \"line\": 1, \"kind\": \"plan\"},\n213:     \"shared_ref\": {\"path\": \"internal/unique.go\", \"line\": 5, \"kind\": \"code\"}\n214:   }\n215: }`\n216: \tdir := t.TempDir()\n217: \tp := filepath.Join(dir, \"overlap.json\")\n218: \tos.WriteFile(p, []byte(overlappingPlan), 0644)\n219: \n220: \tcandidate, err := FromWaveplanTask(p, \"T1\")\n221: \tif err != nil {\n222: \t\tt.Fatalf(\"unexpected error: %v\", err)\n223: \t}\n224: \n225: \t// Should be deduplicated: \"docs/superpowers/plans/test-plan.md\" and \"internal/unique.go\"\n226: \texpectedFiles := []string{\"docs/superpowers/plans/test-plan.md\", \"internal/unique.go\"}\n227: \tif len(candidate.ReferencedFiles) != len(expectedFiles) {\n228: \t\tt.Fatalf(\"expected %d deduplicated files, got %d: %v\", len(expectedFiles), len(candidate.ReferencedFiles), candidate.ReferencedFiles)\n229: \t}\n230: \tfor i, f := range expectedFiles {\n231: \t\tif candidate.ReferencedFiles[i] != f {\n232: \t\t\tt.Errorf(\"expected [%d] = '%s', got '%s'\", i, f, candidate.ReferencedFiles[i])\n233: \t\t}\n234: \t}\n235: }\n236: \n237: func TestFromWaveplanTask_TaskDependsOnCollapsesFromUnitEdges(t *testing.T) {\n238: \t// T2.1 depends on T1.2, T1.2 depends on T1.1.\n239: \t// T2's depends_on should collapse to [\"T1.1\", \"T1.2\"] (all external unit deps transitively).\n240: \tplanPath := makeFixturePlan(t)\n241: \n242: \tcandidate, err := FromWaveplanTask(planPath, \"T2\")\n243: \tif err != nil {\n244: \t\tt.Fatalf(\"unexpected error: %v\", err)\n245: \t}\n246: \n247: \t// T2.1 depends on [\"T1.2\"], T1.2 is a unit in a different task (T1), so it's external.\n248: \t// T1.2 depends on [\"T1.1\"], T1.1 is in same task T1, so it's internal.\n249: \t// Collapsed external deps for T2: [\"T1.2\"]\n250: \tif len(candidate.DependsOn) != 1 {\n251: \t\tt.Fatalf(\"expected 1 depends_on, got %d: %v\", len(candidate.DependsOn), candidate.DependsOn)\n252: \t}\n253: \tif len(candidate.DependsOn) > 0 && candidate.DependsOn[0] != \"T1.2\" {\n254: \t\tt.Errorf(\"expected depends_on ['T1.2'], got %v\", candidate.DependsOn)\n255: \t}\n256: }\n257: \n258: func TestFromWaveplanTask_NoExternalDeps_EmptyDependsOn(t *testing.T) {\n259: \t// T1's units (T1.1, T1.2) only depend on each other, no external deps.\n260: \tplanPath := makeFixturePlan(t)\n261: \n262: \tcandidate, err := FromWaveplanTask(planPath, \"T1\")\n263: \tif err != nil {\n264: \t\tt.Fatalf(\"unexpected error: %v\", err)\n265: \t}\n266: \n267: \tif len(candidate.DependsOn) != 0 {\n268: \t\tt.Errorf(\"expected empty depends_on for T1, got %v\", candidate.DependsOn)\n269: \t}\n270: }\n271: \n272: func TestFromWaveplanUnit_DependsOnFromUnit(t *testing.T) {\n273: \tplanPath := makeFixturePlan(t)\n274: \n275: \t// T1.2 depends on [\"T1.1\"]\n276: \tcandidate, err := FromWaveplanUnit(planPath, \"T1.2\")\n277: \tif err != nil {\n278: \t\tt.Fatalf(\"unexpected error: %v\", err)\n279: \t}\n280: \n281: \tif len(candidate.DependsOn) != 1 {\n282: \t\tt.Fatalf(\"expected 1 depends_on, got %d: %v\", len(candidate.DependsOn), candidate.DependsOn)\n283: \t}\n284: \tif candidate.DependsOn[0] != \"T1.1\" {\n285: \t\tt.Errorf(\"expected depends_on ['T1.1'], got %v\", candidate.DependsOn)\n286: \t}\n287: }\n288: \n289: func TestFromWaveplanTask_EmptyPlanPath_ReturnsError(t *testing.T) {\n290: \t_, err := FromWaveplanTask(\"\", \"T1\")\n291: \tif err == nil {\n292: \t\tt.Fatal(\"expected error for empty plan path, got nil\")\n293: \t}\n294: }\n295: \n296: func TestFromWaveplanUnit_EmptyPlanPath_ReturnsError(t *testing.T) {\n297: \t_, err := FromWaveplanUnit(\"\", \"T1.1\")\n298: \tif err == nil {\n299: \t\tt.Fatal(\"expected error for empty plan path, got nil\")\n300: \t}\n301: }\n302: \n303: func TestFromWaveplanTask_MissingDocRef_ReturnsError(t *testing.T) {\n304: \t// Plan with a doc_ref that doesn't exist in doc_index.\n305: \tbrokenPlan := `{\n306:   \"schema_version\": 1,\n307:   \"generated_on\": \"2026-05-13\",\n308:   \"plan\": {\"id\": \"broken\", \"title\": \"Broken Plan\"},\n309:   \"tasks\": {\n310:     \"T1\": {\n311:       \"title\": \"Broken\",\n312:       \"plan_line\": 10,\n313:       \"doc_refs\": [\"plan\", \"nonexistent_ref\"],\n314:       \"files\": []\n315:     }\n316:   },\n317:   \"units\": {},\n318:   \"doc_index\": {\n319:     \"plan\": {\"path\": \"docs/plan.md\", \"line\": 1, \"kind\": \"plan\"}\n320:   }\n321: }`\n322: \tdir := t.TempDir()\n323: \tp := filepath.Join(dir, \"broken.json\")\n324: \tos.WriteFile(p, []byte(brokenPlan), 0644)\n325: \n326: \t_, err := FromWaveplanTask(p, \"T1\")\n327: \tif err == nil {\n328: \t\tt.Fatal(\"expected error for missing doc_ref, got nil\")\n329: \t}\n330: }\n331: \n332: func TestCandidate_SourceIsWaveplan(t *testing.T) {\n333: \tplanPath := makeFixturePlan(t)\n334: \n335: \ttaskCandidate, err := FromWaveplanTask(planPath, \"T1\")\n336: \tif err != nil {\n337: \t\tt.Fatalf(\"unexpected error: %v\", err)\n338: \t}\n339: \tif taskCandidate.Source != \"waveplan\" {\n340: \t\tt.Errorf(\"expected task candidate source 'waveplan', got '%s'\", taskCandidate.Source)\n341: \t}\n342: \n343: \tunitCandidate, err := FromWaveplanUnit(planPath, \"T1.1\")\n344: \tif err != nil {\n345: \t\tt.Fatalf(\"unexpected error: %v\", err)\n346: \t}\n347: \tif unitCandidate.Source != \"waveplan\" {\n348: \t\tt.Errorf(\"expected unit candidate source 'waveplan', got '%s'\", unitCandidate.Source)\n349: \t}\n350: }\n351: \n352: func TestCandidate_StructurallyValidForEstimator(t *testing.T) {\n353: \t// Verify the candidate is structurally valid for contextsize.ContextCandidate.\n354: \tplanPath := makeFixturePlan(t)\n355: \n356: \tcandidate, err := FromWaveplanTask(planPath, \"T1\")\n357: \tif err != nil {\n358: \t\tt.Fatalf(\"unexpected error: %v\", err)\n359: \t}\n360: \n361: \t// Should be a valid ContextCandidate that can be used with the estimator.\n362: \t// This test verifies no nil slices or invalid fields.\n363: \tvar _ contextsize.ContextCandidate = candidate\n364: \tif candidate.ID == \"\" {\n365: \t\tt.Error(\"expected non-empty ID\")\n366: \t}\n367: \tif candidate.Title == \"\" {\n368: \t\tt.Error(\"expected non-empty title\")\n369: \t}\n370: }\n\n(End of file - total 370 lines)\n</content>","metadata":{"preview":"package adapter\n\nimport (\n\t\"os\"\n\t\"path/filepath\"\n\t\"testing\"\n\n\t\"github.com/darkbit1001/Stability-Toys/waveplan-mcp/internal/contextsize\"\n)\n\n// fixturePlan is a minimal execution-waves JSON for testing the adapter.\nvar fixturePlan = `{\n  \"schema_version\": 1,\n  \"generated_on\": \"2026-05-13\",\n  \"plan\": {\n    \"id\": \"test-plan\",\n    \"title\": \"Test Plan\"\n  },\n  \"tasks\": {\n    \"T1\": {","truncated":false,"loaded":[]},"title":"internal/contextsize/adapter/waveplan_test.go","time":{"start":1778783716275,"end":1778783716289}},"id":"prt_e27c583b2001JNM2ztSKXfPlvV","sessionID":"ses_1d83af79fffedWQViHmEZd7IV3","messageID":"msg_e27c56068002QCQLGZV3sF28Hm"}}
{"type":"tool_use","timestamp":1778783716291,"sessionID":"ses_1d83af79fffedWQViHmEZd7IV3","part":{"type":"tool","tool":"read","callID":"call_16f74dd85030404e90cd7815","state":{"status":"completed","input":{"filePath":"/Users/darkbit1001/workspace/waveplan-mcp/docs/superpowers/specs/2026-05-13-context-sizer-design.md","offset":330},"output":"<path>/Users/darkbit1001/workspace/waveplan-mcp/docs/superpowers/specs/2026-05-13-context-sizer-design.md</path>\n<type>file</type>\n<content>\n330: func FromWaveplanTask(planPath string, taskID string) (contextsize.ContextCandidate, error)\n331: func FromWaveplanUnit(planPath string, unitID string) (contextsize.ContextCandidate, error)\n332: ```\n333: \n334: V1 mapping rules:\n335: \n336: - **Task candidate**\n337:   - `id` = task ID\n338:   - `title` = task title\n339:   - `description` = `\"\"`\n340:   - `referenced_files` = union of task `files` and task `doc_refs` resolved through `doc_index`\n341:   - `depends_on` = collapsed external task dependencies derived from unit-level dependencies\n342:   - `source` = `\"waveplan\"`\n343: - **Unit candidate**\n344:   - `id` = unit ID\n345:   - `title` = unit title\n346:   - `description` = `\"\"`\n347:   - `referenced_files` = unit `doc_refs` resolved through `doc_index`\n348:   - `depends_on` = unit `depends_on`\n349:   - `source` = `\"waveplan\"`\n350: \n351: Additional rules:\n352: \n353: - Deduplicate and sort `referenced_files`\n354: - Reject missing `task_id` / `unit_id` deterministically\n355: - Reject invalid selector combinations (`--candidate` with `--plan`, `--task` with `--unit`, missing selector for `--plan`)\n356: - Keep the raw `--candidate` path for advanced/manual use\n357: \n358: ### Adapter Scope\n359: \n360: Keep the estimator package source-agnostic. The Waveplan-specific decode and\n361: mapping logic belongs in a separate adapter layer, not in `internal/contextsize`\n362: itself.\n363: \n364: ## Future Extensions (deferred)\n365: \n366: - **FP issue adapter**: `FromFPIssue(issue) ContextCandidate`\n367: - **Tree-sitter/LSP enrichment**: symbol maps, precise dependency graph\n368: - **Dagdir integration**: candidates from `dagdir2waveplan` output\n369: \n370: These extend the adapters layer without changing the core `Estimate()` contract.\n371: \n372: ---\n373: \n374: ## MCP Tool (implemented)\n375: \n376: The MCP tool `waveplan_context_estimate` is implemented. See `docs/superpowers/specs/2026-05-13-contextsizer-mcp-integration.md` for the full spec.\n377: \n378: ---\n379: \n380: ## Changelog\n381: \n382: - **2026-05-13** Initial draft. MCP tool implemented (FP-vedqsmra, see `2026-05-13-contextsizer-mcp-integration.md`).\n383: - **2026-05-13** Added native Waveplan adapter contract and `waveplan-cli context estimate --plan/--task|--unit` follow-up scope.\n\n(End of file - total 383 lines)\n</content>","metadata":{"preview":"func FromWaveplanTask(planPath string, taskID string) (contextsize.ContextCandidate, error)\nfunc FromWaveplanUnit(planPath string, unitID string) (contextsize.ContextCandidate, error)\n```\n\nV1 mapping rules:\n\n- **Task candidate**\n  - `id` = task ID\n  - `title` = task title\n  - `description` = `\"\"`\n  - `referenced_files` = union of task `files` and task `doc_refs` resolved through `doc_index`\n  - `depends_on` = collapsed external task dependencies derived from unit-level dependencies\n  - `source` = `\"waveplan\"`\n- **Unit candidate**\n  - `id` = unit ID\n  - `title` = unit title\n  - `description` = `\"\"`\n  - `referenced_files` = unit `doc_refs` resolved through `doc_index`\n  - `depends_on` = unit `depends_on`\n  - `source` = `\"waveplan\"`","truncated":false,"loaded":[]},"title":"docs/superpowers/specs/2026-05-13-context-sizer-design.md","time":{"start":1778783716272,"end":1778783716290}},"id":"prt_e27c583aa001FllQJvpXOrmYCO","sessionID":"ses_1d83af79fffedWQViHmEZd7IV3","messageID":"msg_e27c56068002QCQLGZV3sF28Hm"}}
