+type Watcher struct {
+	options  Options
+	interval time.Duration
+}
+
+// New constructs a watcher. A non-positive interval defaults to one second.
+func New(options Options, interval time.Duration) *Watcher {
+	if interval <= 0 {
+		interval = time.Second
+	}
+	return &Watcher{
+		options:  options,
+		interval: interval,
+	}
+}
