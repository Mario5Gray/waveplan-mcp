+// Options identifies the files and directories read by one watcher poll.
+type Options struct {
+	PlanPaths    []string
+	StatePaths   []string
+	JournalPaths []string
+	NotePaths    []string
+	LogDirs      []string
+	Logs         []model.LogRef
