    88	// PollOnce loads all configured files into one snapshot.
    89	func PollOnce(options Options) (Snapshot, error) {
    90		snapshot := Snapshot{
    91			Logs:     append([]model.LogRef(nil), options.Logs...),
    92			LoadedAt: time.Now(),
    93		}
    94	
    95		for _, path := range options.PlanPaths {
    96			plan, err := model.LoadPlan(path)
    97			if err != nil {
    98				return Snapshot{}, fmt.Errorf("load plan %q: %w", path, err)
    99			}
   100			snapshot.Plans = append(snapshot.Plans, LoadedPlan{Path: path, Plan: plan})
   101		}
   102		for _, path := range options.StatePaths {
   103			state, err := model.LoadState(path)
   104			if err != nil {
   105				return Snapshot{}, fmt.Errorf("load state %q: %w", path, err)
   106			}
   107			snapshot.States = append(snapshot.States, LoadedState{Path: path, State: state})
   108		}
   109		for _, path := range options.JournalPaths {
   110			journal, err := model.LoadJournal(path)
   111			if err != nil {
   112				return Snapshot{}, fmt.Errorf("load journal %q: %w", path, err)
   113			}
   114			snapshot.Journals = append(snapshot.Journals, LoadedJournal{Path: path, Journal: journal})
   115		}
   116		for _, path := range options.NotePaths {
   117			notes, err := model.LoadNotes(path)
   118			if err != nil {
   119				return Snapshot{}, fmt.Errorf("load notes %q: %w", path, err)
   120			}
   121			snapshot.Notes = append(snapshot.Notes, LoadedNotes{Path: path, Notes: notes})
   122		}
   123		for _, dir := range options.LogDirs {
   124			logs, err := discovery.DiscoverLogs(dir)
   125			if err != nil {
   126				return Snapshot{}, fmt.Errorf("discover logs %q: %w", dir, err)
   127			}
   128			snapshot.Logs = append(snapshot.Logs, logs...)
   129		}
   130		sort.Slice(snapshot.Logs, func(left, right int) bool {
   131			return snapshot.Logs[left].Path < snapshot.Logs[right].Path
   132		})
   133		return snapshot, nil
   134	}
   135	
   136	// Run emits an immediate snapshot, then emits another snapshot after each tick.
   137	func (w *Watcher) Run(ctx context.Context, handle func(Snapshot) error) error {
   138		if handle == nil {
   139			return fmt.Errorf("watcher handler is nil")
   140		}
   141		if err := w.poll(handle); err != nil {
   142			return err
   143		}
   144	
   145		ticker := time.NewTicker(w.interval)
   146		defer ticker.Stop()
   147	
   148		for {
   149			select {
   150			case <-ctx.Done():
   151				return nil
   152			case <-ticker.C:
   153				if err := w.poll(handle); err != nil {
   154					return err
   155				}
   156			}
   157		}
   158	}
   159	
   160	func (w *Watcher) poll(handle func(Snapshot) error) error {
   161		snapshot, err := PollOnce(w.options)
   162		if err != nil {
   163			return err
   164		}
   165		if err := handle(snapshot); err != nil {
   166			return fmt.Errorf("handle snapshot: %w", err)
   167		}
   168		return nil
   169	}

