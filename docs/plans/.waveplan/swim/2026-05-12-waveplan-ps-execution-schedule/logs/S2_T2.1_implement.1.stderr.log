+		{
+			Path:    filepath.Join(root, "a", "S1_T1.1_review.2.stdout.log"),
+			StepID:  "S1_T1.1_review",
+			Attempt: 2,
+			Stream:  model.LogStreamStdout,
+		},
+		{
+			Path:    filepath.Join(root, "z", "S2_T2.1_implement.1.stderr.log"),
