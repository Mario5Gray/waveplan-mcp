+func TestDiscoverLogsParsesAndSortsValidLogFiles(t *testing.T) {
+	root := t.TempDir()
+	writeFile(t, filepath.Join(root, "z", "S2_T2.1_implement.1.stderr.log"), "err")
+	writeFile(t, filepath.Join(root, "a", "S1_T1.1_review.2.stdout.log"), "out")
