+	if !strings.Contains(err.Error(), badPath) {
+		t.Fatalf("DiscoverLogs() error = %q, want path %q", err, badPath)
+	}
+}
+
+func TestDiscoverAllCombinesMultipleRootsDeterministically(t *testing.T) {
+	first := t.TempDir()
+	second := t.TempDir()
