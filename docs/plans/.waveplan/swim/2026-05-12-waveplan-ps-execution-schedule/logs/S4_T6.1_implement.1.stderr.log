+	flags.StringArrayVar(&opts.planDirs, "plan-dir", nil, "directory to recursively scan for execution-waves plans")
+	flags.StringArrayVar(&opts.stateDirs, "state-dir", nil, "directory to recursively scan for waveplan state sidecars")
+	flags.StringArrayVar(&opts.journalDirs, "journal-dir", nil, "directory to recursively scan for SWIM journals")
+	flags.StringArrayVar(&opts.noteDirs, "note-dir", nil, "directory to recursively scan for txtstore notes")
+	flags.StringArrayVar(&opts.logDirs, "log-dir", nil, "directory to recursively scan for SWIM logs")
+	flags.DurationVar(&opts.interval, "interval", time.Second, "live refresh interval")
+	flags.IntVar(&opts.tailLimit, "tail-limit", 10, "maximum tail rows to render")
