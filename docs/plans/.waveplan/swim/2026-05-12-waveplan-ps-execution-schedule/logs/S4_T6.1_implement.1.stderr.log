+	return nil
+}
+
+func flagWasPassed(flags *flag.FlagSet, name string) bool {
+	changed := false
+	flags.Visit(func(flag *flag.Flag) {
+		if flag.Name == name {
+			changed = true
+		}
+	})
+	return changed
+}
