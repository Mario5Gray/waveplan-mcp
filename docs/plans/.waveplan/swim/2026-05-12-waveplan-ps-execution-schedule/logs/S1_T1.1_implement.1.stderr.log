+      "review_note": "ok",
+      "git_sha": "abc123",
+      "finished_at": "2026-05-12 12:11"
+    }
+  }
+}`)
+
+	state, err := LoadState(path)
+	if err != nil {
+		t.Fatalf("LoadState() error = %v", err)
+	}
+
+	if got := state.Taken["T1.1"].TakenBy; got != "phi" {
+		t.Fatalf("taken_by = %q, want phi", got)
