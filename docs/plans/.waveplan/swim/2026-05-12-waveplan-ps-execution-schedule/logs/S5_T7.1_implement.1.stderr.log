	waves := make([]model.Wave, 0, len(waveNumbers))
	for _, wave := range waveNumbers {
		units := grouped[wave]
		sort.Strings(units)
		waves = append(waves, model.Wave{Wave: wave, Units: units})
	}
	return waves
}

type tailRow struct {
	taskID string
