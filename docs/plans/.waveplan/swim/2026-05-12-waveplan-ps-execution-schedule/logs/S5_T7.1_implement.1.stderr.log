	queued int
}

func (a *fakeApp) SetRoot(root tview.Primitive, fullscreen bool) appRunner {
	return a
}

func (a *fakeApp) Run() error {
	return nil
}

func (a *fakeApp) Stop() {
}

func (a *fakeApp) QueueUpdateDraw(fn func()) appRunner {
	a.queued++
	if fn != nil {
		fn()
	}
	return a
}

