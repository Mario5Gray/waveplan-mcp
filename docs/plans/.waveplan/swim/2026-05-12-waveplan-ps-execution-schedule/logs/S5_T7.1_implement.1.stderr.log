diff --git a/waveplan-ps/tests/integration/waveplan_ps_test.go b/waveplan-ps/tests/integration/waveplan_ps_test.go
new file mode 100644
index 0000000000000000000000000000000000000000..016a80a858813abe54f45f15c634efc9760edfbf
--- /dev/null
