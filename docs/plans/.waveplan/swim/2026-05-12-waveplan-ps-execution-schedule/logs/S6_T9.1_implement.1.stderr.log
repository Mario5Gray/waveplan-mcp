    indeg: dict[str, int] = {k: 0 for k in units}
    outgoing: dict[str, list[str]] = {k: [] for k in units}
    for uid, unit in units.items():
        for dep in unit["depends_on"]:
            outgoing[dep].append(uid)
            indeg[uid] += 1

    queue = [uid for uid, deg in indeg.items() if deg == 0]
    queue.sort(key=_unit_sort_key)
    seen = 0
    while queue:
        node = queue.pop(0)
        seen += 1
        for child in sorted(outgoing[node], key=_unit_sort_key):
            indeg[child] -= 1
            if indeg[child] == 0:
                queue.append(child)
                queue.sort(key=_unit_sort_key)
    if seen != len(units):
        raise ValueError("unit dependency graph contains a cycle")

    # ---- Canonicalize: preserve every field, deterministic ordering ----
    def _task_sort_key(tid: str) -> tuple[int, int, str]:
        # Numeric-prefixed task IDs (T1, T12) sort numerically; others lexicographically.
        m = re.match(r"^[A-Z]([0-9]+)$", tid)
        if m:
            return (0, int(m.group(1)), tid)
        return (1, 0, tid)

    canonical_units: dict[str, dict] = {}
    for unit_id in sorted(units.keys(), key=_unit_sort_key):
        unit = dict(units[unit_id])
        unit["depends_on"] = sorted(unit["depends_on"], key=_unit_sort_key)
        canonical_units[unit_id] = _ordered(unit, _UNIT_FIELD_ORDER)

    canonical_tasks: dict[str, dict] = {}
    for task_id in sorted(tasks.keys(), key=_task_sort_key):
        canonical_tasks[task_id] = _ordered(dict(tasks[task_id]), _TASK_FIELD_ORDER)

    canonical_doc_index = {k: doc_index[k] for k in sorted(doc_index.keys())}
    canonical_fp_index = {k: fp_index[k] for k in sorted(fp_index.keys())}

    # Build canonical top-level: known fields first in order, then remaining
    # top-level keys alphabetically (preserves any future / experimental fields).
    rebuilt = dict(raw)
    rebuilt["fp_index"] = canonical_fp_index
    rebuilt["doc_index"] = canonical_doc_index
    rebuilt["tasks"] = canonical_tasks
    rebuilt["units"] = canonical_units
    return _ordered(rebuilt, _TOP_FIELD_ORDER)


def _swim_compile_plan_json(in_path: str, out_path: str | None) -> None:
    src = Path(in_path)
    if not src.exists():
        raise ValueError(f"input file not found: {in_path}")
    try:
        payload = json.loads(src.read_text(encoding="utf-8"))
    except json.JSONDecodeError as e:
        raise ValueError(f"invalid JSON in input file: {e}") from e
    if not isinstance(payload, dict):
        raise ValueError("top-level JSON must be an object")

    canonical = _validate_and_canonicalize_plan_json(payload)
    rendered = json.dumps(canonical, indent=2) + "\n"
    if out_path:
        Path(out_path).write_text(rendered, encoding="utf-8")
        print(json.dumps({"ok": True, "input": str(src), "output": str(Path(out_path)), "mode": "write"}, indent=2))
        return
    print(rendered, end="")


def _swim_not_wired(subcommand: str) -> None:
    print(json.dumps({
        "ok": False,
        "error": "not_wired_yet",
        "subcommand": subcommand,
    }, indent=2))
    sys.exit(2)


def _emit_json(obj: dict, code: int = 0) -> None:
    print(json.dumps(obj, indent=2))
    sys.exit(code)


def _default_swim_journal(schedule_path: str) -> str:
    return schedule_path + ".journal.json"


def _derive_swim_state(schedule_path: str) -> str | None:
    env_state = os.environ.get("WAVEPLAN_STATE")
    if env_state:
        return env_state
    try:
        payload = json.loads(Path(schedule_path).read_text(encoding="utf-8"))
    except Exception:
        return None
    execution = payload.get("execution")
    if not isinstance(execution, list):
        return None

