{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/darkbit1001/waveplan-mcp/main/docs/specs/swim-schedule-schema-v2.json",
  "title": "SWIM Execution Schedule v2",
  "description": "Schema for emitted execution schedule rows (wp-emit-wave-execution.sh).",
  "type": "object",
  "required": ["schema_version", "execution"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 2
    },
    "plan": {
      "type": "object"
    },
    "generated_on": {
      "type": "string"
    },
    "execution": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/execution_row"
      }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "task_status": {
      "type": "string",
      "enum": ["available", "taken", "review_taken", "review_ended", "completed"]
    },
    "status_wrapper": {
      "type": "object",
      "required": ["task_status"],
      "properties": {
        "task_status": {
          "$ref": "#/$defs/task_status"
        }
      },
      "additionalProperties": false
    },
    "execution_row": {
      "type": "object",
      "required": [
        "seq",
        "step_id",
        "task_id",
        "action",
        "requires",
        "produces",
        "invoke"
      ],
      "properties": {
        "seq": {
          "type": "integer",
          "minimum": 1
        },
        "step_id": {
          "type": "string",
          "pattern": "^S[0-9]+_[A-Za-z0-9._\\-]+_(implement|review|end_review|finish)$"
        },
        "task_id": {
          "type": "string",
          "minLength": 1
        },
        "action": {
          "type": "string",
          "enum": ["implement", "review", "end_review", "finish"]
        },
        "requires": {
          "$ref": "#/$defs/status_wrapper"
        },
        "produces": {
          "$ref": "#/$defs/status_wrapper"
        },
        "invoke": {
          "type": "object",
          "required": ["argv"],
          "properties": {
            "argv": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        },
        "wp_invoke": {
          "type": "string",
          "description": "Legacy debug-only string form of invoke.argv"
        },
        "status": {
          "type": "string",
          "description": "Deprecated status marker kept for compatibility",
          "deprecated": true
        }
      },
      "additionalProperties": false
    }
  }
}
