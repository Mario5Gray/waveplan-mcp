{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/darkbit1001/waveplan-mcp/main/docs/specs/swim-schedule-schema-v3.json",
  "title": "SWIM Execution Schedule v3",
  "description": "Schema for emitted execution schedule rows with typed operations.",
  "type": "object",
  "required": ["schema_version", "execution"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 3
    },
    "plan": {
      "type": "object"
    },
    "generated_on": {
      "type": "string"
    },
    "execution": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/execution_row"
      }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "task_status": {
      "type": "string",
      "enum": ["available", "taken", "review_taken", "review_ended", "completed"]
    },
    "status_wrapper": {
      "type": "object",
      "required": ["task_status"],
      "properties": {
        "task_status": {
          "$ref": "#/$defs/task_status"
        }
      },
      "additionalProperties": false
    },
    "invoke": {
      "type": "object",
      "required": ["argv"],
      "properties": {
        "argv": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "agent_dispatch_operation": {
      "type": "object",
      "required": ["kind", "target", "agent"],
      "properties": {
        "kind": {
          "const": "agent_dispatch"
        },
        "target": {
          "type": "string",
          "enum": ["codex", "claude", "opencode"]
        },
        "agent": {
          "type": "string",
          "minLength": 1
        },
        "reviewer": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "state_transition_operation": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": {
          "const": "state_transition"
        },
        "review_note": {
          "type": "string"
        },
        "git_sha": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "operation": {
      "oneOf": [
        {
          "$ref": "#/$defs/agent_dispatch_operation"
        },
        {
          "$ref": "#/$defs/state_transition_operation"
        }
      ]
    },
    "execution_row": {
      "type": "object",
      "required": [
        "seq",
        "step_id",
        "task_id",
        "action",
        "operation",
        "invoke"
      ],
      "properties": {
        "seq": {
          "type": "integer",
          "minimum": 1
        },
        "step_id": {
          "type": "string",
          "pattern": "^S[0-9]+_[A-Za-z0-9.\\-]+_(implement|end_review|finish|review(_r[0-9]+)?|fix(_r[0-9]+)?)$"
        },
        "task_id": {
          "type": "string",
          "minLength": 1
        },
        "action": {
          "type": "string",
          "enum": ["implement", "review", "end_review", "finish", "fix"]
        },
        "requires": {
          "$ref": "#/$defs/status_wrapper"
        },
        "produces": {
          "$ref": "#/$defs/status_wrapper"
        },
        "operation": {
          "$ref": "#/$defs/operation"
        },
        "invoke": {
          "$ref": "#/$defs/invoke"
        },
        "wp_invoke": {
          "type": "string",
          "description": "Legacy debug-only string form of invoke.argv"
        },
        "status": {
          "type": "string",
          "description": "Deprecated status marker kept for compatibility",
          "deprecated": true
        }
      },
      "additionalProperties": false
    }
  }
}
