{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/darkbit1001/waveplan-mcp/main/docs/specs/swim-journal-schema-v1.json",
  "title": "SWIM Execution Journal v1",
  "description": "Schema for resumable execution journal sidecar.",
  "type": "object",
  "required": ["schema_version", "schedule_path", "cursor", "events"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "schedule_path": {
      "type": "string",
      "minLength": 1
    },
    "cursor": {
      "type": "integer",
      "minimum": 0
    },
    "last_event": {
      "$ref": "#/$defs/event"
    },
    "events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/event"
      }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "task_status": {
      "type": "string",
      "enum": ["available", "taken", "review_taken", "review_ended", "completed"]
    },
    "state": {
      "type": "object",
      "properties": {
        "task_status": {
          "$ref": "#/$defs/task_status"
        }
      },
      "additionalProperties": true
    },
    "event": {
      "type": "object",
      "required": [
        "event_id",
        "step_id",
        "seq",
        "task_id",
        "action",
        "attempt",
        "started_on",
        "state_before",
        "state_after"
      ],
      "properties": {
        "event_id": {
          "type": "string",
          "pattern": "^E[0-9]{4,}$"
        },
        "step_id": {
          "type": "string",
          "pattern": "^S[0-9]+_[A-Za-z0-9._\\-]+_(implement|review|end_review|finish)$"
        },
        "seq": {
          "type": "integer",
          "minimum": 1
        },
        "task_id": {
          "type": "string",
          "minLength": 1
        },
        "action": {
          "type": "string",
          "enum": ["implement", "review", "end_review", "finish"]
        },
        "attempt": {
          "type": "integer",
          "minimum": 1
        },
        "started_on": {
          "type": "string",
          "format": "date-time"
        },
        "completed_on": {
          "type": "string",
          "format": "date-time"
        },
        "outcome": {
          "type": "string",
          "enum": ["applied", "failed", "blocked", "unknown", "waived"]
        },
        "state_before": {
          "$ref": "#/$defs/state"
        },
        "state_after": {
          "$ref": "#/$defs/state"
        },
        "exit_code": {
          "type": "integer"
        },
        "stdout_path": {
          "type": "string"
        },
        "stderr_path": {
          "type": "string"
        },
        "operator": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "waived_on": {
          "type": "string",
          "format": "date-time"
        }
      },
      "allOf": [
        {
          "if": {
            "required": ["outcome"]
          },
          "then": {
            "required": ["completed_on"]
          }
        },
        {
          "if": {
            "required": ["completed_on"]
          },
          "then": {
            "required": ["outcome"]
          }
        },
        {
          "if": {
            "properties": {
              "outcome": {
                "const": "waived"
              }
            },
            "required": ["outcome"]
          },
          "then": {
            "required": ["operator", "reason", "waived_on"]
          }
        }
      ],
      "additionalProperties": true
    }
  }
}
